<smax xmlns:optional="http://whatsapp.net/smax/optional" xmlns:smax="http://whatsapp.net/smax">
    <mock name="GetQuota">
        <request>
            <iq id=":stanzaID" to=":domainJID:s.whatsapp.net" type="get" xmlns="w:mex">
                <trace>
                    <flow_id>:string</flow_id>
                </trace>
                <query query_id="${MESSAGE_CAPPING_QUERY_ID}">
                    <smax:json>
                        {
                            "queryId":"${MESSAGE_CAPPING_QUERY_ID}",
                            "variables":{"input":{"type":"INDIVIDUAL_NEW_CHAT_MSG"}}
                        }
                    </smax:json>
                </query>
            </iq>
        </request>
        <response name="FirstWarning">
            <iq from="${iq.to}" id="${iq.id}" type='result'>
                <result>
                    <smax:json>
                        {
                            "data": {
                                "xwa2_message_capping_info": {
                                    "total_quota": 100,
                                    "used_quota": 50,
                                    "cycle_start_timestamp": "1759302000",
                                    "cycle_end_timestamp": "1761807600",
                                    "server_sent_timestamp": "1760511600",
                                    "ote_status": "NOT_ELIGIBLE",
                                    "mv_status": "NOT_ELIGIBLE",
                                    "capping_status": "FIRST_WARNING"
                                }
                            }
                        }
                    </smax:json>
                </result>
            </iq>
        </response>
        <response name="SecondWarning">
            <iq from="${iq.to}" id="${iq.id}" type='result'>
                <result>
                    <smax:json>
                        {
                            "data": {
                                "xwa2_message_capping_info": {
                                    "total_quota": 100,
                                    "used_quota": 75,
                                    "cycle_start_timestamp": "1759302000",
                                    "cycle_end_timestamp": "1761807600",
                                    "server_sent_timestamp": "1760511620",
                                    "ote_status": "ELIGIBLE",
                                    "mv_status": "NOT_ELIGIBLE",
                                    "capping_status": "SECOND_WARNING"
                                }
                            }
                        }
                    </smax:json>
                </result>
            </iq>
        </response>
        <response name="Capped">
            <iq from="${iq.to}" id="${iq.id}" type='result'>
                <result>
                    <smax:json>
                        {
                            "data": {
                                "xwa2_message_capping_info": {
                                    "total_quota": 100,
                                    "used_quota": 100,
                                    "cycle_start_timestamp": "1759302000",
                                    "cycle_end_timestamp": "1761807600",
                                    "server_sent_timestamp": "1760519650",
                                    "ote_status": "NOT_ELIGIBLE",
                                    "mv_status": "NOT_ELIGIBLE",
                                    "capping_status": "CAPPED"
                                }
                            }
                        }
                    </smax:json>
                </result>
            </iq>
        </response>
        <response name="Uncapped">
            <iq from="${iq.to}" id="${iq.id}" type='result'>
                <result>
                    <smax:json>
                        {
                            "data": {
                                "xwa2_message_capping_info": {
                                    "total_quota": 0,
                                    "used_quota": 100,
                                    "cycle_start_timestamp": "1759302000",
                                    "cycle_end_timestamp": "1761807600",
                                    "server_sent_timestamp": "1760519800",
                                    "ote_status": "NOT_ELIGIBLE",
                                    "mv_status": "NOT_ELIGIBLE",
                                    "capping_status": "NONE"
                                }
                            }
                        }
                    </smax:json>
                </result>
            </iq>
        </response>
    </mock>
</smax>
