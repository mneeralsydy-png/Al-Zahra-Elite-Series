<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_pressed="true">
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/text" />
            <stroke
                android:width="@dimen/dimen004f"
                android:color="@color/color08eb" />
            <corners
                android:radius="10.0dip" />
        </shape>
    </item>
    <item
        android:state_pressed="false">
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/tag_unhandled_key_listeners" />
            <stroke
                android:width="@dimen/dimen004f"
                android:color="@color/color08eb" />
            <corners
                android:radius="10.0dip" />
        </shape>
    </item>
</selector>