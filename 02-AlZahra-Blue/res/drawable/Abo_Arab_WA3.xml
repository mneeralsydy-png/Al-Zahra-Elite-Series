<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#ff000a44"
                android:endColor="#ff0098ff"
                android:angle="270.0"
                android:centerColor="#ffe0ff50" />
            <stroke
                android:width="3.0dip"
                android:color="#ffffff00" />
            <corners
                android:radius="100.0dip" />
            <padding
                android:left="10.0dip"
                android:top="4.0dip"
                android:right="10.0dip"
                android:bottom="4.0dip" />
        </shape>
    </item>
    <item
        android:state_focused="true">
        <shape>
            <gradient
                android:startColor="#ff000a44"
                android:endColor="#ff0098ff"
                android:angle="270.0"
                android:centerColor="#ffe0ff50" />
            <stroke
                android:width="1.0dip"
                android:color="#fff06292" />
            <corners
                android:radius="100.0dip" />
            <padding
                android:left="10.0dip"
                android:top="4.0dip"
                android:right="10.0dip"
                android:bottom="4.0dip" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#ff000a44"
                android:endColor="#ff0098ff"
                android:angle="0.0"
                android:centerColor="#ffe0ff50" />
            <stroke
                android:width="1.0dip"
                android:color="#fff06292" />
            <corners
                android:radius="100.0dip" />
            <padding
                android:left="10.0dip"
                android:top="4.0dip"
                android:right="10.0dip"
                android:bottom="4.0dip" />
        </shape>
    </item>
</selector>