<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.wds.components.topbar.WDSToolbar
        android:id="@id/register_email_title_toolbar"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:attr08f4="@style/style0704" />
    <ScrollView
        android:id="@id/scroll_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:fillViewport="true">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="@dimen/dimen0ce7"
            android:paddingBottom="@dimen/dimen0ce7"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dimen0cee"
            android:paddingEnd="@dimen/dimen0cee">
            <ViewStub
                android:layout_gravity="center"
                android:id="@id/title_v2"
                android:layout="@layout/layout0e45"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dimen0cea" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textSize="@dimen/dimen0fb6"
                android:gravity="center_horizontal"
                android:id="@id/register_email_description"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dimen0cee"
                android:text="@string/str1190"
                android:lineSpacingMultiplier="@dimen/dimen0bd5"
                style="@style/style03c8" />
            <com.whatsapp.ui.coreui.WaEditText
                android:textColor="?attr066e"
                android:textColorHint="?attr0a46"
                android:ellipsize="end"
                android:id="@id/register_email_text_input"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:hint="@string/str11c2"
                android:maxLines="1"
                android:lines="1"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:autofillHints="emailAddress" />
            <ViewStub
                android:id="@id/invalid_email_sub_text_view_stub"
                android:layout="@layout/layout0939"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <HorizontalScrollView
                android:id="@id/email_domain_chip_scroll_view"
                android:scrollbars="none"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true">
                <com.whatsapp.ui.wds.components.chip.WDSChipGroup
                    android:orientation="horizontal"
                    android:id="@id/email_domain_chip_group"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </HorizontalScrollView>
            <Space
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:layout_weight="1.0" />
            <com.whatsapp.ui.wds.components.button.WDSButtonGroup
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.wds.components.button.WDSButton
                    android:enabled="false"
                    android:id="@id/register_email_submit"
                    android:layout_width="fill_parent"
                    android:layout_marginTop="@dimen/dimen1039"
                    android:text="@string/str2157"
                    style="@style/style0555" />
                <com.whatsapp.ui.wds.components.button.WDSButton
                    android:id="@id/register_email_skip"
                    android:layout_width="fill_parent"
                    android:text="@string/str427b"
                    style="@style/style0557" />
            </com.whatsapp.ui.wds.components.button.WDSButtonGroup>
        </LinearLayout>
    </ScrollView>
</LinearLayout>