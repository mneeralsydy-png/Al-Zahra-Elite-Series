<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:paddingTop="@dimen/dimen0ce8"
    android:paddingBottom="@dimen/dimen0ce8"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:layout_marginStart="@dimen/dimen0cee"
        android:layout_marginEnd="@dimen/dimen0cee">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="?attr066e"
            android:ellipsize="end"
            android:layout_gravity="start"
            android:id="@id/language_name"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAlignment="viewStart"
            app:attr0a24="wds_font_body1"
            style="@style/style05a4" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="?attr0a46"
            android:ellipsize="end"
            android:layout_gravity="start"
            android:id="@id/language_name_translated"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAlignment="viewStart"
            app:attr0a24="wds_font_body2"
            style="@style/style05a6" />
    </LinearLayout>
    <com.whatsapp.ui.coreui.checkbox.RtlCheckBox
        android:layout_gravity="center_vertical"
        android:id="@id/language_checkbox"
        android:background="@null"
        android:focusable="false"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dimen0cee"
        style="@style/style0329" />
</LinearLayout>