<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/order_detail_container"
    android:background="@color/color0562"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@id/order_details"
        android:background="@color/color0562"
        android:paddingBottom="@dimen/dimen102e"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_weight="1.0">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/order_detail_recycler_view"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:attr0488="androidx.recyclerview.widget.LinearLayoutManager" />
    </LinearLayout>
    <View
        android:id="@id/shadow_top"
        android:background="@drawable/merchant_details_downward_shadow"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen0a5f" />
    <RelativeLayout
        android:gravity="center_horizontal"
        android:id="@id/buttons"
        android:background="?attr0a5a"
        android:padding="@dimen/dimen0a5d"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:gravity="center_horizontal"
            android:id="@id/payment_button_wrapper"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:id="@id/button_additional_info"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dimen0a5d">
                <com.whatsapp.ui.coreui.base.TextEmojiLabel
                    android:textSize="@dimen/dimen0fbc"
                    android:gravity="center_horizontal"
                    android:id="@id/terms_of_services_footer"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dimen0a5d"
                    android:lineSpacingMultiplier="1.33"
                    style="@style/style05a8" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textColor="?attr066e"
                    android:id="@id/total_key"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen0a62"
                    android:layout_marginTop="0.0dip"
                    android:text="@string/str232e"
                    android:layout_below="@id/terms_of_services_footer"
                    android:layout_alignParentLeft="true"
                    android:fontFamily="?attr03b8"
                    android:layout_alignParentStart="true"
                    style="@style/style02cc" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textColor="?attr066e"
                    android:id="@id/total_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/dimen0a62"
                    android:layout_alignBaseline="@id/total_key"
                    android:layout_alignParentRight="true"
                    android:fontFamily="?attr03b8"
                    android:layout_alignParentEnd="true"
                    style="@style/style02cd" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textColor="?attr066e"
                    android:id="@id/installment_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/dimen0a62"
                    android:layout_below="@id/total_key"
                    android:layout_alignParentRight="true"
                    android:fontFamily="?attr03b8"
                    android:layout_alignParentEnd="true"
                    style="@style/style02cc" />
                <com.whatsapp.ui.coreui.base.TextEmojiLabel
                    android:textColor="@color/color0924"
                    android:id="@id/learn_more_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/dimen0a62"
                    android:layout_below="@id/installment_info"
                    android:layout_alignParentRight="true"
                    android:fontFamily="?attr03b8"
                    android:layout_alignParentEnd="true"
                    style="@style/style02cc" />
            </RelativeLayout>
            <com.whatsapp.ui.coreui.WaButtonWithLoader
                android:textColor="?attr0a2f"
                android:id="@id/proceed_to_pay_btn"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str4095"
                android:layout_below="@id/button_additional_info"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true" />
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/proceed_to_pay_btn"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fbc"
                    android:textColor="?attr0a46"
                    android:gravity="center"
                    android:id="@id/expiry_footer"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen0a5c"
                    android:lineSpacingMultiplier="1.33"
                    app:attr0a24="wds_font_body3" />
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:id="@id/secure_footer"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen0a5c">
                    <com.whatsapp.ui.coreui.base.WaImageView
                        android:id="@id/icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:attr0838="@drawable/ic_fbpay_lock_gray"
                        app:attr090d="@color/color02b3" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fbc"
                        android:textColor="?attr0a46"
                        android:id="@id/secure_text_footer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str2316"
                        android:lineSpacingExtra="2.0sp"
                        app:attr0a24="wds_font_body3" />
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:gravity="center_horizontal"
            android:id="@id/pending_payment_button_wrapper"
            android:visibility="visible"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.WaButtonWithLoader
                android:textColor="?attr0a2f"
                android:id="@id/confirm_pay_btn"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true" />
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:textColor="?attr0a2f"
                android:id="@id/not_yet_btn"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str2312"
                android:layout_below="@id/confirm_pay_btn"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                style="@style/style055d" />
        </RelativeLayout>
    </RelativeLayout>
</LinearLayout>