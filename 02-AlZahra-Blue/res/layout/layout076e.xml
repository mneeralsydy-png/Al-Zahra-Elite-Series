<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:paddingTop="@dimen/dimen0cee"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:tint="@color/color0347"
        app:attr0838="@drawable/vec_ic_trash" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen0cea"
        android:text="@string/str0ff5"
        android:layout_marginStart="@dimen/dimen0cee"
        android:layout_marginEnd="@dimen/dimen0cee"
        style="@style/style05aa" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:textColor="?attr0a46"
        android:id="@id/dialog_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen0cea"
        android:text="@string/str0ff4"
        android:layout_marginStart="@dimen/dimen0cee"
        android:layout_marginEnd="@dimen/dimen0cee"
        style="@style/style05a6" />
    <RelativeLayout
        android:id="@id/block_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="18.0dip"
        android:layout_marginTop="@dimen/dimen0cea"
        android:layout_marginRight="@dimen/dimen0cee"
        android:layout_marginBottom="@dimen/dimen0cec">
        <CheckBox
            android:id="@id/block_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0cf0"
            android:layout_marginRight="@dimen/dimen0ce8" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:id="@id/block_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0cec"
            android:layout_toRightOf="@id/block_checkbox"
            android:fontFamily="?attr03b8"
            style="@style/style05a4" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="?attr0a46"
            android:id="@id/block_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0cf0"
            android:text="@string/str0ff1"
            android:layout_toRightOf="@id/block_checkbox"
            android:layout_below="@id/block_header"
            style="@style/style05a6" />
    </RelativeLayout>
</LinearLayout>