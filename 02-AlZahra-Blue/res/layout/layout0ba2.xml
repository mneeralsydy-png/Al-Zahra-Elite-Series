            android:id="@id/admin_profile_photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/avatar_contact_colorable"
            android:importantForAccessibility="no"
            app:attr0674="circle"
            app:attr0675="xx_large" />
