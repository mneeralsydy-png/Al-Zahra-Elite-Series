            android:id="@id/admin_profile_initials"
            android:background="@drawable/newsletter_admin_initials_background"
            android:visibility="gone"
            android:layout_width="@dimen/dimen100c"
            android:layout_height="@dimen/dimen100c"
            android:importantForAccessibility="no"
            app:attr03ae="?attr03b8" />
    </FrameLayout>
    <com.whatsapp.ui.coreui.base.TextEmojiLabel
        android:textSize="@dimen/dimen0fc8"
        android:textColor="?attr0a47"
        android:gravity="center"
        android:id="@id/admin_profile_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen103a" />
</LinearLayout>