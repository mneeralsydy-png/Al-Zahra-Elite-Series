<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/root_view"
    android:background="#ff000000"
    android:fitsSystemWindows="true"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:id="@id/image_container"
        android:padding="@dimen/dimen102e"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_weight="1.0">
        <com.whatsapp.crop.CropImageView
            android:id="@id/image"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_alignParentTop="true" />
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:textSize="@dimen/dimen0fbc"
            android:textColor="?attr0a2f"
            android:gravity="center"
            android:id="@id/image_web_link"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen102e"
            android:layout_marginTop="@dimen/dimen102e"
            android:layout_marginRight="@dimen/dimen102e"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true" />
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:textSize="@dimen/dimen0fbc"
            android:textColor="?attr0a2f"
            android:gravity="center"
            android:id="@id/tos_link"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen102e"
            android:layout_marginRight="@dimen/dimen102e"
            android:layout_marginBottom="@dimen/dimen102e"
            android:text="@string/str0ea0"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:lineSpacingMultiplier="1.25" />
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:textColor="?attr0a2f"
            android:ellipsize="end"
            android:id="@id/cancel_btn"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="@string/str3d9b"
            android:layout_weight="1.0"
            android:textAllCaps="true"
            android:fontFamily="?attr03b8"
            app:attr0009="media"
            style="@style/style0006" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/rotate"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:layout_weight="1.0"
            android:contentDescription="@string/str2d00"
            app:attr0838="@drawable/ic_rotate_90_degrees_ccw"
            style="@style/style0006" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:textColor="?attr0a2f"
            android:ellipsize="end"
            android:id="@id/ok_btn"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="@string/str3e2a"
            android:layout_weight="1.0"
            android:textAllCaps="true"
            android:fontFamily="?attr03b8"
            app:attr0009="media"
            style="@style/style0006" />
    </LinearLayout>
</LinearLayout>