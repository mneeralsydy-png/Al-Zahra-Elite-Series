            android:layout_centerInParent="true"
            android:lineSpacingMultiplier="1.28"
            app:attr03ae="?attr03b8"
            app:attr0a24="wds_font_body1_emphasized" />
    </RelativeLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@id/installment_recycler_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_above="@id/footer_container"
        android:layout_below="@id/header"
        app:attr0488="androidx.recyclerview.widget.LinearLayoutManager" />
    <LinearLayout
        android:id="@id/footer_container"
        android:background="?android:selectableItemBackground"
        android:padding="@dimen/dimen0a5d"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen0a63"
        android:layout_alignParentBottom="true">
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/select_button"
            android:layout_width="fill_parent"
            android:text="@string/str1995"
            app:attr04ad="parent"
            style="@style/style0555" />
    </LinearLayout>
</RelativeLayout>