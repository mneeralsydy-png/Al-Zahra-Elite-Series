<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/document_picker_item"
    android:layout_width="fill_parent"
    android:layout_height="@dimen/dimen0ccb"
    android:minHeight="@dimen/dimen0ccb"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <View
        android:id="@id/selection_check"
        android:layout_width="1.0dip"
        android:layout_height="1.0dip" />
    <FrameLayout
        android:layout_gravity="start|center"
        android:id="@id/icon_container"
        android:layout_width="@dimen/dimen04fe"
        android:layout_height="@dimen/dimen04fe"
        android:layout_marginStart="@dimen/dimen04ff">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center"
            android:id="@id/icon"
            android:padding="@dimen/dimen0500"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:scaleType="fitCenter" />
        <com.whatsapp.ui.coreui.components.SelectionCheckView
            android:layout_gravity="end|bottom|center"
            android:id="@id/selection_badge"
            android:visibility="gone"
            android:layout_width="@dimen/dimen0502"
            android:layout_height="@dimen/dimen0502" />
    </FrameLayout>
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:id="@id/text_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen04e9"
        android:layout_marginEnd="@dimen/dimen04ff">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/style0289" />
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style0285" />
            <View
                android:layout_width="0.0dip"
                android:layout_height="1.0dip"
                android:layout_weight="1.0" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style0285" />
        </LinearLayout>
    </LinearLayout>
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="end|center"
        android:id="@id/preview_icon"
        android:visibility="gone"
        android:layout_width="@dimen/dimen0501"
        android:layout_height="@dimen/dimen0501"
        android:src="@drawable/vec_ic_zoom_out_map"
        android:scaleType="fitCenter"
        android:layout_marginEnd="@dimen/dimen04ff" />
</FrameLayout>