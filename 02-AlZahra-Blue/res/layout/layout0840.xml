<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/container_view"
    android:paddingBottom="10.0dip"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:layout_marginTop="30.0dip"
    android:paddingStart="10.0dip"
    android:paddingEnd="10.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="start|center|top"
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <CheckBox
            android:id="@id/background_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toggle background" />
    </LinearLayout>
    <TextView
        android:textSize="12.0sp"
        android:layout_gravity="start|center|top"
        android:id="@id/info_text"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="56.0dip" />
    <TextView
        android:textSize="12.0sp"
        android:textColor="@color/color0976"
        android:layout_gravity="start|bottom|center"
        android:id="@id/error_text"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <TextView
        android:textSize="12.0sp"
        android:layout_gravity="end|bottom|center"
        android:id="@id/compact_info_text"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
</FrameLayout>