<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:windowIsFloating="false"
    android:id="@id/coordinator"
    android:fitsSystemWindows="true"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.KeyboardPopupLayout
        android:id="@id/emoji_edit_text_layout"
        android:fitsSystemWindows="true"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <FrameLayout
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:layout_weight="1.0">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/top_layout"
                    android:background="?attr0a59"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent">
                    <FrameLayout
                        android:background="?attr0a2f"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:elevation="?attr002f">
                        <include
                            layout="@layout/layout10cb" />
                    </FrameLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@id/view_placeholder"
                        android:layout_width="fill_parent"
                        android:layout_height="0.0dip"
                        android:layout_weight="1.0" />
                    <RelativeLayout
                        android:layout_gravity="bottom"
                        android:id="@id/footer"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/dimen0ca3">
                        <View
                            android:id="@id/link_preview_divider"
                            android:background="?attr0604"
                            android:visibility="gone"
                            android:layout_width="fill_parent"
                            android:layout_height="0.5dip" />
                        <com.whatsapp.ui.coreui.WaFrameLayout
                            android:id="@id/web_page_preview_container"
                            android:background="?attr0a63"
                            android:visibility="gone"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_above="@id/recipients_container"
                            android:layout_below="@id/link_preview_divider" />
                        <RelativeLayout
                            android:id="@id/recipients_container"
                            android:background="?attr0a29"
                            android:paddingRight="60.0dip"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true">
                            <com.whatsapp.ui.coreui.base.WaImageView
                                android:id="@id/recipients_chevron"
                                android:paddingLeft="10.0dip"
                                android:layout_width="wrap_content"
                                android:layout_height="15.0dip"
                                android:scaleType="centerCrop"
                                android:layout_alignParentLeft="true"
                                android:layout_centerInParent="true"
                                app:attr0838="@drawable/chevron_right" />
                            <HorizontalScrollView
                                android:id="@id/recipients_scroller"
                                android:paddingLeft="7.0dip"
                                android:scrollbars="none"
                                android:fadingEdge="horizontal"
                                android:fadingEdgeLength="50.0dip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toRightOf="@id/recipients_chevron"
                                android:layout_alignParentTop="true"
                                android:requiresFadingEdge="horizontal"
                                android:layoutDirection="ltr">
                                <com.whatsapp.ui.coreui.base.TextEmojiLabel
                                    android:textColor="?attr0a2f"
                                    android:ellipsize="none"
                                    android:gravity="center_vertical"
                                    android:layout_gravity="bottom"
                                    android:id="@id/recipients"
                                    android:paddingRight="@dimen/dimen102f"
                                    android:layout_width="wrap_content"
                                    android:layout_height="@dimen/dimen0ca3"
                                    android:singleLine="true" />
                            </HorizontalScrollView>
                        </RelativeLayout>
                    </RelativeLayout>
                </LinearLayout>
                <com.whatsapp.ui.wds.components.fab.WDSFab
                    android:id="@id/send"
                    android:src="@drawable/input_send"
                    android:contentDescription="@string/str4217"
                    style="@style/style055f" />
            </FrameLayout>
            <com.whatsapp.emoji.search.EmojiSearchContainer
                android:id="@id/emoji_search_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <com.whatsapp.emoji.search.EmojiSearchKeyboardContainer
                android:id="@id/expressions_tray_emoji_search_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:attr048b="bottom" />
        </LinearLayout>
    </com.whatsapp.ui.coreui.KeyboardPopupLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>