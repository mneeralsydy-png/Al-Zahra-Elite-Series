<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:paddingLeft="@dimen/dimen021b"
    android:paddingRight="@dimen/dimen021b"
    android:layout_width="fill_parent"
    android:layout_height="@dimen/dimen0621"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="left"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/mde_agent_attr_ic"
                android:layout_width="22.0dip"
                android:layout_height="wrap_content"
                app:attr090d="@color/color0503" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:id="@id/biz_agent_name"
                android:paddingLeft="@dimen/dimen1035"
                android:paddingRight="@dimen/dimen1035"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style0289" />
        </LinearLayout>
        <com.whatsapp.ui.coreui.base.WaTextView
            android:layout_gravity="left"
            android:id="@id/biz_agent_sent_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/style0285" />
    </LinearLayout>
    <View
        android:id="@id/agent_separator"
        style="@style/style0142" />
</FrameLayout>