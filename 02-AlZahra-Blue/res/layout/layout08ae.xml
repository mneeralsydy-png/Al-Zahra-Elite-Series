<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen103b"
        android:layout_marginTop="@dimen/dimen103b"
        android:layout_marginRight="@dimen/dimen103b">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="?attr066e"
            android:id="@id/title_text"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="@string/str36da"
            android:layout_weight="1.0"
            style="@style/style03ff" />
        <com.whatsapp.ui.coreui.base.WaImageView
            style="@style/style02f5" />
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginLeft="22.0dip"
        android:layout_marginTop="@dimen/dimen102e"
        android:layout_marginRight="22.0dip">
        <com.whatsapp.ui.coreui.WaEditText
            android:textSize="@dimen/dimen0fb0"
            android:id="@id/account_id_handle"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:lines="1"
            android:singleLine="true"
            android:maxLength="255"
            android:layout_weight="17.0" />
        <ProgressBar
            android:id="@id/progress"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="32.0dip"
            android:layout_weight="3.0"
            style="progressBarStyleInverse" />
    </LinearLayout>
    <com.whatsapp.ui.coreui.base.WaTextView
        android:textSize="@dimen/dimen0fb0"
        android:textColor="?attr0a4f"
        android:id="@id/error_text"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen103b"
        android:layout_marginRight="@dimen/dimen103b"
        android:minHeight="28.0dip"
        android:text="@string/str24b1"
        app:attr0a24="wds_font_body1" />
    <LinearLayout
        android:gravity="right"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen1035"
        android:layout_marginRight="@dimen/dimen1035"
        android:layout_marginBottom="@dimen/dimen1039">
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:layout_gravity="start"
            android:id="@id/close_dialog_button"
            android:text="@string/str3d9b"
            app:attr03ae="?attr03b8"
            style="@style/style0557" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:layout_gravity="end"
            android:id="@id/primary_payment_button"
            android:text="@string/str252e"
            style="@style/style0557" />
    </LinearLayout>
</LinearLayout>