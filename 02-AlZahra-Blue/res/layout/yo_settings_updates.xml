<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:orientation="vertical"
    android:background="@color/yosettings_background"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <include
            layout="@layout/yo_toolbar" />
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip">
            <LinearLayout
                android:orientation="horizontal"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:onClick="checkForUpdates">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="8.0dip"
                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:src="@drawable/updates_updates"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip"
                    android:layout_marginEnd="6.0dip" />
                <LinearLayout
                    android:layout_gravity="start"
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_margin="3.0dip"
                    android:layout_weight="1.0">
                    <com.whatsapp.yo.tf
                        android:textSize="16.0sp"
                        android:textColor="@color/primary_text"
                        android:ellipsize="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3.0dip"
                        android:text="@string/yo_CUpdates"
                        android:maxLines="1" />
                    <com.whatsapp.yo.tf
                        android:textSize="12.0sp"
                        android:textStyle="normal"
                        android:textColor="@color/secondary_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1.0dip"
                        android:text="@string/yo_UpInfo"
                        android:singleLine="false" />
                </LinearLayout>
                <ImageView
                    android:layout_gravity="end|center"
                    android:paddingLeft="@dimen/info_screen_padding"
                    android:paddingRight="@dimen/info_screen_padding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/abu_arab_chevron_right"
                    android:tint="@color/conversations_text_gray"
                    android:paddingStart="@dimen/info_screen_padding"
                    android:paddingEnd="@dimen/info_screen_padding" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:onClick="openChangelog">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="8.0dip"
                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:src="@drawable/updates_changelog"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip"
                    android:layout_marginEnd="6.0dip" />
                <LinearLayout
                    android:layout_gravity="start"
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_margin="3.0dip"
                    android:layout_weight="1.0">
                    <com.whatsapp.yo.tf
                        android:textSize="16.0sp"
                        android:textColor="@color/primary_text"
                        android:ellipsize="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3.0dip"
                        android:text="@string/yo_changelog"
                        android:maxLines="1" />
                    <com.whatsapp.yo.tf
                        android:textSize="12.0sp"
                        android:textStyle="normal"
                        android:textColor="@color/secondary_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1.0dip"
                        android:text="@string/yo_changelogS"
                        android:singleLine="false" />
                </LinearLayout>
                <ImageView
                    android:layout_gravity="end|center"
                    android:paddingLeft="@dimen/info_screen_padding"
                    android:paddingRight="@dimen/info_screen_padding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/abu_arab_chevron_right"
                    android:tint="@color/conversations_text_gray"
                    android:paddingStart="@dimen/info_screen_padding"
                    android:paddingEnd="@dimen/info_screen_padding" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/rounded_card"
            android:padding="@dimen/info_screen_padding"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip"
            android:foreground="?android:selectableItemBackground"
            android:onClick="openWebsite">
            <ImageView
                android:background="@drawable/Abo_Arab_WA5"
                android:padding="8.0dip"
                android:layout_width="40.0dip"
                android:layout_height="40.0dip"
                android:src="@drawable/updates_download"
                android:scaleType="centerInside"
                android:tint="@color/icon_primary"
                android:layout_marginStart="12.0dip"
                android:layout_marginEnd="6.0dip" />
            <LinearLayout
                android:layout_gravity="start"
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_margin="3.0dip"
                android:layout_weight="1.0">
                <com.whatsapp.yo.tf
                    android:textSize="16.0sp"
                    android:textColor="@color/primary_text"
                    android:ellipsize="end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3.0dip"
                    android:text="@string/yo_webdl"
                    android:maxLines="1" />
                <com.whatsapp.yo.tf
                    android:textSize="12.0sp"
                    android:textStyle="normal"
                    android:textColor="@color/secondary_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1.0dip"
                    android:text="@string/yo_webdlS"
                    android:singleLine="false" />
            </LinearLayout>
            <ImageView
                android:layout_gravity="end|center"
                android:paddingLeft="@dimen/info_screen_padding"
                android:paddingRight="@dimen/info_screen_padding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/abu_arab_chevron_right"
                android:tint="@color/conversations_text_gray"
                android:paddingStart="@dimen/info_screen_padding"
                android:paddingEnd="@dimen/info_screen_padding" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>