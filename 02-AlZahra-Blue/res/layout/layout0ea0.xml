        <ProgressBar
            android:layout_gravity="center"
            android:id="@id/progress_bar"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="progressBarStyleLargeInverse" />
    </FrameLayout>
</LinearLayout>