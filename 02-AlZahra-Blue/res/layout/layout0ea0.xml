                    android:background="@drawable/qr_code_scan_card"
                    android:padding="@dimen/dimen1030"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen102e">
                    <com.whatsapp.ui.coreui.QrImageView
                        android:layout_gravity="center_horizontal"
                        android:id="@id/qr_code"
                        android:padding="@dimen/dimen1030"
                        android:layout_width="150.0dip"
                        android:layout_height="150.0dip"
                        whatsapp:attr07ef="false" />
                    <com.whatsapp.ui.coreui.base.WaImageView
                        android:layout_gravity="center"
                        android:layout_width="38.0dip"
                        android:layout_height="38.0dip"
