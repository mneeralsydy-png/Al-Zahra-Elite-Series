            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            whatsapp:attr068d="round_scanline" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="?attr09ca"
            android:gravity="center"
            android:id="@id/error_indicator"
            android:background="@color/color0854"
            android:padding="@dimen/dimen1039"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            whatsapp:attr0a24="wds_font_body2" />
        <ScrollView
            android:id="@id/main_layout"
            android:background="?attr0a59"
            android:paddingBottom="@dimen/dimen0048"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <LinearLayout
                android:orientation="vertical"
                android:paddingTop="@dimen/dimen102f"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb6"
                    android:textColor="?attr0a46"
                    android:id="@id/qr_code_description"
                    android:paddingLeft="@dimen/dimen103b"
                    android:paddingRight="@dimen/dimen103b"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/str2a19"
                    whatsapp:attr0a24="wds_font_body2"
                    style="@style/style03c9" />
                <View
                    android:id="@id/scan_qr_code_divider_1"
                    android:layout_marginTop="@dimen/dimen103b"
                    android:layout_marginBottom="@dimen/dimen103b"
