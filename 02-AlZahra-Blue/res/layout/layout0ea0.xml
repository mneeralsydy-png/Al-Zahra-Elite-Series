                    android:background="?android:selectableItemBackground"
                    android:paddingTop="@dimen/dimen1039"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str2d1a"
                    android:drawablePadding="10.0dip"
                    whatsapp:attr02ec="@drawable/ic_qr_code"
                    whatsapp:attr02ed="?attr0a45" />
            </LinearLayout>
        </ScrollView>
        <FrameLayout
