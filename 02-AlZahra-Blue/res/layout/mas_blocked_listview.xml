<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="@color/yosettings_background"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <include
        layout="@layout/yo_toolbar" />
    <include
        android:gravity="center"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        layout="@layout/abu_arab_databases1" />
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/rounded_card"
        android:layout_width="fill_parent"
        android:layout_height="56.0dip"
        android:layout_marginLeft="16.0dip"
        android:layout_marginTop="12.0dip"
        android:layout_marginRight="16.0dip">
        <androidx.appcompat.widget.SwitchCompat
            android:textSize="16.0sp"
            android:textColor="@color/primary_text"
            android:layout_gravity="center"
            android:id="@id/blocked_notify"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_margin="16.0dip"
            android:text="@string/Abo_Arab_Not" />
    </LinearLayout>
    <FrameLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <ListView
            android:id="@id/f_listview"
            android:background="@drawable/rounded_card"
            android:paddingTop="8.0dip"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip"
            android:divider="@android:color/darker_gray"
            android:dividerHeight="0.049999952dip" />
        <ImageView
            android:layout_gravity="end|bottom|center"
            android:id="@id/mas_blocked_settings"
            android:background="@drawable/input_circle_green"
            android:layout_width="56.0dip"
            android:layout_height="56.0dip"
            android:layout_margin="16.0dip"
            android:src="@drawable/ic_action_delete"
            android:scaleType="center"
            android:adjustViewBounds="true"
            android:onClick="onClickSettings" />
    </FrameLayout>
</LinearLayout>