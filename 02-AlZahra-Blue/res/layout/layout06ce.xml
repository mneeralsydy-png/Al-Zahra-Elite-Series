<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ScrollView
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_weight="1.0">
        <com.whatsapp.ui.coreui.WaLinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen054a"
            android:layout_marginRight="@dimen/dimen054a">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:gravity="start"
                android:id="@id/enc_backup_password_input_title"
                android:text="@string/str1224"
                style="@style/style0203" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/enc_backup_password_input_instruction"
                android:text="@string/str1222"
                style="@style/style0201" />
            <com.google.android.material.textfield.TextInputLayout
                android:id="@id/enc_backup_password_input_layout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24.0dip"
                app:attr0321="password_toggle"
                style="@style/style0587">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@id/enc_backup_password_input"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:id="@id/enc_backup_password_input_forgot_password"
                android:text="@string/str125b"
                style="@style/style0202" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/enc_backup_password_input_requirement"
                style="@style/style0201" />
        </com.whatsapp.ui.coreui.WaLinearLayout>
    </ScrollView>
    <com.whatsapp.ui.wds.components.button.WDSButton
        android:layout_gravity="bottom"
        android:id="@id/enc_backup_password_input_button"
        android:text="@string/str1221"
        style="@style/style055c" />
    <com.whatsapp.ui.wds.components.button.WDSButton
        android:layout_gravity="center"
        android:id="@id/enc_backup_password_input_secondary_button"
        android:visibility="gone"
        style="@style/style0557" />
</LinearLayout>