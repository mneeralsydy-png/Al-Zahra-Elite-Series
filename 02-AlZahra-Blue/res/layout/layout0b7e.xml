<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:gravity="center"
    android:orientation="vertical"
    android:id="@id/new_community_admin_bottom_sheet"
    android:layout_width="fill_parent"
    android:layout_height="0.0dip"
    android:layout_weight="1.0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageButton
            android:layout_gravity="center|left|top"
            android:id="@id/bottom_sheet_close_button"
            android:background="?attr076e"
            android:padding="@dimen/dimen0ce7"
            android:layout_width="@dimen/dimen02cf"
            android:layout_height="@dimen/dimen02cf"
            android:contentDescription="@string/str3dac"
            app:attr0838="@drawable/ic_close"
            app:attr090d="@color/color0347" />
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:paddingTop="@dimen/dimen0cf1"
                android:layout_width="@dimen/dimen09db"
                android:layout_height="wrap_content"
                app:attr0838="@drawable/vec_ic_new_community_admin_illustration" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen09dc"
                android:gravity="center"
                android:id="@id/newCommunityAdminNux_title"
                android:paddingTop="@dimen/dimen0cee"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str1f94"
                style="@style/style0566" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textSize="@dimen/dimen09da"
                android:textColor="@color/color02e4"
                android:gravity="center"
                android:id="@id/newCommunityAdminNux_description"
                android:paddingLeft="@dimen/dimen0cee"
                android:paddingTop="@dimen/dimen0cea"
                android:paddingRight="@dimen/dimen0cee"
                android:paddingBottom="@dimen/dimen0ce8"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                style="@style/style03c7" />
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:id="@id/newCommunityAdminNux_continueButton"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen0cea"
                android:layout_marginRight="@dimen/dimen0cea"
                android:text="@string/str1f92"
                style="@style/style055c" />
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:id="@id/newCommunityAdminNux_removeAsAdminButton"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen0cea"
                android:layout_marginRight="@dimen/dimen0cea"
                android:layout_marginBottom="@dimen/dimen0cee"
                android:text="@string/str1f95"
                style="@style/style055e" />
        </LinearLayout>
    </FrameLayout>
</ScrollView>