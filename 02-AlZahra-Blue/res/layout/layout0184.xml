<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="bottom"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false">
        <com.whatsapp.calling.ui.views.CallResponseLayout
            android:gravity="bottom"
            android:layout_gravity="bottom"
            android:id="@id/decline_incoming_call_container"
            android:layout_width="0.0dip"
            android:layout_height="180.0dip"
            android:layout_weight="1.0">
            <ViewStub
                android:layout_gravity="bottom|center"
                android:id="@id/decline_call_swipe_up_hint_view_stub"
                android:layout="@layout/layout0183"
                android:inflatedId="@id/decline_call_swipe_up_hint_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="98.0dip" />
            <ViewStub
                android:layout_gravity="bottom|center"
                android:id="@id/decline_incoming_call_imageview_stub"
                android:layout="@layout/layout05fa"
                android:inflatedId="@id/decline_incoming_call_view"
                android:layout_width="@dimen/dimen01ac"
                android:layout_height="@dimen/dimen01ac" />
            <ViewStub
                android:layout_gravity="bottom|center"
                android:id="@id/decline_incoming_call_wds_button_stub"
                android:layout="@layout/layout05fb"
                android:inflatedId="@id/decline_incoming_call_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </com.whatsapp.calling.ui.views.CallResponseLayout>
        <com.whatsapp.calling.ui.views.CallResponseLayout
            android:gravity="bottom"
            android:layout_gravity="bottom"
            android:id="@id/accept_incoming_call_container"
            android:layout_width="0.0dip"
            android:layout_height="180.0dip"
            android:layout_weight="1.0">
            <ViewStub
                android:layout_gravity="bottom|center"
                android:id="@id/accept_call_swipe_up_hint_view_stub"
                android:layout="@layout/layout0183"
                android:inflatedId="@id/accept_call_swipe_up_hint_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="98.0dip" />
            <ViewStub
                android:layout_gravity="bottom|center"
                android:id="@id/accept_incoming_call_imageview_stub"
                android:layout="@layout/layout0186"
                android:inflatedId="@id/accept_incoming_call_view"
                android:layout_width="@dimen/dimen01ac"
                android:layout_height="@dimen/dimen01ac" />
            <ViewStub
                android:layout_gravity="bottom|center"
                android:id="@id/accept_incoming_call_wds_button_stub"
                android:layout="@layout/layout0187"
                android:inflatedId="@id/accept_incoming_call_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </com.whatsapp.calling.ui.views.CallResponseLayout>
        <com.whatsapp.calling.ui.views.CallResponseLayout
            android:gravity="bottom"
            android:layout_gravity="bottom"
            android:id="@id/reply_incoming_call_container"
            android:layout_width="0.0dip"
            android:layout_height="180.0dip"
            android:layout_weight="1.0">
            <ViewStub
                android:layout_gravity="bottom|center"
                android:id="@id/reply_call_swipe_up_hint_view_stub"
                android:layout="@layout/layout0183"
                android:inflatedId="@id/reply_call_swipe_up_hint_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="98.0dip" />
            <ViewStub
                android:layout_gravity="bottom|center"
                android:id="@id/reply_incoming_call_imageview_stub"
                android:layout="@layout/layout0e54"
                android:inflatedId="@id/reply_incoming_call_view"
                android:layout_width="@dimen/dimen01ac"
                android:layout_height="@dimen/dimen01ac" />
            <ViewStub
                android:layout_gravity="bottom|center"
                android:id="@id/reply_incoming_call_wds_button_stub"
                android:layout="@layout/layout0e55"
                android:inflatedId="@id/reply_incoming_call_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </com.whatsapp.calling.ui.views.CallResponseLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:ellipsize="end"
            android:gravity="center"
            android:layout_gravity="bottom|center"
            android:id="@id/decline_incoming_call_hint"
            android:visibility="invisible"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="@string/str3a35"
            android:maxLines="4"
            android:layout_weight="1.0"
            android:importantForAccessibility="no"
            style="@style/style013b" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:ellipsize="end"
            android:gravity="center"
            android:layout_gravity="bottom|center"
            android:id="@id/accept_incoming_call_hint"
            android:visibility="invisible"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="@string/str331e"
            android:maxLines="4"
            android:layout_weight="1.0"
            android:importantForAccessibility="no"
            style="@style/style013b" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:ellipsize="end"
            android:gravity="center"
            android:layout_gravity="bottom|center"
            android:id="@id/decline_with_message_hint"
            android:visibility="invisible"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="@string/str3ab7"
            android:maxLines="4"
            android:layout_weight="1.0"
            android:importantForAccessibility="no"
            style="@style/style013b" />
    </LinearLayout>
</LinearLayout>