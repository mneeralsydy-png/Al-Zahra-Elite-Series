<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/gif_expressions_tab_root"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:minHeight="@dimen/dimen060c"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_weight="1.0">
        <com.whatsapp.infra.graphicsearch.gifsearch.controls.AdaptiveRecyclerView
            android:id="@id/search_result_view"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginLeft="@dimen/dimen1030" />
        <ViewStub
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@id/gifs_search_no_results"
            android:layout="@layout/layout07d0"
            android:inflatedId="@id/gifs_search_no_results"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <ViewStub
            android:layout_gravity="center_vertical"
            android:id="@id/progress_container_layout"
            android:layout="@layout/layout07d2"
            android:inflatedId="@id/progress_container_layout"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dimen060b" />
        <ViewStub
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/retry_panel"
            android:layout="@layout/layout07d6"
            android:inflatedId="@id/retry_panel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </FrameLayout>
</LinearLayout>