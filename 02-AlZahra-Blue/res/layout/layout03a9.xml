                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:layout_margin="16.0dip"
                    android:scaleType="fitXY"
                    app:attr0838="@drawable/ic_shopping_cart"
                    app:attr090d="#ff128c7e" />
                <LinearLayout
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0">
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fb6"
                        android:textColor="?attr0a46"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str2523"
                        app:attr0a24="wds_font_body2"
                        style="@style/style0289" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fb0"
                        android:ellipsize="end"
                        android:id="@id/payment_to_merchant_options"
                        android:paddingTop="1.0dip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        app:attr0a24="wds_font_body1"
                        style="@style/style0289" />
                </LinearLayout>
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:layout_gravity="center|right"
                    android:paddingLeft="16.0dip"
                    android:paddingRight="16.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    app:attr0838="@drawable/chevron_right"
                    app:attr0a24="wds_font_body2" />
            </LinearLayout>
            <View
                android:background="@drawable/payments_divider_gray"
                android:layout_width="fill_parent"
                android:layout_height="0.5dip"
                android:layout_marginLeft="16.0dip"
                android:layout_marginRight="16.0dip" />
        </LinearLayout>
        <LinearLayout
            android:id="@id/payment_method_container"
            android:background="@drawable/selector_orange_gradient"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.payments.common.ui.widget.PaymentMethodRow
                android:id="@id/payment_method_row"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textAppearance="@style/style05a7"
                android:textSize="@dimen/dimen0fb6"
                android:textColor="?attr0a45"
                android:layout_gravity="center_vertical"
                android:id="@id/expand_details_button"
                android:paddingLeft="16.0dip"
                android:paddingRight="16.0dip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str24c3"
                app:attr0a24="wds_font_body2" />
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/transaction_description_container"
            android:background="@drawable/selector_orange_gradient"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.payments.common.ui.widget.PaymentDescriptionRow
                android:id="@id/payment_description_row"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0" />
            <com.whatsapp.ui.coreui.base.WaImageView
                android:layout_gravity="center|right"
                android:id="@id/expand_description_button"
                android:paddingLeft="16.0dip"
                android:paddingRight="16.0dip"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:contentDescription="@string/str249e"
                app:attr0838="@drawable/chevron_right" />
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/payment_rails_container"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <View
