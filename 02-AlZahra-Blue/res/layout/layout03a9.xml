                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0">
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fb6"
                        android:textColor="?attr0a46"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str0ccc"
                        app:attr0a24="wds_font_body2"
                        style="@style/style0289" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fb0"
                        android:ellipsize="end"
                        android:id="@id/payment_rails_label"
                        android:paddingTop="1.0dip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str24ed"
                        android:singleLine="true"
                        app:attr0a24="wds_font_body1"
                        style="@style/style0289" />
