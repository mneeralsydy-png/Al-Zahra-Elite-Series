                android:layout_weight="1.0">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb6"
                    android:textColor="?attr0a46"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str1999"
                    app:attr0a24="wds_font_body2"
                    style="@style/style0289" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb0"
                    android:ellipsize="end"
                    android:id="@id/installment_content"
                    android:paddingTop="1.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    app:attr0a24="wds_font_body1"
                    style="@style/style0289" />
            </LinearLayout>
            <com.whatsapp.ui.coreui.base.WaImageView
                android:layout_gravity="center|right"
                android:paddingLeft="16.0dip"
                android:paddingRight="16.0dip"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                app:attr0838="@drawable/chevron_right" />
        </LinearLayout>
        <ViewStub
            android:id="@id/amount_container_view"
            android:layout="@layout/layout03aa"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen1032"
            android:layout_marginRight="16.0dip" />
        <View
            android:background="@drawable/payments_divider_gray"
            android:layout_width="fill_parent"
            android:layout_height="0.5dip"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/dimen102f"
            android:layout_marginRight="16.0dip" />
        <View
            android:id="@id/education_divider"
            android:background="@drawable/payments_divider_gray"
            android:layout_width="fill_parent"
            android:layout_height="0.5dip"
            android:layout_marginLeft="16.0dip"
            android:layout_marginRight="16.0dip" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb6"
            android:textColor="?attr0a46"
            android:id="@id/education"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="16.0dip"
            android:layout_marginRight="16.0dip"
            app:attr03ae="?attr03b6"
            app:attr0a24="wds_font_body2" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/extra_info_view"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <FrameLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10.0dip"
            android:layout_marginTop="16.0dip"
            android:layout_marginRight="10.0dip"
            android:layout_marginBottom="16.0dip">
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:id="@id/confirm_payment"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str0cc4"
                style="@style/style0555" />
            <ProgressBar
                android:layout_gravity="center"
                android:id="@id/confirm_payment_progressbar"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </FrameLayout>
        <FrameLayout
            android:id="@id/footer_view"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</ScrollView>