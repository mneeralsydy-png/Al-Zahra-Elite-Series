                    android:paddingLeft="16.0dip"
                    android:paddingRight="16.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    app:attr0838="@drawable/chevron_right" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
