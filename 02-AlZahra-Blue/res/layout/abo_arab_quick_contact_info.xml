<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center"
    android:layout_gravity="center"
    android:id="@id/floating_layout"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:descendantFocusability="afterDescendants"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:id="@android:id/content"
        android:background="@color/primary_surface"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            android:layout_weight="1.0">
            <ImageView
                android:id="@id/picture"
                android:layout_width="@dimen/quick_contact_profile_photo_size"
                android:layout_height="@dimen/quick_contact_profile_photo_size"
                android:src="@drawable/avatar_contact_large"
                android:scaleType="centerCrop"
                android:contentDescription="@string/profile_photo" />
            <FrameLayout
                android:background="@color/black_alpha_20"
                android:layout_width="@dimen/quick_contact_profile_photo_size"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="18.0dip"
                    android:textColor="@color/white"
                    android:ellipsize="end"
                    android:gravity="left"
                    android:id="@id/name"
                    android:paddingLeft="8.0dip"
                    android:paddingTop="4.0dip"
                    android:paddingRight="8.0dip"
                    android:paddingBottom="6.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contacts"
                    android:singleLine="true" />
            </FrameLayout>
        </FrameLayout>
        <View
            android:id="@id/quick_contact_divider"
            style="@style/SectionDivider.Heavy" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/buttons"
            android:background="@color/white"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:ellipsize="end"
                android:id="@id/message_btn"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:src="@drawable/vec_ic_chat_filled"
                android:tint="@color/abo_arab_accent"
                android:layout_weight="0.5"
                style="@style/style0006" />
            <ImageView
                android:ellipsize="end"
                android:id="@id/audio_call_btn"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_action_call"
                android:tint="@color/abo_arab_accent"
                android:layout_weight="0.5"
                style="@style/style0006" />
            <ImageView
                android:ellipsize="end"
                android:id="@id/video_call_btn"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_action_videocall"
                android:tint="@color/abo_arab_accent"
                android:layout_weight="0.5"
                style="@style/style0006" />
            <ImageView
                android:ellipsize="end"
                android:id="@id/call_picker_btn"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_add_call"
                android:layout_weight="0.5"
                app:tint="@color/primary_light"
                style="@style/style0006" />
            <LinearLayout
                android:gravity="center_vertical"
                android:id="@id/join_call_btn"
                android:background="@drawable/join_call_button_in_quick_contact_background"
                android:paddingLeft="12.0dip"
                android:paddingRight="12.0dip"
                android:focusable="true"
                android:visibility="gone"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="31.0dip">
                <ImageView
                    android:id="@id/call_type"
                    android:layout_width="16.0dip"
                    android:layout_height="16.0dip"
                    android:layout_marginRight="8.0dip"
                    android:src="@drawable/ic_action_videocall"
                    android:tint="@color/white" />
            </LinearLayout>
            <ImageView
                android:ellipsize="end"
                android:id="@id/info_btn"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_info_white"
                android:tint="@color/abo_arab_accent"
                android:layout_weight="0.5"
                style="@style/style0006" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>