<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/booking_confirmation_header"
        android:background="@drawable/conversation_row_booking_confirmation_bubble_background"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen0168"
        android:layout_marginTop="@dimen/dimen0168"
        android:layout_marginRight="@dimen/dimen0168">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/booking_confirmation_header_content_wrapper"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0ce7"
            android:layout_marginStart="@dimen/dimen0ce7"
            android:layout_marginEnd="@dimen/dimen0cec">
            <com.whatsapp.conversation.ui.conversationrow.components.interactive.InteractiveMessageIconContainer
                android:id="@id/booking_confirmation_icon_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/dimen0ce7">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center"
                    android:id="@id/booking_confirmation_icon"
                    android:layout_width="@dimen/dimen0fdd"
                    android:layout_height="@dimen/dimen0fdd"
                    android:tint="@color/color00fe"
                    app:attr0838="@drawable/vec_ic_calendar_month" />
            </com.whatsapp.conversation.ui.conversationrow.components.interactive.InteractiveMessageIconContainer>
            <com.whatsapp.conversation.ui.conversationrow.businessmessaging.interactive.components.BookingConfirmationHeaderTextsAndDateLayout
                android:orientation="vertical"
                android:id="@id/booking_confirmation_header_texts_and_date"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/booking_confirmation_header_texts"
                    android:paddingBottom="@dimen/dimen0ce7"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent">
                    <com.whatsapp.ui.coreui.base.TextEmojiLabel
                        android:textAppearance="@style/style05a7"
                        android:layout_gravity="left"
                        android:id="@id/title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <com.whatsapp.ui.coreui.base.TextEmojiLabel
                        android:textAppearance="@style/style05a8"
                        android:textColor="?attr0a46"
                        android:ellipsize="end"
                        android:layout_gravity="left"
                        android:id="@id/datetime_range"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true" />
                    <com.whatsapp.ui.coreui.base.TextEmojiLabel
                        android:textAppearance="@style/style05a8"
                        android:textColor="?attr0a46"
                        android:ellipsize="end"
                        android:layout_gravity="left"
                        android:id="@id/location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true" />
                    <com.whatsapp.ui.coreui.base.TextEmojiLabel
                        android:textAppearance="@style/style05a8"
                        android:textColor="?attr0a46"
                        android:ellipsize="end"
                        android:layout_gravity="left"
                        android:id="@id/video_call"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str06a4"
                        android:singleLine="true" />
                    <com.whatsapp.ui.coreui.base.TextEmojiLabel
                        android:textAppearance="@style/style05a8"
                        android:textColor="?attr0a46"
                        android:ellipsize="end"
                        android:layout_gravity="left"
                        android:id="@id/phone_call"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true" />
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:layout_gravity="bottom|center|right"
                    android:orientation="horizontal"
                    android:id="@id/booking_confirmation_date_wrapper"
                    android:paddingBottom="@dimen/dimen0cec"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:id="@id/booking_confirmation_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/style0567" />
                </LinearLayout>
            </com.whatsapp.conversation.ui.conversationrow.businessmessaging.interactive.components.BookingConfirmationHeaderTextsAndDateLayout>
        </LinearLayout>
    </FrameLayout>
</merge>