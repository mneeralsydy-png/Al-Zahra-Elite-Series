<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:id="@id/ai_home_scroll_view"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="vertical"
        android:id="@id/ai_home_container"
        android:padding="@dimen/dimen102e"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/ai_home_capabilities_grid"
            android:background="@drawable/ai_home_capabilities_background"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen102e"
            android:nestedScrollingEnabled="false" />
        <ViewStub
            android:id="@id/ai_home_convo_starters_stub"
            android:background="@drawable/ai_home_capabilities_background"
            android:paddingBottom="@dimen/dimen102e"
            android:layout="@layout/layout0143"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>