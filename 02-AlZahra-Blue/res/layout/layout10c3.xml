            android:scaleType="centerInside"
            android:tint="@color/color08dc"
            whatsapp:attr0838="@drawable/ic_perm_media" />
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:textColor="?attr0a47"
