                android:layout_height="wrap_content"
                android:text="@string/str3429"
                android:textAlignment="viewStart"
                whatsapp:attr0a24="wds_font_body2" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
