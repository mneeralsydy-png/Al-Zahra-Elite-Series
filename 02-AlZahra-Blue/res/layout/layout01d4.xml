<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.wds.components.textlayout.WDSTextLayout
            android:id="@id/ban_appeal_form_submitted_text_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen103b" />
        <View
            android:id="@id/divider"
            android:background="?attr0a52"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dimen0f98"
            android:layout_marginTop="@dimen/dimen103b"
            android:layout_marginBottom="@dimen/dimen103b" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:id="@id/section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen1039"
            android:layout_marginBottom="@dimen/dimen102e"
            android:text="@string/str04e1"
            android:layout_marginStart="@dimen/dimen103b"
            android:layout_marginEnd="@dimen/dimen103b"
            style="@style/style05a5" />
        <androidx.recyclerview.widget.RecyclerView
            android:orientation="horizontal"
            android:id="@id/education_cards_recycler"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dimen103b"
            android:paddingEnd="@dimen/dimen103b" />
    </LinearLayout>
</ScrollView>