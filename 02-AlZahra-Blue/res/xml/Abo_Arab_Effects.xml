<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory
        android:layout="@layout/abu_arab_preference_category"
        android:title="@string/Abo_Arab_Effects">
        <ListPreference
            android:icon="@drawable/abo_arab_ic_homeguias"
            android:entries="@array/transformer_entry"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/title_pref_transformer"
            android:key="key_pager_animation"
            android:summary="%s"
            android:defaultValue="0"
            android:entryValues="@array/transformer_value" />
        <ListPreference
            android:icon="@drawable/abo_arab_ic_homechata"
            android:entries="@array/listanimation_entry"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/chats_list_animations"
            android:key="key_chats_listanimation"
            android:summary="%s"
            android:defaultValue="0"
            android:entryValues="@array/listanimation_value" />
        <ListPreference
            android:icon="@drawable/abo_arab_ic_conversationeffect"
            android:entries="@array/listanimation_entry"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/chat_list_animations"
            android:key="key_chat_animation"
            android:summary="%s"
            android:defaultValue="0"
            android:entryValues="@array/listanimation_value" />
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/abu_arab_preference_category"
        android:title="@string/abu_arab_snow_hctitle">
        <Preference
            android:icon="@drawable/abo_arab_ic_snow_effect"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/abu_arab_snow_hctitle"
            android:summary="@string/abu_arab_snow_hctitle_sum">
            <intent
                android:targetPackage="com.alzahra"
                android:action="android.intent.action.VIEW"
                android:targetClass="abu3arab.snowfalling.xml.snow_xml" />
        </Preference>
    </PreferenceCategory>
</PreferenceScreen>