<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:animateLayoutChanges="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:layout_width="0.0dip"
        android:layout_height="fill_parent"
        android:layout_weight="0.5">
        <FrameLayout
            android:id="@id/map_holder"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/my_location"
            android:background="@drawable/map_button_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10.0dip"
            android:scaleType="center"
            android:layout_alignParentRight="true"
            android:contentDescription="@string/str1edf"
            app:attr0838="@drawable/btn_myl"
            app:attr090d="@color/color089a" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/zoom_out"
            android:background="@drawable/map_button_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10.0dip"
            android:scaleType="center"
            android:layout_below="@id/my_location"
            android:layout_alignParentRight="true"
            android:contentDescription="@string/str1be9"
            app:attr0838="@drawable/btn_locations_zoom_reset"
            app:attr090d="@color/color089a" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/status_panel"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:scaleType="fitXY"
                app:attr0838="@drawable/shadow_send_location" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textSize="@dimen/dimen0fb6"
                android:textColor="?attr0a46"
                android:gravity="center"
                android:id="@id/status"
                android:background="?attr0506"
                android:paddingTop="8.0dip"
                android:paddingBottom="8.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            android:scaleType="fitXY"
            android:layout_alignParentRight="true"
            app:attr0838="@drawable/shadow_send_location_landscape" />
    </RelativeLayout>
    <FrameLayout
        android:layout_width="0.0dip"
        android:layout_height="fill_parent"
        android:layout_weight="0.5">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/user_list"
            android:paddingTop="1.0dip"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/landscape_selected_list_holder"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/selected_list_title_holder"
                android:background="?notification_material_background_media_default_color"
                android:paddingLeft="12.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:minHeight="48.0dip">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/selected_cancel"
                    android:layout_width="30.0dip"
                    android:layout_height="30.0dip"
                    android:layout_marginRight="26.0dip"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/str3dac"
                    app:attr0838="@drawable/ic_close_white_small"
                    app:attr090d="?attr0a2f" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb0"
                    android:textColor="?attr0a2f"
                    android:layout_gravity="center_vertical"
                    android:id="@id/selected_list_title"
                    android:focusable="false"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/style03c7" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@id/selected_list"
                android:background="?attr0a59"
                android:paddingTop="1.0dip"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>