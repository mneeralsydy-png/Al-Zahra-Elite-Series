<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center|left"
        android:orientation="vertical"
        android:id="@id/content"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/dimen012b"
        android:minHeight="30.0dip">
        <ViewStub
            android:id="@id/conversation_row_participant_header_view_stub"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <include
            layout="@layout/layout054e" />
        <include
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            layout="@layout/layout04e1" />
        <com.whatsapp.conversation.ui.conversationrow.businessmessaging.interactive.components.InteractiveAndDateLayout
            android:orientation="vertical"
            android:id="@id/interactive_and_date_layout"
            android:paddingBottom="@dimen/dimen0b5f"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.conversation.ui.conversationrow.businessmessaging.interactive.InteractiveMessageView
                android:layout_gravity="start"
                android:orientation="vertical"
                android:id="@id/interactive_view"
                android:paddingBottom="@dimen/dimen042e"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:minWidth="@dimen/dimen03d9" />
            <include
                layout="@layout/layout04ba" />
        </com.whatsapp.conversation.ui.conversationrow.businessmessaging.interactive.components.InteractiveAndDateLayout>
        <View
            android:id="@id/button_div"
            style="@style/style0356" />
        <com.whatsapp.conversation.ui.conversationrow.businessmessaging.interactive.components.InteractiveMessageButton
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@id/button"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</merge>