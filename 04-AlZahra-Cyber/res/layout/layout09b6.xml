<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:id="@id/scroll_view"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.wds.components.banners.WDSBanner
            android:id="@id/logging_out_soon_banner"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.0dip"
            android:layout_marginBottom="16.0dip"
            android:layout_marginStart="16.0dip"
            android:layout_marginEnd="16.0dip"
            style="@style/style0576" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center_horizontal"
            android:id="@id/device_image"
            android:layout_width="88.0dip"
            android:layout_height="88.0dip"
            android:layout_marginLeft="24.0dip"
            android:layout_marginTop="16.0dip"
            android:layout_marginRight="24.0dip"
            android:layout_marginBottom="16.0dip"
            android:scaleType="fitCenter"
            app:attr0838="@drawable/device_list_ic_unknown_browser" />
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/device_name_container"
            android:background="?android:selectableItemBackground"
            android:paddingLeft="24.0dip"
            android:paddingTop="16.0dip"
            android:paddingRight="24.0dip"
            android:paddingBottom="16.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb6"
                    android:textColor="?attr0a46"
                    android:id="@id/device_name_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str1167"
                    android:lineSpacingExtra="3.0sp"
                    app:attr0a24="wds_font_body2" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb0"
                    android:textColor="?attr066e"
                    android:id="@id/device_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2.0dip"
                    android:lineSpacingExtra="2.0sp"
                    app:attr0a24="wds_font_body1" />
            </LinearLayout>
            <com.whatsapp.ui.coreui.base.WaImageView
                android:layout_gravity="center_vertical"
                android:id="@id/device_name_edit_btn"
                android:layout_width="24.0dip"
                android:layout_height="24.0dip"
                android:layout_marginStart="4.0dip"
                app:attr0838="@drawable/ic_edit_white"
                app:attr090d="?attr0a46" />
        </LinearLayout>
        <View
            style="@style/style0355" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb6"
            android:textColor="?attr0a46"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24.0dip"
            android:layout_marginTop="24.0dip"
            android:layout_marginRight="24.0dip"
            android:layout_marginBottom="8.0dip"
            android:text="@string/str1165"
            app:attr0a24="wds_font_body2" />
        <LinearLayout
            android:id="@id/history_sync_container"
            android:visibility="gone"
            style="@style/style01de">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/history_sync_icon"
                app:attr0838="@drawable/ic_history"
                style="@style/style01df" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/history_sync_text"
                style="@style/style01e0" />
        </LinearLayout>
        <LinearLayout
            android:id="@id/status_container"
            style="@style/style01de">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/status_icon"
                app:attr0838="@drawable/ic_schedule"
                style="@style/style01df" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/status_text"
                style="@style/style01e0" />
        </LinearLayout>
        <LinearLayout
            android:id="@id/platform_container"
            style="@style/style01de">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/platform_icon"
                app:attr0838="@drawable/ic_language"
                style="@style/style01df" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/platform_text"
                style="@style/style01e0" />
        </LinearLayout>
        <LinearLayout
            android:id="@id/location_container"
            style="@style/style01de">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/location_icon"
                app:attr0838="@drawable/ic_location_on_white"
                style="@style/style01df" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/location_text"
                style="@style/style01e0" />
        </LinearLayout>
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/log_out_btn"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16.0dip"
            android:text="@string/str1c07"
            style="@style/style055b" />
    </LinearLayout>
</ScrollView>