<?xml version="1.0" encoding="utf-8"?>
<com.whatsapp.ui.coreui.WaLinearLayout
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <include
        layout="@layout/layout12f5" />
    <com.whatsapp.ui.coreui.WaLinearLayout
        android:orientation="vertical"
        android:id="@id/wfal_settings_row"
        android:background="?android:selectableItemBackground"
        android:paddingLeft="@dimen/dimen103b"
        android:paddingTop="@dimen/dimen102e"
        android:paddingRight="@dimen/dimen103b"
        android:paddingBottom="@dimen/dimen102e"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/account_center_meta_lockup_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/meta_lockup" />
        <com.whatsapp.ui.coreui.WaLinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ProgressBar
                android:layout_gravity="center_vertical"
                android:id="@id/wfal_spinner"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="progressBarStyleSmallInverse" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textAppearance="@style/style05a4"
                android:textColor="?attr0a47"
                android:id="@id/wfal_title_text_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5.0dip"
                android:text="@string/str3c90"
                android:layout_weight="1.0" />
        </com.whatsapp.ui.coreui.WaLinearLayout>
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="@style/style05a6"
            android:textColor="?attr0a46"
            android:id="@id/wfal_subtitle_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen1035"
            android:text="@string/str3c8e" />
    </com.whatsapp.ui.coreui.WaLinearLayout>
    <include
        layout="@layout/layout12f5" />
</com.whatsapp.ui.coreui.WaLinearLayout>