<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:id="@id/contactpicker_text_container"
    android:paddingTop="8.0dip"
    android:paddingRight="@dimen/dimen034d"
