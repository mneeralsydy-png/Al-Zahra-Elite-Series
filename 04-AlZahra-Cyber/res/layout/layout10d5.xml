<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:id="@id/transcription_onboarding_bottom_sheet"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="@dimen/dimen0cee"
        android:paddingTop="@dimen/dimen0cec"
        android:paddingRight="@dimen/dimen0cee"
        android:paddingBottom="@dimen/dimen0cee"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center"
            android:paddingBottom="@dimen/dimen0ceb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:attr0838="@drawable/wds_picto_text_warning" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:paddingBottom="@dimen/dimen0cee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str350c"
            app:attr03ae="?attr03b6"
            style="@style/style052b" />
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen0cee">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen0ce7"
                app:attr0838="@drawable/vec_ic_public" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/transcription_choose_language_per_chat_choose_language"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str3509"
                android:lineSpacingExtra="5.0sp"
                android:layout_marginStart="@dimen/dimen0cf2"
                android:layout_marginEnd="@dimen/dimen0cf1"
                app:attr03ae="?attr03b6"
                style="@style/style052c" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen0cee">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen0ce7"
                app:attr0838="@drawable/vec_ic_chat_support_wds" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str350a"
                android:lineSpacingExtra="5.0sp"
                android:layout_marginStart="@dimen/dimen0cf2"
                android:layout_marginEnd="@dimen/dimen0cf1"
                app:attr03ae="?attr03b6"
                style="@style/style052c" />
        </LinearLayout>
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:id="@id/transcription_choose_language_per_chat_settings"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen0cee"
            android:text="@string/str350b"
            android:lineSpacingExtra="5.0sp"
            android:layout_marginStart="@dimen/dimen0cf2"
            android:layout_marginEnd="@dimen/dimen0cf2"
            app:attr03ae="?attr03b6"
            style="@style/style052c" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/transcription_choose_language_per_chat_okay_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str22a9"
            style="@style/style0555" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>