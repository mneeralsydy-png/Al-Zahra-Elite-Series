<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:id="@id/conversation_row_newsletter_admin_profile_container"
    android:paddingLeft="@dimen/dimen0ce9"
    android:paddingTop="@dimen/dimen0ced"
    android:paddingRight="@dimen/dimen0ce9"
    android:paddingBottom="@dimen/dimen0cec"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/conversation_row_profile_pic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:layout_marginEnd="@dimen/dimen0ce7">
        <com.whatsapp.ui.wds.components.profilephoto.WDSProfilePhoto
            android:id="@id/group_profile_pic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:importantForAccessibility="no"
            app:attr0674="circle"
            app:attr0675="xx_small" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb6"
            android:textColor="?attr0a2f"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/group_profile_initials"
            android:background="@drawable/newsletter_admin_initials_background"
            android:visibility="gone"
            android:layout_width="@dimen/dimen100d"
            android:layout_height="@dimen/dimen100d"
            android:singleLine="true"
            android:importantForAccessibility="no"
            app:attr03ae="?attr03b8"
            app:attr0a24="wds_font_chat_body2_emphasized" />
    </FrameLayout>
    <com.whatsapp.ui.coreui.base.TextEmojiLabel
        android:id="@id/profile_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/style01bb" />
</LinearLayout>