<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:gravity="center"
    android:orientation="vertical"
    android:id="@id/about_community_bottom_sheet"
    android:layout_width="fill_parent"
    android:layout_height="0.0dip"
    android:layout_weight="1.0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageButton
            android:layout_gravity="center|left|top"
            android:id="@id/bottom_sheet_close_button"
            android:background="?attr076e"
            android:layout_width="@dimen/dimen02cf"
            android:layout_height="@dimen/dimen02cf"
            android:layout_marginLeft="@dimen/dimen0ce7"
            android:layout_marginTop="@dimen/dimen0cea"
            android:contentDescription="@string/str3dac"
            app:attr0838="@drawable/ic_close"
            app:attr090d="@color/color0347" />
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:paddingTop="@dimen/dimen0cf1"
                android:layout_width="@dimen/dimen02c1"
                android:layout_height="wrap_content"
                app:attr0838="@drawable/vec_community_creation_nux" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fc0"
                android:gravity="center"
                android:id="@id/about_community_title"
                android:paddingTop="@dimen/dimen0cee"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str005d"
                app:attr0a24="wds_font_headline1"
                style="@style/style0566" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:gravity="center"
                android:id="@id/about_community_name"
                android:paddingTop="@dimen/dimen0cec"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                style="@style/style0401" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textSize="@dimen/dimen0fb0"
                android:textColor="@color/color0905"
                android:gravity="center"
                android:id="@id/about_community_description"
                android:paddingLeft="@dimen/dimen0cee"
                android:paddingTop="@dimen/dimen0cea"
                android:paddingRight="@dimen/dimen0cee"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                style="@style/style03c7" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textSize="@dimen/dimen0fbc"
                android:textColor="@color/color02e4"
                android:gravity="center"
                android:id="@id/additional_community_description"
                android:paddingLeft="@dimen/dimen0cee"
                android:paddingTop="@dimen/dimen0cea"
                android:paddingRight="@dimen/dimen0cee"
                android:paddingBottom="@dimen/dimen0ce8"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str005b"
                style="@style/style03c7" />
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:id="@id/about_community_join_button"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen0cea"
                android:layout_marginRight="@dimen/dimen0cea"
                android:layout_marginBottom="@dimen/dimen0cee"
                android:text="@string/str005e"
                style="@style/style055c" />
        </LinearLayout>
    </FrameLayout>
</ScrollView>