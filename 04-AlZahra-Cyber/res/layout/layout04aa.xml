<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@id/contact_info_header"
        android:background="?attr076d"
        android:padding="12.0dip"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.wds.components.profilephoto.WDSProfilePhoto
            android:layout_gravity="center"
            android:id="@id/contact_photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_settings_profile"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:transitionName="@string/str42e3"
            app:attr0675="x_large" />
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:ellipsize="end"
            android:gravity="left"
            android:layout_gravity="center"
            android:id="@id/contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.0dip"
            android:maxLines="2"
            android:scrollHorizontally="false"
            android:singleLine="false"
            style="@style/style05bd" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="left"
            android:layout_gravity="center"
            android:id="@id/info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0cec"
            android:text="@string/str07e6"
            app:attr03bb="500"
            style="@style/style05be" />
    </LinearLayout>
</merge>