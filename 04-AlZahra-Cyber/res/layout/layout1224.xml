<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:importantForAccessibility="noHideDescendants"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:id="@id/debug_header_view"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:id="@id/debug_tx_network_conditioner_param_text_view"
            android:layout_alignParentTop="true"
            android:layout_toStartOf="@id/debug_spinner"
            android:layout_toEndOf="@id/debug_btn"
            style="@style/style0551" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:id="@id/debug_rx_network_conditioner_param_text_view"
            android:layout_below="@id/debug_tx_network_conditioner_param_text_view"
            android:layout_toStartOf="@id/debug_spinner"
            android:layout_toEndOf="@id/debug_btn"
            style="@style/style0550" />
        <com.whatsapp.ui.coreui.base.WaImageButton
            android:id="@id/debug_btn"
            android:layout_width="60.0dip"
            android:layout_height="40.0dip"
            android:layout_alignParentTop="true"
            android:layout_marginStart="@dimen/dimen016f"
            android:layout_marginEnd="@dimen/dimen016f"
            android:layout_alignParentStart="true"
            android:backgroundTint="@color/color07e1"
            app:attr0838="@drawable/ic_info_white" />
        <com.whatsapp.ui.coreui.CircularProgressBar
            android:layout_gravity="end"
            android:id="@id/debug_spinner"
            android:layout_width="40.0dip"
            android:layout_height="40.0dip"
            android:indeterminate="true"
            android:indeterminateOnly="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="@dimen/dimen016f"
            android:layout_marginEnd="@dimen/dimen016f"
            android:layout_alignParentEnd="true"
            android:indeterminateTint="?attr0a29"
            android:indeterminateTintMode="src_atop"
            app:attr028b="?attr0a59"
            app:attr028c="?attr0a29"
            app:attr0290="4.0" />
    </RelativeLayout>
    <ScrollView
        android:textColor="?attr0a2f"
        android:id="@id/call_debug_view"
        android:background="?attr00b5"
        android:paddingLeft="8.0dip"
        android:paddingRight="8.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/debug_header_view">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fbc"
            android:textStyle="bold"
            android:id="@id/call_debug_stats"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </ScrollView>
</RelativeLayout>