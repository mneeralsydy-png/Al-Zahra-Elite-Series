<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/favorites_logo"
            android:layout_width="@dimen/dimen05a1"
            android:layout_height="@dimen/dimen05a0"
            android:layout_margin="@dimen/dimen103b"
            app:attr0838="@drawable/vec_favorites_logo" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:focusable="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen103b"
            android:layout_marginRight="@dimen/dimen103b"
            android:text="@string/str2dd3"
            android:textAlignment="center"
            app:attr0a24="wds_font_headline1"
            style="@style/style05aa" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:focusable="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen103b"
            android:layout_marginTop="@dimen/dimen103b"
            android:layout_marginRight="@dimen/dimen103b"
            android:text="@string/str1006"
            android:textAlignment="center"
            app:attr0a24="wds_font_body1"
            style="@style/style05a4" />
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/function_one"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginLeft="@dimen/dimen103b"
            android:layout_marginTop="@dimen/dimen102e"
            android:layout_marginRight="@dimen/dimen103b">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/lock_privacy_icon"
                android:layout_width="@dimen/dimen0fd9"
                android:layout_height="@dimen/dimen0fd9"
                android:layout_marginLeft="@dimen/dimen1039"
                android:layout_marginTop="@dimen/dimen1031"
                android:layout_marginRight="@dimen/dimen103b"
                android:layout_marginBottom="@dimen/dimen1031"
                app:attr0838="@drawable/ic_lock_person"
                app:attr090d="@color/color08de" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:gravity="start"
                android:focusable="true"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen1031"
                android:layout_marginBottom="@dimen/dimen1031"
                android:text="@string/str1494"
                app:attr0a24="wds_font_body1"
                style="@style/style05a4" />
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/function_two"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginLeft="@dimen/dimen103b"
            android:layout_marginTop="@dimen/dimen102e"
            android:layout_marginRight="@dimen/dimen103b"
            android:layout_marginBottom="@dimen/dimen103b">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/settings_icon"
                android:layout_width="@dimen/dimen0fd9"
                android:layout_height="@dimen/dimen0fd9"
                android:layout_marginLeft="@dimen/dimen1039"
                android:layout_marginTop="@dimen/dimen1031"
                android:layout_marginRight="@dimen/dimen103b"
                android:layout_marginBottom="@dimen/dimen1031"
                app:attr0838="@drawable/wa_ic_settings"
                app:attr090d="@color/color08de" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:gravity="start"
                android:focusable="true"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen1031"
                android:layout_marginBottom="@dimen/dimen1031"
                android:text="@string/str1495"
                app:attr0a24="wds_font_body1"
                style="@style/style05a4" />
        </LinearLayout>
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:layout_gravity="center"
            android:id="@id/continue_button"
            android:text="@string/str3d8c"
            style="@style/style055c" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:layout_gravity="center"
            android:id="@id/manage_favorite"
            android:layout_marginBottom="@dimen/dimen103b"
            android:text="@string/str1c33"
            style="@style/style0557" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>