<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:padding="@dimen/dimen1039"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center|left"
            android:id="@id/conversation_row_lto_offer_icon"
            android:background="@drawable/circle_shade_big"
            android:padding="@dimen/dimen1039"
            android:visibility="visible"
            android:layout_width="48.0dip"
            android:layout_height="48.0dip"
            android:scaleType="fitCenter"
            android:tint="@color/color0922"
            android:backgroundTint="@color/color05ee"
            app:attr0838="@drawable/ic_gift_card" />
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:paddingTop="@dimen/dimen1039"
        android:paddingRight="@dimen/dimen1039"
        android:paddingBottom="@dimen/dimen1039"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="@style/style05a7"
            android:textColor="@color/color05f4"
            android:id="@id/offer_title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textAlignment="viewStart"
            app:attr0a24="wds_font_body2_emphasized" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="@style/style05a8"
            android:textColor="?attr0a47"
            android:id="@id/lto_expiration"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:attr0a24="wds_font_body3" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="@style/style05a8"
            android:textColor="?attr0a46"
            android:id="@id/coupon_code"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            app:attr0a24="wds_font_body3" />
    </LinearLayout>
</LinearLayout>