<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="?android:selectableItemBackground"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:minHeight="@dimen/dimen0ffd"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ViewStub
        android:id="@id/lists_item_left_add_on"
        android:layout="@layout/layout09e4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/lists_item_row"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen103a"
        android:layout_marginBottom="@dimen/dimen103a"
        android:layout_weight="1.0"
        android:layout_marginStart="@dimen/dimen103b"
        android:layout_marginEnd="1.0dip">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:ellipsize="end"
            android:id="@id/lists_item_row_title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dimen0faf"
            android:maxLines="1"
            android:textAlignment="viewStart"
            app:attr0a24="wds_font_body1"
            style="@style/style05a4" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="@color/color08de"
            android:ellipsize="end"
            android:layout_gravity="start|center"
            android:id="@id/lists_item_row_entity"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0763"
            android:minHeight="@dimen/dimen0fb5"
            android:maxLines="1"
            android:textAlignment="viewStart"
            app:attr0a24="wds_font_body2"
            style="@style/style05a6" />
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen102e"
        android:layout_marginEnd="@dimen/dimen1039">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/lists_delete"
            android:padding="@dimen/dimen1039"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/vec_ic_trash"
            android:layout_marginEnd="@dimen/dimen1035" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/lists_reorder"
            android:padding="@dimen/dimen1039"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/vec_ic_menu_reorder"
            android:layout_marginEnd="@dimen/dimen1030" />
    </LinearLayout>
</LinearLayout>