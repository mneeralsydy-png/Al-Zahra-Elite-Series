                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textAppearance="?attr09f0"
                    android:id="@id/response_text"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dimen0ce7"
                    android:layout_marginStart="@dimen/dimen0ce7"
                    app:attr0a24="wds_font_chat_body1" />
