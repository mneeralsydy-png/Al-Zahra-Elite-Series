                android:layout_height="fill_parent" />
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:paddingEnd="@dimen/dimen0ce7">
                <LinearLayout
