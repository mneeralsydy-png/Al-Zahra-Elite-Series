<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:whatsapp="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.wds.components.profilephoto.WDSProfilePhoto
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@id/wds_profile_picture"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen0ce8"
        whatsapp:attr0675="xx_large" />
    <LinearLayout
        android:layout_gravity="bottom|center"
        android:orientation="horizontal"
        android:background="@drawable/status_custom_audience_label_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen1039"
        android:layout_marginBottom="@dimen/dimen0ced"
        android:rotation="-2.0">
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:textSize="20.0sp"
            android:layout_gravity="center_vertical"
            android:id="@id/audience_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen0ce7" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="12.0sp"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@id/audience_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0ce7"
            android:layout_marginBottom="@dimen/dimen0ce7"
            android:maxLines="1"
            android:layout_marginStart="@dimen/dimen1030"
            android:layout_marginEnd="@dimen/dimen0ce7"
            whatsapp:attr0a24="wds_font_body1_emphasized"
            style="?attr09f7" />
    </LinearLayout>
</FrameLayout>