<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/fragment_consumer_disclosure"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaImageButton
        android:layout_gravity="end"
        android:id="@id/dismiss_disclosure"
        android:background="?attr076e"
        android:visibility="gone"
        android:layout_width="24.0dip"
        android:layout_height="24.0dip"
        android:layout_marginBottom="@dimen/dimen102f"
        android:layout_marginEnd="16.0dip"
        app:attr0838="@drawable/ic_close_themed" />
    <androidx.core.widget.NestedScrollView
        android:layout_gravity="top"
        android:id="@id/scroll_view"
        android:paddingLeft="@dimen/dimen04df"
        android:paddingRight="@dimen/dimen04df"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:fillViewport="true"
        android:layout_weight="1.0"
        android:overScrollMode="never">
        <LinearLayout
            android:gravity="center_horizontal"
            android:layout_gravity="top"
            android:orientation="vertical"
            android:paddingBottom="16.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/icon"
                android:layout_width="48.0dip"
                android:layout_height="48.0dip"
                android:layout_marginTop="24.0dip"
                app:attr0838="@drawable/vec_ic_datasharing" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fc0"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28.0dip"
                android:text="@string/str10ca"
                style="@style/style03ff" />
            <com.whatsapp.ui.coreui.FAQTextView
                android:textSize="@dimen/dimen0fb6"
                android:textColor="?android:textColorSecondary"
                android:gravity="center"
                android:id="@id/description"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16.0dip"
                style="@style/style03fb" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textColor="?attr066e"
                android:gravity="center_vertical"
                android:id="@id/data_row1"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16.0dip"
                android:text="@string/str10c5"
                android:drawablePadding="24.0dip"
                android:paddingStart="8.0dip"
                style="@style/style03fb" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textColor="?attr066e"
                android:gravity="center_vertical"
                android:id="@id/data_row2"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12.0dip"
                android:text="@string/str10c6"
                android:drawablePadding="24.0dip"
                android:paddingStart="8.0dip"
                style="@style/style03fb" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textColor="?attr066e"
                android:gravity="center_vertical"
                android:id="@id/data_row3"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12.0dip"
                android:layout_marginBottom="16.0dip"
                android:text="@string/str10c7"
                android:drawablePadding="24.0dip"
                android:paddingStart="8.0dip"
                style="@style/style03fb" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/buttons_layout"
        android:paddingLeft="@dimen/dimen04df"
        android:paddingRight="@dimen/dimen04df"
        android:paddingBottom="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/action"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.0dip"
            android:text="@string/str10c3"
            style="@style/style0555" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/cancel"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str10c2"
            style="@style/style0557" />
    </LinearLayout>
</LinearLayout>