<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:background="@drawable/list_separator_bot"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/info_screen_card_spacing" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/div4"
        android:background="@color/primary_surface"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/selector_orange_gradient"
            android:padding="@dimen/info_screen_padding"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.yo.FMImageView
                android:layout_gravity="center|left"
                android:background="@drawable/icon_background_modern"
                android:padding="6.0dip"
                android:layout_width="32.0dip"
                android:layout_height="32.0dip"
                android:layout_marginLeft="@dimen/space_base"
                android:layout_marginRight="@dimen/space_xLoose"
                android:src="@drawable/ic_full_message"
                android:scaleType="fitCenter"
                android:layout_marginStart="@dimen/space_base"
                android:layout_marginEnd="@dimen/space_xLoose"
                android:backgroundTint="#ffa1700e"
                app:customTintColor="#ffa1700e"
                app:customTintMode="src_in" />
            <LinearLayout
                android:gravity="left"
                android:layout_gravity="center|left"
                android:orientation="vertical"
                android:paddingRight="@dimen/list_item_right_view_padding"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <com.whatsapp.yo.tf
                    android:id="@id/div5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/viewallmsgs"
                    style="@style/ListItemTitle.V2" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@drawable/list_separator_top"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/info_screen_card_spacing" />
</LinearLayout>