<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.whatsapp.yo.ColorPref
        android:icon="@drawable/abo_arab_ic_hedondo"
        android:layout="@layout/abu_arab_preference_layout"
        android:title="@string/acj_actionbar"
        android:key="ModChatColor"
        android:summary="@string/acj_chat_actionbar_sum" />
    <SwitchPreference
        android:icon="@drawable/abo_arab_imagehidden"
        android:layout="@layout/abu_arab_preference_layout"
        android:title="@string/yoProfilePic"
        android:key="PicProf"
        android:summary="@string/yoProfilePicS"
        android:defaultValue="false" />
    <SwitchPreference
        android:icon="@drawable/abo_arab_namehidden"
        android:layout="@layout/abu_arab_preference_layout"
        android:title="@string/yoHideProfileName"
        android:key="NameProf"
        android:summary="@string/yoHideProfileNameS"
        android:defaultValue="false" />
    <SwitchPreference
        android:icon="@drawable/abo_arab_callhiden"
        android:layout="@layout/abu_arab_preference_layout"
        android:title="@string/yoCallBtn"
        android:key="Conv_call_btn"
        android:summary="@string/yoCallBtnSum"
        android:defaultValue="false" />
    <SwitchPreference
        android:icon="@drawable/abo_arab_recadohidden"
        android:layout="@layout/abu_arab_preference_layout"
        android:title="@string/yoContactStatus"
        android:key="statuschat"
        android:summary="@string/yoContactStatusSum"
        android:defaultValue="false" />
    <com.whatsapp.yo.ColorPref
        android:icon="@drawable/abo_arab_recadocolor"
        android:layout="@layout/abu_arab_preference_layout"
        android:title="@string/contactstatusC"
        android:key="ModChatGStatusB"
        android:summary="@string/contactstatusCSB" />
    <com.whatsapp.yo.ColorPref
        android:icon="@drawable/abo_arab_textorecado"
        android:layout="@layout/abu_arab_preference_layout"
        android:title="@string/contactstatusTC"
        android:key="ModChatGStatusT"
        android:summary="@string/contactstatusCS" />
    <ListPreference
        android:icon="@drawable/abo_arab_ic_newheader"
        android:entries="@array/conversation_style_toolbar"
        android:layout="@layout/abu_arab_preference_cevron"
        android:title="@string/yocent"
        android:key="convostyle"
        android:summary="@string/yocentS"
        android:entryValues="@array/conversation_style_toolbar_values" />
</PreferenceScreen>