<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_pressed="false">
        <layer-list>
            <item>
                <shape>
                    <solid
                        android:color="#ffffffff" />
                    <corners
                        android:radius="19.0dip" />
                </shape>
            </item>
            <item
                android:bottom="5.0px">
                <shape>
                    <padding
                        android:bottom="5.0dip" />
                    <gradient
                        android:startColor="#0066FF"
                        android:endColor="#0066FF"
                        android:angle="270.0" />
                    <corners
                        android:radius="19.0dip" />
                    <padding
                        android:left="10.0dip"
                        android:top="10.0dip"
                        android:right="5.0dip"
                        android:bottom="10.0dip" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item
        android:state_pressed="true">
        <layer-list>
            <item>
                <shape>
                    <solid
                        android:color="#0066FF" />
                    <corners
                        android:radius="19.0dip" />
                </shape>
            </item>
            <item
                android:bottom="5.0px">
                <shape>
                    <padding
                        android:bottom="5.0dip" />
                    <gradient
                        android:startColor="#0066FF"
                        android:endColor="#0066FF"
                        android:angle="270.0" />
                    <corners
                        android:radius="19.0dip" />
                    <padding
                        android:left="10.0dip"
                        android:top="10.0dip"
                        android:right="5.0dip"
                        android:bottom="10.0dip" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>