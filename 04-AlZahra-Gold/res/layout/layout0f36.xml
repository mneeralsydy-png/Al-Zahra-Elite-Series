<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen103b"
        android:src="@drawable/wds_anim_bell_notifications_off_mute"
        android:importantForAccessibility="no" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="@string/str2247"
        android:textAlignment="center"
        style="@style/style05aa" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:textColor="@color/color08de"
        android:paddingLeft="@dimen/dimen102f"
        android:paddingRight="@dimen/dimen102f"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen102e"
        android:layout_marginTop="@dimen/dimen102e"
        android:layout_marginRight="@dimen/dimen102e"
        android:layout_marginBottom="@dimen/dimen103b"
        android:text="@string/str2248"
        android:textAlignment="center"
        style="@style/style05a6" />
    <com.whatsapp.ui.wds.components.button.WDSButton
        android:layout_gravity="center"
        android:id="@id/go_to_settings_button"
        android:layout_marginLeft="@dimen/dimen102e"
        android:layout_marginTop="@dimen/dimen0ce7"
        android:layout_marginRight="@dimen/dimen102e"
        android:layout_marginBottom="@dimen/dimen0ce7"
        android:text="@string/str168e"
        style="@style/style055c" />
</LinearLayout>