<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/thumb_container"
    android:layout_width="@dimen/dimen0736"
    android:layout_height="@dimen/dimen0734"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.whatsapp.ui.coreui.components.button.ThumbnailButton
        android:id="@id/thumb"
        android:layout_width="@dimen/dimen0736"
        android:layout_height="@dimen/dimen0734"
        android:scaleType="centerCrop" />
    <ImageView
        android:layout_gravity="start|bottom|center"
        android:id="@id/video_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen04e8"
        android:src="@drawable/mark_video"
        android:importantForAccessibility="no"
        android:layout_marginStart="@dimen/dimen04e8" />
</FrameLayout>