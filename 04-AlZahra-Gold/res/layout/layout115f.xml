<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ScrollView
        android:id="@id/scroll_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:fillViewport="true">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="@dimen/dimen0cea"
            android:paddingBottom="@dimen/dimen0cea"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dimen0cee"
            android:paddingEnd="@dimen/dimen0cee">
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textColor="?attr0a46"
                android:gravity="center_horizontal"
                android:id="@id/verify_email_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dimen0cf4"
                android:text="@string/str38b3"
                style="@style/style05a6" />
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.CodeInputField
                    android:textSize="22.0sp"
                    android:gravity="bottom|center"
                    android:id="@id/verify_email_code_input"
                    android:background="@null"
                    android:layout_width="160.0sp"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:digits=" 0123456789"
                    android:inputType="phone"
                    app:attr02ff="outline" />
                <ProgressBar
                    android:id="@id/progress_bar_code_input_blocked"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="2.0dip"
                    android:layout_marginTop="5.0dip"
                    android:progressDrawable="@drawable/email_auth_selector_progress_bar"
                    android:importantForAccessibility="no"
                    style="@android:style/Widget.ProgressBar.Horizontal" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb6"
                    android:textStyle="bold"
                    android:textColor="?attr0a29"
                    android:layout_gravity="center_horizontal"
                    android:id="@id/resend_code_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen0cea"
                    android:text="@string/str11c1"
                    style="@style/style03c8" />
                <ViewStub
                    android:id="@id/shortest_wait_time_text_view_stub"
                    android:layout="@layout/layout0f63"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen0ce7" />
            </LinearLayout>
            <Space
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:layout_weight="1.0" />
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:enabled="false"
                android:id="@id/email_code_submit"
                android:layout_width="fill_parent"
                android:layout_marginTop="@dimen/dimen0ce7"
                android:layout_marginBottom="@dimen/dimen0ce8"
                android:text="@string/str11d9"
                style="@style/style0555" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>