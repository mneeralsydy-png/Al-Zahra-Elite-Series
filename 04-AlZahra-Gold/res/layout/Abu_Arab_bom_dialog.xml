<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="horizontal"
        android:background="@color/abo_arab_primary"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.yo.tf
            android:textSize="17.0sp"
            android:textStyle="bold"
            android:textColor="@color/mas_white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16.0dip"
            android:text="@string/title_autotext" />
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:padding="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10.0dip"
            android:layout_marginTop="15.0dip"
            android:layout_marginRight="10.0dip"
            android:layout_marginBottom="15.0dip">
            <ImageView
                android:layout_gravity="center"
                android:layout_width="0.0dip"
                android:layout_height="2.0dip"
                android:src="@color/abo_arab_accent"
                android:layout_weight="1.0" />
            <com.whatsapp.yo.tf
                android:textSize="18.0sp"
                android:textStyle="bold"
                android:textColor="@color/abo_arab_accent"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5.0dip"
                android:layout_marginRight="5.0dip"
                android:text="@string/title_autotext_input" />
            <ImageView
                android:layout_gravity="center"
                android:layout_width="0.0dip"
                android:layout_height="2.0dip"
                android:src="@color/abo_arab_accent"
                android:layout_weight="1.0" />
        </LinearLayout>
        <EditText
            android:id="@id/mInput"
            android:background="@null"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4.0dip" />
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10.0dip"
            android:layout_marginTop="15.0dip"
            android:layout_marginRight="10.0dip"
            android:layout_marginBottom="15.0dip">
            <ImageView
                android:layout_gravity="center"
                android:layout_width="0.0dip"
                android:layout_height="2.0dip"
                android:src="@color/abo_arab_accent"
                android:layout_weight="1.0" />
            <com.whatsapp.yo.tf
                android:textSize="18.0sp"
                android:textStyle="bold"
                android:textColor="@color/abo_arab_accent"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5.0dip"
                android:layout_marginRight="5.0dip"
                android:text="@string/title_autotext_count" />
            <ImageView
                android:layout_gravity="center"
                android:layout_width="0.0dip"
                android:layout_height="2.0dip"
                android:src="@color/abo_arab_accent"
                android:layout_weight="1.0" />
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <include
                android:gravity="center"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                layout="@layout/abu_arab_databases4" />
        </LinearLayout>
        <EditText
            android:id="@id/mCount"
            android:background="@null"
            android:focusable="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4.0dip"
            android:singleLine="true"
            android:inputType="number" />
    </LinearLayout>
</LinearLayout>