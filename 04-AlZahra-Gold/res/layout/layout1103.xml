        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="@style/style05a5"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str2c31"
            app:attr0a24="wds_font_body1_emphasized" />
