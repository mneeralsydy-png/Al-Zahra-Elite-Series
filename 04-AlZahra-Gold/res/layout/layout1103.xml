                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str2b4a"
                android:layout_marginStart="8.0dip"
                app:attr0a24="wds_font_body3" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>