                        android:textAppearance="@style/style05a6"
                        android:textColor="@color/color08de"
                        android:id="@id/block_checkbox_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str2be5"
                        app:attr0a24="wds_font_body2" />
                </LinearLayout>
            </LinearLayout>
            <ViewStub
                android:id="@id/report_spam_data_sharing_label_stub"
                android:layout="@layout/layout05f2"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_marginTop="16.0dip" />
            <LinearLayout
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24.0dip">
                <com.whatsapp.ui.wds.components.button.WDSButton
                    android:id="@id/report_spam_dialog_cancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str3d9b"
                    android:layout_marginEnd="8.0dip"
                    app:attr096b="borderless" />
                <com.whatsapp.ui.wds.components.button.WDSButton
                    android:id="@id/report_spam_dialog_send"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str4203"
                    app:attr096b="borderless" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:id="@id/report_spam_dialog_loading"
        android:padding="24.0dip"
