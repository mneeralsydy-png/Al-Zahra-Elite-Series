<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/report_spam_dialog_root"
    android:background="@drawable/spam_report_dialog_background"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ScrollView
        android:id="@id/report_spam_dialog_content"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:padding="24.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:layout_gravity="center"
                android:id="@id/report_icon"
                android:layout_width="24.0sp"
                android:layout_height="24.0sp"
                android:layout_marginBottom="16.0dip"
                android:tint="?attr0a46"
                app:attr0838="@drawable/ic_thumb_down" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textAppearance="@style/style05aa"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/report_spam_dialog_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str2bf4"
                app:attr0a24="wds_font_headline1" />
            <com.whatsapp.ui.coreui.base.WaTextView
