<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/translation_feedback_group"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaTextView
        android:gravity="start"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="@string/str3985"
        style="@style/style040e" />
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen0ce7">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/translation_feedback_useful"
            android:background="?attr076e"
            android:padding="@dimen/dimen1030"
            android:layout_width="@dimen/dimen0fd9"
            android:layout_height="@dimen/dimen0fd9"
            android:tint="@color/color08de"
            android:contentDescription="@string/str3534"
            app:attr0838="@drawable/vec_ic_thumb_up" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/translation_feedback_not_useful"
            android:background="?attr076e"
            android:padding="@dimen/dimen1030"
            android:layout_width="@dimen/dimen0fd9"
            android:layout_height="@dimen/dimen0fd9"
            android:tint="@color/color08de"
            android:contentDescription="@string/str3533"
            android:layout_marginStart="@dimen/dimen0cee"
            app:attr0838="@drawable/vec_ic_thumb_down" />
    </LinearLayout>
</LinearLayout>