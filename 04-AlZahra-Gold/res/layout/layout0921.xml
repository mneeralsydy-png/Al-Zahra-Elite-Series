<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ScrollView
        style="@style/style0266">
        <LinearLayout
            style="@style/style0268">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/instrumentation_auth_image"
                app:attr0838="@drawable/private_ptt"
                style="@style/style025d" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:layout_marginBottom="@dimen/dimen0cea"
                android:text="@string/str19b0"
                style="@style/style0267" />
            <LinearLayout
                style="@style/style025f">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:paddingRight="@dimen/dimen0cea"
                    app:attr0838="@drawable/ic_settings_chats"
                    style="@style/style0260" />
                <LinearLayout
                    style="@style/style0263">
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:id="@id/instrumentation_auth_complete_bullet_one"
                        android:text="@string/str199f"
                        style="@style/style0262" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:id="@id/instrumentation_auth_complete_bullet_one_body"
                        android:text="@string/str19a0"
                        style="@style/style0261" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                style="@style/style025f">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:paddingRight="@dimen/dimen0cea"
                    app:attr0838="@drawable/ic_keyboard_voice"
                    style="@style/style0260" />
                <LinearLayout
                    style="@style/style0263">
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:id="@id/instrumentation_auth_complete_bullet_two"
                        android:text="@string/str19a6"
                        style="@style/style0262" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:id="@id/instrumentation_auth_complete_bullet_two_body"
                        android:text="@string/str19a7"
                        style="@style/style0261" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                style="@style/style025f">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:paddingRight="@dimen/dimen0cea"
                    app:attr0838="@drawable/ic_settings"
                    style="@style/style0260" />
                <LinearLayout
                    style="@style/style0263">
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:id="@id/instrumentation_auth_complete_bullet_three"
                        android:text="@string/str19a2"
                        style="@style/style0262" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:id="@id/instrumentation_auth_complete_bullet_three_body"
                        android:text="@string/str19a3"
                        style="@style/style0261" />
                </LinearLayout>
            </LinearLayout>
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/instrumentation_auth_complete_link"
                android:layout_marginTop="@dimen/dimen0cea"
                android:text="@string/str19ad"
                style="@style/style025c" />
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        style="@style/style025a">
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/instrumentation_auth_complete_button"
            android:text="@string/str19ab"
            style="@style/style025b" />
    </LinearLayout>
</LinearLayout>