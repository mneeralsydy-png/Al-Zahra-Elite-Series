<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@id/ban_info"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            android:layout_weight="1.0">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/ban_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen0cf2" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textAppearance="@style/style05aa"
                android:gravity="center"
                android:id="@id/heading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen0cee"
                android:layout_marginStart="@dimen/dimen0cee"
                android:layout_marginEnd="@dimen/dimen0cee"
                app:attr0a24="wds_font_headline1" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textAppearance="@style/style05a6"
                android:textColor="@color/color08de"
                android:gravity="center"
                android:id="@id/sub_heading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen0cea"
                android:lineSpacingExtra="2.0sp"
                android:layout_marginStart="@dimen/dimen0cee"
                android:layout_marginEnd="@dimen/dimen0cee" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textAppearance="@style/style05a6"
                android:textColor="@color/color08de"
                android:gravity="center"
                android:id="@id/sub_heading_2"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen0cea"
                android:lineSpacingExtra="2.0sp"
                android:layout_marginStart="@dimen/dimen0cee"
                android:layout_marginEnd="@dimen/dimen0cee"
                app:attr0a24="wds_font_body2" />
        </LinearLayout>
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:gravity="center"
            android:id="@id/action_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dimen0cea"
            style="@style/style055d" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:gravity="center"
            android:id="@id/action_button_2"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dimen0cea"
            style="@style/style0555" />
    </LinearLayout>
</ScrollView>