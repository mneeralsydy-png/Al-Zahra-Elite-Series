<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/dimen103b"
        android:paddingEnd="@dimen/dimen103b">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center_horizontal"
            android:id="@id/paid_partnership_icon"
            android:layout_width="@dimen/dimen0fe9"
            android:layout_height="@dimen/dimen0fe9"
            android:layout_marginTop="@dimen/dimen103b"
            android:layout_marginBottom="@dimen/dimen102e"
            app:attr0838="@drawable/wds_picto_megaphone_ads" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:id="@id/paid_partnership_title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen102e"
            android:text="@string/str2415"
            app:attr03ae="?attr03b8"
            app:attr0a24="wds_font_headline2"
            style="@style/style05ab" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="?attr0a46"
            android:gravity="center"
            android:id="@id/paid_partnership_body"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dimen1039"
            android:text="@string/str2412"
            app:attr0a24="wds_font_body2"
            style="@style/style05a6" />
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen102e"
            android:layout_marginBottom="@dimen/dimen102e">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textColor="?attr0a46"
                android:gravity="center"
                android:id="@id/paid_partnership_footnote"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dimen103a"
                android:text="@string/str2414"
                app:attr0a24="wds_font_body3"
                style="@style/style05a8" />
            <com.whatsapp.ui.wds.components.button.WDSButtonGroup
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.wds.components.button.WDSButton
                    android:id="@id/add_label_button"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen103b"
                    android:text="@string/str2411"
                    app:attr03ae="?attr03b8"
                    style="@style/style055c" />
                <com.whatsapp.ui.wds.components.button.WDSButton
                    android:id="@id/cancel_button"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen1039"
                    android:text="@string/str2413"
                    app:attr03ae="?attr03b8"
                    style="@style/style0557" />
            </com.whatsapp.ui.wds.components.button.WDSButtonGroup>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>