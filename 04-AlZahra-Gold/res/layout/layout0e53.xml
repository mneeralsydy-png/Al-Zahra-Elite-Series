<?xml version="1.0" encoding="utf-8"?>
<com.whatsapp.ui.coreui.KeyboardPopupLayout
    android:gravity="bottom"
    android:id="@id/edit_text_layout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/emoji_edit_text_with_expressions_tray_linear_layout"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:paddingBottom="@dimen/dimen1030"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen1030"
            android:layout_marginRight="@dimen/dimen1030">
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/reply_composer_input_background"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen1031"
                    android:layout_marginTop="@dimen/dimen1031"
                    android:layout_marginRight="@dimen/dimen1031">
                    <View
                        android:background="@drawable/reply_composer_quoted_background_left_part"
                        android:layout_width="@dimen/dimen1030"
                        android:layout_height="fill_parent" />
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:background="@drawable/reply_composer_quoted_background"
                        android:paddingLeft="@dimen/dimen0b9e"
                        android:paddingTop="@dimen/dimen1039"
                        android:paddingRight="@dimen/dimen0b9e"
                        android:paddingBottom="@dimen/dimen1039"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dimen0b9f">
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">
                            <com.whatsapp.ui.coreui.base.WaImageView
                                android:layout_gravity="center"
                                android:layout_width="@dimen/dimen0b93"
                                android:layout_height="@dimen/dimen0b93"
                                android:src="@drawable/wa_ic_help"
                                android:contentDescription="@null"
                                app:attr090d="?attr0a46" />
                            <com.whatsapp.ui.coreui.base.WaTextView
                                android:textAppearance="?attr09f6"
                                android:textColor="?attr0a46"
                                android:ellipsize="end"
                                android:id="@id/question_text_view"
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:singleLine="true"
                                android:layout_marginStart="@dimen/dimen1035"
                                app:attr0a24="wds_font_body2" />
                        </LinearLayout>
                        <com.whatsapp.ui.coreui.base.WaTextView
                            android:textAppearance="?attr09f0"
                            android:ellipsize="end"
                            android:id="@id/response_text_view"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            app:attr0a24="wds_font_body1" />
                    </LinearLayout>
                </LinearLayout>
                <ViewStub
                    android:id="@id/web_page_preview_container"
                    android:layout="@layout/layout12e8"
                    android:inflatedId="@id/web_page_preview_container"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:attr04ad="parent"
                    app:attr04b1="parent" />
                <com.whatsapp.ui.coreui.base.perf.MeasuringLinearLayout
                    android:layout_gravity="bottom"
                    android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/dimen03a5">
                    <com.whatsapp.ui.coreui.base.WaAsyncImageButton
                        android:layout_gravity="bottom"
                        android:id="@id/emoji_button"
                        android:layout_width="@dimen/dimen03a6"
                        android:layout_height="@dimen/dimen03a5"
                        android:scaleType="center"
                        android:contentDescription="@string/str3e44"
                        app:attr0838="@drawable/ic_mood_black"
                        app:attr090d="?attr0a46"
                        style="@style/style0006" />
                    <com.whatsapp.mentions.ui.MentionableEntry
                        android:scrollbarAlwaysDrawVerticalTrack="true"
                        android:scrollbarStyle="outsideOverlay"
                        android:textColor="?attr066e"
                        android:textColorHint="?attr0a46"
                        android:layout_gravity="center_vertical"
                        android:id="@id/reply_text_input"
                        android:background="@null"
                        android:paddingTop="@dimen/dimen1030"
                        android:paddingBottom="@dimen/dimen1030"
                        android:scrollbars="vertical"
                        android:layout_width="0.0dip"
                        android:layout_height="wrap_content"
                        android:maxLines="6"
                        android:capitalize="sentences"
                        android:autoText="true"
                        android:layout_weight="1.0"
                        android:imeOptions="actionSend"
                        android:scrollbarFadeDuration="300"
                        android:scrollbarDefaultDelayBeforeFade="200"
                        android:paddingEnd="@dimen/dimen1039"
                        style="?attr08bf" />
                    <com.whatsapp.ui.coreui.base.WaAsyncImageButton
                        android:layout_gravity="bottom"
                        android:id="@id/media_button"
                        android:layout_width="@dimen/dimen03a6"
                        android:layout_height="@dimen/dimen03a5"
                        android:scaleType="center"
                        android:contentDescription="@string/str3d99"
                        app:attr0837="@drawable/vec_camera_stack"
                        app:attr090d="?attr0a46"
                        style="@style/style0006" />
                </com.whatsapp.ui.coreui.base.perf.MeasuringLinearLayout>
            </LinearLayout>
            <com.whatsapp.ui.coreui.base.WaAsyncImageButton
                android:layout_gravity="bottom"
                android:id="@id/send_button"
                android:background="@drawable/input_circle_selector"
                android:layout_width="@dimen/dimen0fe5"
                android:layout_height="@dimen/dimen0fe5"
                android:scaleType="center"
                android:layout_marginStart="@dimen/dimen1030"
                app:attr0838="@drawable/input_send"
                app:attr090d="?attr0a4b" />
        </LinearLayout>
        <com.whatsapp.emoji.search.EmojiSearchKeyboardContainer
            android:id="@id/emoji_search_container"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</com.whatsapp.ui.coreui.KeyboardPopupLayout>