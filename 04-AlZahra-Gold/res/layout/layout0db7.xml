<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen05cf"
        android:layout_marginStart="@dimen/dimen05cf"
        android:layout_marginEnd="@dimen/dimen05cf">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:gravity="center_vertical"
            android:id="@id/safety_tips_close_button"
            android:layout_width="@dimen/dimen05cb"
            android:layout_height="@dimen/dimen05cb"
            android:contentDescription="@string/str3dac"
            app:attr0838="@drawable/ic_close"
            app:attr090d="@color/color0347" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="20.0sp"
            android:textColor="?attr066e"
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str1506"
            android:fontFamily="?attr03b8" />
    </FrameLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb6"
                android:textColor="?attr0a46"
                android:layout_gravity="start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05cf"
                android:text="@string/str14fc"
                android:fontFamily="?attr03b6"
                android:layout_marginStart="@dimen/dimen05cf"
                android:layout_marginEnd="@dimen/dimen05cf"
                app:attr0a24="wds_font_body2" />
            <com.whatsapp.settings.SettingsRowIconText
                android:id="@id/fmx_group_safety_tips_add_you_id"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05cc"
                app:attr07a5="?attr0a46"
                app:attr07a8="@drawable/ic_lock"
                app:attr07aa="@string/str14fa"
                app:attr07ab="@string/str14fb"
                style="?attr07a6" />
            <com.whatsapp.settings.SettingsRowIconText
                android:id="@id/fmx_group_safety_tips_report_messages_id"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05cc"
                app:attr07a5="?attr0a46"
                app:attr07a8="@drawable/ic_action_compose"
                app:attr07aa="@string/str1500"
                app:attr07ab="@string/str1501"
                style="?attr07a6" />
            <com.whatsapp.settings.SettingsRowIconText
                android:id="@id/fmx_group_safety_tips_report_group_id"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05cc"
                app:attr07a5="?attr0a46"
                app:attr07a8="@drawable/ic_thumb_down"
                app:attr07aa="@string/str14fe"
                app:attr07ab="@string/str14ff"
                style="?attr07a6" />
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:id="@id/safety_tips_learn_more"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05ce"
                android:layout_marginBottom="@dimen/dimen05cf"
                android:text="@string/str14fd"
                android:layout_marginStart="@dimen/dimen05cf"
                android:layout_marginEnd="@dimen/dimen05cf"
                style="@style/style0557" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>