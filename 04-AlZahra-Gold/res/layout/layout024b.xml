<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/header_placeholder"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen06a1" />
    <include
        layout="@layout/layout0f7c" />
    <com.whatsapp.chatinfo.group.view.custom.GroupDetailsCard
        android:id="@id/group_details_card"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <com.whatsapp.ui.coreui.InfoCard
        android:orientation="vertical"
        android:id="@id/lists_management_info_card"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        style="@style/style0256">
        <LinearLayout
            android:orientation="vertical"
            android:background="?attr0a59"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ViewStub
                android:id="@id/lists_management_card_stub"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </com.whatsapp.ui.coreui.InfoCard>
    <ViewStub
        android:id="@id/upcoming_events_card"
        android:layout="@layout/layout1101"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <ViewStub
        android:id="@id/media_card_stub"
        android:layout="@layout/layout033e"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <include
        layout="@layout/layout004f" />
    <ViewStub
        android:id="@id/automatic_updates_info_card_stub"
        android:layout="@layout/layout01be"
        android:inflatedId="@id/automatic_updates_info_card"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <include
        layout="@layout/layout03e9" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/participants_card"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <View
            style="@style/style0290" />
        <LinearLayout
            android:orientation="horizontal"
            android:background="?attr0a59"
            android:paddingTop="@dimen/dimen102c"
            android:paddingStart="@dimen/dimen06a4"
            style="@style/style0218">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/dynamic_audiences_count"
                android:paddingTop="@dimen/dimen0cea"
                android:paddingBottom="@dimen/dimen0ce8"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingEnd="@dimen/dimen0ce7"
                style="@style/style021c" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/participants_title"
                android:paddingTop="@dimen/dimen0cea"
                android:paddingBottom="@dimen/dimen0ce8"
                android:layout_width="0.0dip"
                android:layout_weight="1.0"
                style="@style/style021c" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/participants_info"
                android:paddingTop="@dimen/dimen103a"
                style="@style/style0219" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/add_participant_layout"
        android:background="?attr0a59"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:gravity="center_vertical"
            android:id="@id/add_participant_button"
            android:background="@drawable/chat_info_list_selector"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dimen0ccb"
            android:paddingStart="@dimen/dimen06a3"
            android:paddingEnd="@dimen/dimen06a3">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/add_participant_icon"
                android:background="@drawable/primary_light_circle_background"
                app:attr0838="@drawable/ic_person_add_white"
                app:attr090d="?attr0a4b"
                style="@style/style0284" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/add_participant_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str1159"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/add_participant_icon"
                style="@style/style0289" />
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>