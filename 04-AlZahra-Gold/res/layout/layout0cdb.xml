<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="?attr0a59"
    android:paddingLeft="@dimen/dimen0ac6"
    android:paddingRight="@dimen/dimen0ac6"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.wds.components.button.WDSButtonGroup
        android:layout_gravity="center"
        android:id="@id/button_group_view"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24.0dip">
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/request_decline_button"
            android:layout_marginRight="@dimen/dimen0ac6"
            android:text="@string/str2578"
            style="@style/style055d" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/request_pay_button"
            android:text="@string/str25ee"
            style="@style/style0555" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/request_cancel_button"
            android:visibility="gone"
            android:text="@string/str2568"
            style="@style/style055d" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/accept_payment_button"
            android:visibility="gone"
            android:text="@string/str2535"
            style="@style/style055d" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/retry_withdrawal_button"
            android:visibility="gone"
            android:text="@string/str2631"
            style="@style/style055d" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:enabled="true"
            android:id="@id/pause_resume_button"
            android:visibility="gone"
            android:text="@string/str25ed"
            style="@style/style0555" />
    </com.whatsapp.ui.wds.components.button.WDSButtonGroup>
</LinearLayout>