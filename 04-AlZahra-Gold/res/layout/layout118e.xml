<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="?android:selectableItemBackground"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaTextView
        android:layout_gravity="start|center"
        android:id="@id/list_name_text"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:text="@string/str1b86"
        android:layout_marginStart="@dimen/dimen102f"
        app:attr0a24="wds_font_body3"
        style="@style/style05a8" />
    <LinearLayout
        android:id="@id/edit_text_layout"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_gravity="start|center"
            android:id="@id/list_text_frame"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:layout_marginStart="@dimen/dimen102e">
            <com.whatsapp.ui.coreui.WaEditText
                android:textColor="?attr066e"
                android:id="@id/list_text"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:hint="@string/str1b88"
                android:inputType="text"
                android:privateImeOptions="disableSticker=true;disableGifKeyboard=true"
                android:imeOptions="actionDone"
                android:textAlignment="viewStart"
                style="@style/style05a4" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb6"
                android:textColor="?attr0a46"
                android:layout_gravity="end|center"
                android:id="@id/list_text_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen0f5e"
                app:attr0a24="wds_font_body2" />
        </FrameLayout>
        <com.whatsapp.ui.coreui.base.WaImageButton
            android:layout_gravity="center"
            android:id="@id/list_emoji"
            android:layout_width="48.0dip"
            android:layout_height="48.0dip"
            android:contentDescription="@string/str3e44"
            android:layout_marginStart="@dimen/dimen1035"
            android:layout_marginEnd="@dimen/dimen1030"
            app:attr0838="@drawable/ic_insert_emoticon"
            app:attr090d="@color/color033e"
            style="@style/style0006" />
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/list_badge_color_picker_stub"
            android:layout="@layout/layout09c1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/str3ed0"
            android:layout_marginStart="@dimen/dimen1035"
            android:layout_marginEnd="@dimen/dimen102e" />
    </LinearLayout>
    <com.whatsapp.ui.coreui.base.WaTextView
        android:layout_gravity="start|center"
        android:id="@id/below_input_text"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/dimen1039"
        android:text="@string/str1b8a"
        android:layout_marginStart="@dimen/dimen102f"
        app:attr0a24="wds_font_body3"
        style="@style/style05a8" />
</LinearLayout>