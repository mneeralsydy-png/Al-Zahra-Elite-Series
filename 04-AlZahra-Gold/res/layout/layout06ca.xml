<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <ScrollView
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_weight="1.0">
        <com.whatsapp.ui.coreui.WaLinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen054a"
            android:layout_marginRight="@dimen/dimen054a">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:text="@string/str1264"
                style="@style/style0203" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/enc_backup_encryption_key_input_instructional"
                style="@style/style0201" />
            <RelativeLayout
                android:id="@id/enc_key_background"
                android:background="@drawable/enc_backup_enc_key_bg"
                android:layout_marginTop="@dimen/dimen0b62"
                style="@style/style01fd">
                <FrameLayout
                    android:id="@id/encryption_key_input_encryption_key_container"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
            </RelativeLayout>
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:id="@id/enc_backup_encryption_key_input_forgot"
                android:text="@string/str1262"
                style="@style/style0202" />
        </com.whatsapp.ui.coreui.WaLinearLayout>
    </ScrollView>
    <com.whatsapp.ui.wds.components.button.WDSButton
        android:layout_gravity="bottom|center"
        android:id="@id/encryption_key_input_next_button"
        android:text="@string/str1263"
        style="@style/style055c" />
    <com.whatsapp.ui.wds.components.button.WDSButton
        android:layout_gravity="center"
        android:id="@id/encryption_key_input_secondary_button"
        android:visibility="gone"
        android:text="@string/str127a"
        style="@style/style0557" />
</LinearLayout>