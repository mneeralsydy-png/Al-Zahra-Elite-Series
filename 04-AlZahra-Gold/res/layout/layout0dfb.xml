<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:whatsapp="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.qrcode.QrScannerView
        android:id="@id/qr_scanner_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_alignParentBottom="true" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:id="@id/hint"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        style="@style/style0327" />
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_below="@id/hint">
        <View
            android:id="@id/shade"
            android:background="@color/color08a0"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <com.whatsapp.qrcode.QrScannerOverlay
            android:id="@id/overlay"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            whatsapp:attr068d="round_corners" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="bottom|center|left"
            android:id="@id/qr_scan_from_gallery"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10.0dip"
            android:contentDescription="@string/str2d22"
            whatsapp:attr0838="@drawable/ic_filter"
            whatsapp:attr090d="?attr0a2f"
            style="@style/style0006" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="bottom|center|right"
            android:id="@id/qr_scan_flash"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10.0dip"
            whatsapp:attr0838="@drawable/flash_off"
            whatsapp:attr090d="?attr0a2f"
            style="@style/style0006" />
        <ViewStub
            android:layout_gravity="bottom|center"
            android:id="@id/bottom_banner_stub"
            android:layout="@layout/layout0dfc"
            android:inflatedId="@id/bottom_banner"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <ViewStub
            android:layout_gravity="bottom|center"
            android:id="@id/bottom_button_stub"
            android:layout="@layout/layout0dfd"
            android:inflatedId="@id/bottom_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <FrameLayout
            android:padding="@dimen/dimen1034"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <com.whatsapp.ui.coreui.BoundedLinearLayout
                android:layout_gravity="center"
                android:orientation="vertical"
                android:id="@id/education"
                android:background="@drawable/panel"
                android:clipChildren="false"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:maxWidth="350.0dip"
                android:maxHeight="350.0dip"
                whatsapp:attr09b2="?attr0085">
                <com.whatsapp.qrcode.QrEducationView
                    android:layout_gravity="center_horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="0.0dip"
                    android:layout_weight="1.0" />
                <com.whatsapp.ui.wds.components.button.WDSButton
                    android:id="@id/ok"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen1036"
                    android:layout_marginRight="@dimen/dimen1036"
                    android:layout_marginBottom="10.0dip"
                    android:text="@string/str22a9" />
            </com.whatsapp.ui.coreui.BoundedLinearLayout>
        </FrameLayout>
    </FrameLayout>
</RelativeLayout>