<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageButton
            android:layout_gravity="center"
            android:id="@id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12.0dip"
            android:layout_marginRight="12.0dip"
            android:contentDescription="@string/str3d62"
            android:layout_marginStart="12.0dip"
            android:layout_marginEnd="12.0dip"
            app:attr0838="@drawable/ic_arrow_back_white"
            app:attr090d="?attr02a8"
            style="?attr0015" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb0"
            android:textColor="?attr0625"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen102f"
            android:layout_marginBottom="@dimen/dimen102f"
            android:text="@string/str2523"
            app:attr03ae="?attr03b8"
            app:attr0a24="wds_font_body1" />
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/buying_goods_and_services_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen102f">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center_vertical"
            android:padding="5.0dip"
            android:layout_width="40.0dip"
            android:layout_height="40.0dip"
            android:layout_margin="16.0dip"
            android:scaleType="fitXY"
            app:attr0838="@drawable/ic_shopping_cart"
            app:attr090d="#ff128c7e" />
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:ellipsize="end"
                android:id="@id/buying_goods_and_services_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                app:attr0a24="wds_font_body1"
                style="@style/style0289" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb6"
                android:id="@id/buying_goods_and_services_hint_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:attr0a24="wds_font_body2" />
        </LinearLayout>
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center|right"
            android:id="@id/buying_goods_and_services_check"
            android:paddingLeft="16.0dip"
            android:paddingRight="16.0dip"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            app:attr0838="@drawable/ic_check"
            app:attr090d="?attr0a29" />
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/sending_to_friends_and_family_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen102f">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center_vertical"
            android:padding="5.0dip"
            android:layout_width="40.0dip"
            android:layout_height="40.0dip"
            android:layout_margin="16.0dip"
            android:scaleType="fitXY"
            app:attr0838="@drawable/ic_group"
            app:attr090d="#ff128c7e" />
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:ellipsize="end"
                android:id="@id/sending_to_friends_and_family_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                app:attr0a24="wds_font_body1"
                style="@style/style0289" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb6"
                android:id="@id/sending_to_friends_and_family_hint_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:attr0a24="wds_font_body2" />
        </LinearLayout>
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center|right"
            android:id="@id/sending_to_friends_and_family_check"
            android:paddingLeft="16.0dip"
            android:paddingRight="16.0dip"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            app:attr0838="@drawable/ic_check"
            app:attr090d="?attr0a29" />
    </LinearLayout>
</LinearLayout>