<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@id/effect_strength_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.chip.Chip
        android:textAppearance="@style/style002e"
        android:textColor="@color/color006b"
        android:id="@id/strength_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checkable="false"
        app:attr01bb="false"
        app:attr01c3="@color/color006a"
        app:attr01c8="false"
        app:attr01d4="0.0dip"
        app:attr01d6="@color/color0790"
        app:attr01eb="false"
        app:attr0327="false" />
    <com.whatsapp.areffects.button.VerticalSeekBar
        android:id="@id/vertical_seek_bar"
        android:paddingTop="@dimen/dimen00a4"
        android:paddingBottom="@dimen/dimen00a4"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dimen00a3"
        android:progress="50"
        android:progressDrawable="@drawable/ar_effects_slider"
        android:thumb="@drawable/ar_effects_slider_thumb"
        android:layout_centerHorizontal="true"
        android:layoutDirection="ltr"
        android:layout_toEndOf="@id/strength_value"
        android:splitTrack="false" />
</RelativeLayout>