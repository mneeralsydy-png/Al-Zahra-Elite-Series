<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:gravity="center_vertical"
    android:id="@id/psi_handoff_footer"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:background="@color/color08f8"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen0cf3"
        android:layout_alignParentTop="true" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen0cea"
        android:layout_centerInParent="true">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_width="@dimen/dimen0fdd"
            android:layout_height="@dimen/dimen0fdd"
            android:src="@drawable/ic_reply"
            android:tint="@color/color08dd"
            android:layout_marginEnd="@dimen/dimen0cec" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb0"
            android:textColor="@color/color08dd"
            android:ellipsize="end"
            android:id="@id/psi_handoff_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:attr0a24="wds_font_body2_emphasized"
            style="@style/style05a7" />
    </LinearLayout>
</RelativeLayout>