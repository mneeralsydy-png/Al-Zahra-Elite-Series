            android:paddingTop="@dimen/dimen1034"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dimen102e"
            android:paddingEnd="@dimen/dimen102e">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:layout_gravity="center"
                android:paddingBottom="@dimen/dimen0ce8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/wds_illo_ptt_transcripts"
                app:attr0838="@drawable/wds_illo_ptt_transcripts" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:gravity="center"
                android:layout_gravity="center"
                android:paddingBottom="@dimen/dimen0ce8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str3510"
                android:paddingStart="@dimen/dimen102e"
                android:paddingEnd="@dimen/dimen102e"
                app:attr0a24="wds_font_headline1"
                style="@style/style05aa" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/transcription_settings_subheading"
                android:paddingBottom="@dimen/dimen0cee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str3512"
                android:paddingStart="@dimen/dimen102e"
                android:paddingEnd="@dimen/dimen102e"
                app:attr0a24="wds_font_body2"
