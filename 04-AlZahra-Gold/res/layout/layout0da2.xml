                android:paddingBottom="@dimen/dimen0ce7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str3514"
                app:attr0a24="wds_font_body2_emphasized"
                style="@style/style05a7" />
            <RadioGroup
                android:id="@id/transcription_settings_trigger_radio_group"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.radio.RadioButtonWithSubtitle
                    android:id="@id/transcription_settings_trigger_automatic_radio_button"
                    android:paddingTop="@dimen/dimen0cea"
                    android:paddingBottom="@dimen/dimen0cea"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:attr069a="@dimen/dimen103b"
                    app:attr069b="@string/str42d8"
                    app:attr069c="@string/str42d9" />
                <com.whatsapp.ui.coreui.radio.RadioButtonWithSubtitle
                    android:id="@id/transcription_settings_trigger_manual_radio_button"
                    android:paddingTop="@dimen/dimen0cea"
                    android:paddingBottom="@dimen/dimen0cea"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:attr069a="@dimen/dimen103b"
                    app:attr069b="@string/str42da"
                    app:attr069c="@string/str42db" />
                <com.whatsapp.ui.coreui.radio.RadioButtonWithSubtitle
                    android:id="@id/transcription_settings_trigger_none_radio_button"
                    android:paddingTop="@dimen/dimen0cea"
                    android:paddingBottom="@dimen/dimen0cea"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:attr069a="@dimen/dimen103b"
                    app:attr069c="@string/str42dc" />
            </RadioGroup>
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/preferences_voice_message_transcription_choose_language_container"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:paddingTop="@dimen/dimen0cea"
                    android:paddingBottom="@dimen/dimen0ce7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str3511"
                    app:attr0a24="wds_font_body2_emphasized"
                    style="@style/style05a7" />
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/preferences_voice_message_transcription_choose_language_view"
                    android:paddingLeft="56.0dip"
                    android:paddingTop="15.0dip"
                    android:paddingRight="16.0dip"
                    android:paddingBottom="15.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    style="@style/style0363">
