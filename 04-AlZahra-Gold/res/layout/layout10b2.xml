<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@id/rl_text_tip_container"
    android:background="@drawable/bg_rounded"
    android:padding="16.0dip"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="32.0dip"
    android:layout_marginEnd="32.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout
        android:layout_gravity="center"
        android:id="@id/fl_icon_container"
        android:layout_width="20.0dip"
        android:layout_height="20.0dip"
        android:layout_marginRight="10.0dip"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="10.0dip"
        android:layout_alignParentStart="true">
        <ImageView
            android:id="@id/iv_tip_icon"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <ProgressBar
            android:id="@id/pb_text_tip"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:indeterminate="true" />
    </FrameLayout>
    <TextView
        android:textSize="15.0sp"
        android:textColor="?attr0717"
        android:id="@id/tv_tip_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@id/fl_icon_container"
        android:layout_alignParentTop="true"
        android:fontFamily="?attr0716"
        android:layout_toEndOf="@id/fl_icon_container" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="?attr0718"
        android:id="@id/tv_tip_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@id/fl_icon_container"
        android:layout_below="@id/tv_tip_title"
        android:fontFamily="?attr0715"
        android:layout_toEndOf="@id/fl_icon_container" />
</RelativeLayout>