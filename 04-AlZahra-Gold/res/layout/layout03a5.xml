                    android:gravity="center_horizontal"
                    android:layout_gravity="center_horizontal"
                    android:orientation="vertical"
                    android:id="@id/confirm_legal_name_input_container"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
                    <com.whatsapp.ui.coreui.base.WaImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24.0dip"
                        app:attr0838="@drawable/wds_picto_account" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="20.0sp"
                        android:textColor="?attr0625"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@id/confirm_legal_name_title_view"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8.0dip"
                        android:text="@string/str0ca8"
                        app:attr03ae="?attr03b8" />
                    <com.whatsapp.ui.coreui.base.TextEmojiLabel
                        android:textSize="@dimen/dimen0fb0"
                        android:textColor="?attr0a46"
                        android:layout_gravity="center"
                        android:id="@id/confirm_legal_name_desc_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="5.0sp"
                        android:textAlignment="center" />
                    <com.whatsapp.ui.coreui.WaEditText
                        android:id="@id/full_name_edit_view"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen1034"
                        android:hint="@string/str0ca7"
                        android:inputType="textPersonName|textCapWords|textNoSuggestions" />
                </LinearLayout>
            </FrameLayout>
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:id="@id/continue_btn"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16.0dip"
                android:layout_marginTop="@dimen/dimen1034"
                android:layout_marginRight="16.0dip"
                android:layout_marginBottom="16.0dip"
                android:text="@string/str3d8c"
                style="@style/style0555" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>