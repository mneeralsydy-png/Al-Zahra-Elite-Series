<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_horizontal"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_width="@dimen/dimen09d1"
        android:layout_height="@dimen/dimen09d0">
        <ImageView
            android:layout_gravity="center|right"
            android:id="@id/music_shape_background"
            android:layout_width="@dimen/dimen09d0"
            android:layout_height="@dimen/dimen09d0" />
        <ViewStub
            android:gravity="right"
            android:layout_gravity="center|right"
            android:id="@id/music_shape_animated_background"
            android:layout="@layout/layout0b63"
            android:inflatedId="@id/music_shape_animated_background"
            android:layout_width="@dimen/dimen09cf"
            android:layout_height="@dimen/dimen09ce" />
        <ImageView
            android:layout_gravity="center"
            android:id="@id/music_shape_artwork"
            android:layout_width="@dimen/dimen09d0"
            android:layout_height="@dimen/dimen09d0"
            android:scaleType="centerCrop" />
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/music_artwork_error"
            android:layout="@layout/layout0b42"
            android:inflatedId="@id/music_artwork_error"
            android:layout_width="@dimen/dimen09c1"
            android:layout_height="@dimen/dimen09c1" />
    </FrameLayout>
    <TextView
        android:textSize="@dimen/dimen09cc"
        android:textStyle="bold"
        android:textColor="@color/color09a6"
        android:ellipsize="end"
        android:id="@id/music_shape_title"
        android:paddingTop="@dimen/dimen1039"
        android:paddingBottom="@dimen/dimen1030"
        android:layout_width="@dimen/dimen09d0"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:textAlignment="center"
        android:paddingStart="@dimen/dimen1039"
        android:paddingEnd="@dimen/dimen1039"
        android:elevation="2.0dip" />
    <TextView
        android:textSize="@dimen/dimen09cc"
        android:textColor="@color/color09a6"
        android:ellipsize="end"
        android:id="@id/music_shape_artist"
        android:paddingBottom="@dimen/dimen1030"
        android:layout_width="@dimen/dimen09d0"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:textAlignment="center"
        android:paddingStart="@dimen/dimen1039"
        android:paddingEnd="@dimen/dimen1039" />
</LinearLayout>