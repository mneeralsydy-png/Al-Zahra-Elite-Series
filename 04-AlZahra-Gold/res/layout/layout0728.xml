<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:gravity="center"
    android:id="@id/edit_favorites_bottom_sheet"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:layout_weight="1.0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dimen0157">
            <com.whatsapp.ui.coreui.base.WaImageButton
                android:layout_gravity="start|center"
                android:id="@id/bottom_sheet_close_button"
                android:background="?attr076e"
                android:layout_width="@dimen/dimen014a"
                android:layout_height="@dimen/dimen014a"
                android:contentDescription="@string/str3dac"
                android:layout_marginStart="@dimen/dimen0ce7"
                app:attr0838="@drawable/ic_close"
                app:attr090d="@color/color08df" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0158"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/bottom_sheet_title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str1490"
                android:layout_marginStart="@dimen/dimen014a"
                android:layout_marginEnd="@dimen/dimen014a"
                style="@style/style0566" />
            <com.whatsapp.ui.coreui.base.WaImageButton
                android:layout_gravity="end|center"
                android:id="@id/bottom_sheet_done_button"
                android:background="?attr076e"
                android:layout_width="@dimen/dimen014a"
                android:layout_height="@dimen/dimen014a"
                android:contentDescription="@string/str3e2a"
                android:layout_marginStart="@dimen/dimen0ce7"
                app:attr0838="@drawable/ic_check_white"
                app:attr090d="@color/color08df" />
        </FrameLayout>
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:id="@id/favorites_subtitle"
            android:focusable="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen103b"
            android:layout_marginTop="@dimen/dimen102e"
            android:layout_marginRight="@dimen/dimen103b"
            android:text="@string/str148f"
            app:attr0a24="wds_font_body2"
            style="@style/style05a6" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="start"
            android:id="@id/favorites_table_title"
            android:focusable="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen102e"
            android:layout_marginTop="@dimen/dimen1034"
            android:layout_marginRight="@dimen/dimen102e"
            android:text="@string/str1490"
            app:attr0a24="wds_font_body3_emphasized"
            style="@style/style05a9" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/recycler_view"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen1039"
            android:nestedScrollingEnabled="false"
            app:attr0488="androidx.recyclerview.widget.LinearLayoutManager" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:id="@id/favorites_table_description"
            android:focusable="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen1034"
            android:layout_marginTop="@dimen/dimen1039"
            android:layout_marginRight="@dimen/dimen1034"
            android:layout_marginBottom="@dimen/dimen102e"
            android:text="@string/str1496"
            app:attr0a24="wds_font_body3_emphasized"
            style="@style/style05a9" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>