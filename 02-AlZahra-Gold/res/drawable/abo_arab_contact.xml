<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#77000000"
                android:endColor="#77000000"
                android:angle="270.0" />
            <stroke
                android:width="3.0dip"
                android:color="#ffffff00" />
            <corners
                android:radius="15.0dip" />
            <padding
                android:left="10.0dip"
                android:top="4.0dip"
                android:right="10.0dip"
                android:bottom="4.0dip" />
        </shape>
    </item>
    <item
        android:state_focused="true">
        <shape>
            <gradient
                android:startColor="@color/abo_arab_accent"
                android:endColor="@color/abo_arab_accent"
                android:angle="270.0" />
            <stroke
                android:width="5.0dip"
                android:color="@color/abo_arab_accent" />
            <corners
                android:radius="19.0dip" />
            <padding
                android:left="10.0dip"
                android:top="4.0dip"
                android:right="10.0dip"
                android:bottom="4.0dip" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#ffffffff"
                android:endColor="#ffffffff"
                android:angle="0.0" />
            <stroke
                android:width="5.0dip"
                android:color="@color/abo_arab_accent" />
            <corners
                android:radius="19.0dip" />
            <padding
                android:left="10.0dip"
                android:top="4.0dip"
                android:right="10.0dip"
                android:bottom="4.0dip" />
        </shape>
    </item>
</selector>