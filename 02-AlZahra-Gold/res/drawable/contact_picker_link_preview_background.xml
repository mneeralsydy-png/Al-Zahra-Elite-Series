<?xml version="1.0" encoding="utf-8"?>
<ripple
    android:color="?attr0a60"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@android:id/mask"
        android:drawable="?attr0a2f" />
    <item>
        <selector>
            <item
                android:state_activated="true">
                <shape
                    android:shape="rectangle">
                    <solid
                        android:color="?attr0a60" />
                    <corners
                        android:radius="@dimen/dimen0ce7" />
                </shape>
            </item>
            <item
                android:state_pressed="true">
                <shape
                    android:shape="rectangle">
                    <solid
                        android:color="?attr0a60" />
                    <corners
                        android:radius="@dimen/dimen0ce7" />
                </shape>
            </item>
            <item
                android:state_activated="false">
                <shape
                    android:shape="rectangle">
                    <solid
                        android:color="?attr0a3d" />
                    <corners
                        android:radius="@dimen/dimen0ce7" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>