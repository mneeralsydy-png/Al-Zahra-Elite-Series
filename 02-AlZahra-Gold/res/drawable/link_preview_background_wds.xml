<?xml version="1.0" encoding="utf-8"?>
<ripple
    android:color="?attr0a60"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@android:id/mask">
        <shape
            android:shape="rectangle">
            <corners
                android:topLeftRadius="@dimen/dimen0f90"
                android:topRightRadius="@dimen/dimen0f90"
                android:bottomLeftRadius="@dimen/dimen0f95"
                android:bottomRightRadius="@dimen/dimen0f95" />
            <solid
                android:color="?attr0a2f" />
        </shape>
    </item>
    <item>
        <selector>
            <item
                android:state_activated="true">
                <shape
                    android:shape="rectangle">
                    <corners
                        android:topLeftRadius="@dimen/dimen0f90"
                        android:topRightRadius="@dimen/dimen0f90"
                        android:bottomLeftRadius="@dimen/dimen0f95"
                        android:bottomRightRadius="@dimen/dimen0f95" />
                    <solid
                        android:color="?attr0a60" />
                </shape>
            </item>
            <item
                android:state_pressed="true">
                <shape
                    android:shape="rectangle">
                    <corners
                        android:topLeftRadius="@dimen/dimen0f90"
                        android:topRightRadius="@dimen/dimen0f90"
                        android:bottomLeftRadius="@dimen/dimen0f95"
                        android:bottomRightRadius="@dimen/dimen0f95" />
                    <solid
                        android:color="?attr0a60" />
                </shape>
            </item>
            <item
                android:state_activated="false">
                <shape
                    android:shape="rectangle">
                    <corners
                        android:topLeftRadius="@dimen/dimen0f90"
                        android:topRightRadius="@dimen/dimen0f90"
                        android:bottomLeftRadius="@dimen/dimen0f95"
                        android:bottomRightRadius="@dimen/dimen0f95" />
                    <solid
                        android:color="?attr0a3d" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>