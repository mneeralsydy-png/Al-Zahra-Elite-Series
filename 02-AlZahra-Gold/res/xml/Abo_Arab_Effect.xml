<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory
        android:layout="@layout/abu_arab_preference_category"
        android:title="@string/auto_Replay_schdulr">
        <Preference
            android:icon="@drawable/abo_arab_ic_autoreply"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/msg_autoreply_title"
            android:summary="@string/acjauto_R">
            <intent
                android:targetPackage="com.alzahra"
                android:targetClass="com.whatsapp.yo.autoschedreply.Auto_message" />
        </Preference>
        <Preference
            android:icon="@drawable/abo_arab_ic_message_schedule"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/msg_scheduler_title"
            android:summary="@string/acjschdulr_S">
            <intent
                android:targetPackage="com.alzahra"
                android:targetClass="com.whatsapp.yo.autoschedreply.ListMessages" />
        </Preference>
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/abu_arab_preference_category"
        android:title="@string/massmsgr_title">
        <Preference
            android:icon="@drawable/abo_arab_ic_massmsger"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/massmsgr_title"
            android:summary="@string/massmsgr_title_abu_arab">
            <intent
                android:targetPackage="com.alzahra"
                android:targetClass="com.whatsapp.yo.massmsger.SavedCollections" />
        </Preference>
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/abu_arab_preference_category"
        android:title="@string/mas_quickreplies">
        <Preference
            android:icon="@drawable/abo_arab_ic_quick_replies"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/mas_quickreplies"
            android:summary="@string/quickreplies_abu_arab">
            <intent
                android:targetPackage="com.alzahra"
                android:targetClass="abu3arab.quickreply.QuickReplyActivity" />
        </Preference>
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/abu_arab_preference_category"
        android:title="@string/blocked_you_menu">
        <Preference
            android:icon="@drawable/abo_arab_ic_viewonce"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/blocked_you_menu"
            android:summary="@string/blocked_you_menu_abu_arab">
            <intent
                android:targetPackage="com.alzahra"
                android:targetClass="abu3arab.mas.block.BlockListActivity" />
        </Preference>
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/abu_arab_preference_category"
        android:title="@string/mesaj_sifreleme_panel">
        <SwitchPreference
            android:icon="@drawable/abo_arab_ic_privspec"
            android:layout="@layout/abu_arab_preference_layout"
            android:title="@string/mesaj_sifreleme_etkin"
            android:key="mesaj_sifreleme_etkin"
            android:defaultValue="false"
            android:summaryOn="@string/mesaj_sifreleme_etkin_a"
            android:summaryOff="@string/mesaj_sifreleme_etkin_b" />
        <EditTextPreference
            android:icon="@drawable/abo_arab_ic_decrypyy"
            android:layout="@layout/abu_arab_preference_cevron"
            android:title="@string/mesaj_sifreleme_sifredegistir_1"
            android:key="mas_cozumleme_parolasi"
            android:summary="@string/mesaj_sifreleme_sifredegistir_2"
            android:defaultValue="12345"
            android:dialogTitle="@string/mesaj_sifreleme_sifredegistir_1" />
        <com.whatsapp.yo.ColorPref
            android:icon="@drawable/abo_arab_ic_customimg"
            android:layout="@layout/abu_arab_preference_layout"
            android:title="@string/mesaj_sifreleme_panel_arkaplan"
            android:key="SifreArkaplan" />
        <com.whatsapp.yo.ColorPref
            android:icon="@drawable/abo_arab_ic_deslizar"
            android:layout="@layout/abu_arab_preference_layout"
            android:title="@string/mesaj_sifreleme_panel_metin1"
            android:key="MesajSifrelemeBaslikRengi" />
        <com.whatsapp.yo.ColorPref
            android:icon="@drawable/abo_arab_ic_toastext"
            android:layout="@layout/abu_arab_preference_layout"
            android:title="@string/mesaj_sifreleme_panel_metin"
            android:key="MesajSifrelemeMetinRengi" />
        <com.whatsapp.yo.ColorPref
            android:icon="@drawable/abo_arab_ic_viewonce"
            android:layout="@layout/abu_arab_preference_layout"
            android:title="@string/mesaj_sifreleme_panel_goz"
            android:key="ParolaGozRengi" />
    </PreferenceCategory>
</PreferenceScreen>