<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@id/order_details"
    android:background="@color/color0562"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/additional_note_container"
        android:background="?attr0a5a"
        android:paddingLeft="@dimen/dimen0a5d"
        android:paddingTop="@dimen/dimen0a64"
        android:paddingBottom="@dimen/dimen0a64"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12.0dip">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb6"
            android:textColor="?attr0a46"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen1035"
            android:text="@string/str3df5"
            app:attr0a24="wds_font_body2" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb0"
            android:textColor="?attr066e"
            android:id="@id/additional_note"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:attr0a24="wds_font_body1" />
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/payment_details"
        android:background="?attr0a5a"
        android:paddingTop="@dimen/dimen0a64"
        android:paddingBottom="@dimen/dimen0a64"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12.0dip">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center"
            android:id="@id/payment_currency_symbol_icon"
            android:layout_width="@dimen/dimen0a6e"
            android:layout_height="@dimen/dimen0a6c" />
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:textColor="?attr066e"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str2308"
                app:attr0a24="wds_font_body1" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb6"
                android:textColor="?attr0a46"
                android:id="@id/payment_details_status"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen1035"
                app:attr0a24="wds_font_body2" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/payment_support_container"
        android:background="?attr0a5a"
        android:paddingLeft="@dimen/dimen0c93"
        android:paddingTop="@dimen/dimen0c98"
        android:paddingRight="@dimen/dimen0c93"
        android:paddingBottom="@dimen/dimen0c98"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12.0dip">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/payment_support_icon"
            android:layout_width="@dimen/dimen0ac8"
            android:layout_height="@dimen/dimen0ac8"
            android:layout_marginRight="@dimen/dimen0c8a"
            app:attr0838="@drawable/ic_help"
            app:attr090d="?attr0948"
            app:attr0a89="true" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb0"
            android:textColor="?attr0a47"
            android:id="@id/payment_support_title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str34a5"
            app:attr0a24="wds_font_body1" />
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/message_biz"
        android:background="?attr0a5a"
        android:paddingTop="@dimen/dimen0a64"
        android:paddingBottom="@dimen/dimen0a64"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12.0dip">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center"
            android:id="@id/message_biz_icon"
            android:layout_width="@dimen/dimen0a6e"
            android:layout_height="@dimen/dimen0a6c"
            app:attr0838="@drawable/ic_settings_chats"
            app:attr090d="?attr0948" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb0"
            android:textColor="?attr066e"
            android:id="@id/message_biz_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str22f3"
            app:attr0a24="wds_font_body1" />
    </LinearLayout>
</LinearLayout>