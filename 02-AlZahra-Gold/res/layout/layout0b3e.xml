<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@id/row_container"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/contact_selector"
        android:layout_width="@dimen/dimen0362"
        android:layout_height="@dimen/dimen034a"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true">
        <com.whatsapp.ui.coreui.components.button.ThumbnailButton
            android:enabled="false"
            android:layout_gravity="center"
            android:id="@id/contact_photo"
            android:background="@drawable/round_corner_icebreaker_shimmer"
            android:layout_width="@dimen/dimen0334"
            android:layout_height="@dimen/dimen0334"
            android:src="@drawable/avatar_contact"
            android:scaleType="fitCenter"
            android:alpha="0.5"
            app:attr08a9="false"
            app:attr08aa="@dimen/dimen0cc5" />
    </FrameLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingTop="8.0dip"
        android:paddingRight="@dimen/dimen075d"
        android:paddingBottom="8.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/dimen034c"
        android:layout_toRightOf="@id/contact_selector"
        android:layout_centerVertical="true">
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:layout_gravity="left"
            android:id="@id/chat_able_contacts_row_name"
            android:background="@drawable/round_corner_icebreaker_shimmer"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text=""
            style="@style/style0289" />
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:layout_gravity="left"
            android:id="@id/chat_able_contacts_row_status"
            android:background="@drawable/round_corner_icebreaker_shimmer"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text=""
            style="@style/style0285" />
    </LinearLayout>
</RelativeLayout>