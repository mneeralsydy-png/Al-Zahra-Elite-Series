<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@id/status_question_container"
    android:background="@drawable/status_question_shape_background"
    android:layout_width="@dimen/dimen0d30"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        android:textSize="@dimen/dimen0d2f"
        android:textColor="@color/color089a"
        android:ellipsize="end"
        android:id="@id/status_question_prompt"
        android:paddingLeft="@dimen/dimen102e"
        android:paddingTop="@dimen/dimen103b"
        android:paddingRight="@dimen/dimen102e"
        android:paddingBottom="@dimen/dimen102e"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="3"
        android:textAlignment="center" />
    <include
        android:layout_width="@dimen/dimen0d30"
        android:layout_height="wrap_content"
        layout="@layout/layout0ffe" />
</LinearLayout>