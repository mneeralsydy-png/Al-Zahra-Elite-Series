<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.components.button.ThumbnailButton
        android:layout_gravity="center_vertical"
        android:id="@id/thumb"
        android:layout_width="@dimen/dimen0a1a"
        android:layout_height="@dimen/dimen0a1a"
        android:scaleType="centerCrop" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:background="@drawable/sticker_pack_background"
        android:padding="10.0dip"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb6"
            android:textColor="@color/color090b"
            android:ellipsize="end"
            android:id="@id/title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:letterSpacing="0.01"
            app:attr04d0="18.0dip" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fbc"
            android:textColor="@color/color0905"
            android:ellipsize="end"
            android:id="@id/description"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0b60"
            android:maxLines="2"
            android:letterSpacing="0.02"
            app:attr04d0="16.0dip" />
    </LinearLayout>
</LinearLayout>