<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:background="@drawable/mentions_row_selector"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/dimen08bc"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/dimen08bc">
        <com.whatsapp.ui.coreui.components.button.ThumbnailButton
            android:id="@id/contact_photo"
            style="@style/style0197" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dimen08bc"
            android:layout_weight="1.0">
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:id="@id/primary_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                style="@style/style0285" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textAppearance="@style/style03eb"
                android:ellipsize="end"
                android:id="@id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1" />
        </LinearLayout>
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/action_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str0199"
            android:layout_marginEnd="@dimen/dimen075d"
            app:attr096b="outline"
            app:attr09ea="small" />
    </LinearLayout>
    <ViewStub
        android:layout_gravity="bottom"
        android:id="@id/separator_stub"
        android:layout="@layout/layout0a9f"
        android:layout_width="fill_parent"
        android:layout_height="1.0dip" />
</FrameLayout>