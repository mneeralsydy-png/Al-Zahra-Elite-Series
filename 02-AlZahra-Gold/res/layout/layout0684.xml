<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaTextView
        android:id="@id/section_title_separator"
        android:background="@color/color039e"
        android:layout_width="fill_parent"
        android:layout_height="1.0dip"
        android:layout_marginTop="@dimen/dimen103a"
        android:layout_marginBottom="@dimen/dimen102e"
        app:attr0a24="wds_font_body2" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:textColor="@color/color0948"
        android:id="@id/title"
        android:focusable="false"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen102e"
        android:textAlignment="viewStart"
        android:layout_marginStart="@dimen/dimen103b"
        android:layout_marginEnd="@dimen/dimen103b"
        app:attr0a24="wds_font_body2_emphasized"
        style="@style/style05a7" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:textColor="@color/color08de"
        android:gravity="center"
        android:id="@id/lists_home_bottom_description"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen102e"
        android:layout_marginBottom="@dimen/dimen102e"
        android:textAlignment="center"
        android:layout_marginStart="@dimen/dimen1034"
        android:layout_marginEnd="@dimen/dimen1034"
        app:attr0a24="wds_font_body3"
        style="@style/style05a8" />
</LinearLayout>