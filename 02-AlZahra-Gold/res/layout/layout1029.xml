<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@id/container"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/dimen0450"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:whatsapp="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/contact_selector"
        android:paddingLeft="@dimen/dimen0d1c"
        android:layout_width="@dimen/dimen0d05"
        android:layout_height="@dimen/dimen0450"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true">
        <com.whatsapp.status.api.ContactStatusThumbnail
            android:layout_gravity="center|left"
            android:id="@id/contact_photo"
            android:padding="2.5dip"
            android:layout_width="@dimen/dimen0d67"
            android:layout_height="@dimen/dimen0d67"
            android:scaleType="centerCrop"
            whatsapp:attr0298="?attr0a4f"
            whatsapp:attr0299="@color/color0713"
            whatsapp:attr029a="@color/color0718"
            whatsapp:attr08a7="2.5dip"
            whatsapp:attr08a9="false"
            whatsapp:attr08aa="@dimen/dimen0cc5" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="end|bottom|center"
            android:id="@id/contact_mark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen0d04"
            android:scaleType="center"
            android:layout_marginEnd="@dimen/dimen0d1c" />
    </FrameLayout>
    <ViewStub
        android:id="@id/mute_indicator"
        android:paddingRight="@dimen/dimen102e"
        android:layout="@layout/layout099b"
        android:inflatedId="@id/mute_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/contact_selector"
        android:layout_alignBottom="@id/contact_selector"
        android:layout_alignParentRight="true" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@id/contact_text_container"
        android:paddingRight="@dimen/dimen0747"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@id/mute_indicator"
        android:layout_toRightOf="@id/contact_selector"
        android:layout_centerVertical="true">
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:ellipsize="end"
            android:id="@id/contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen0d19"
            android:maxLines="1"
            style="?attr08d4" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:ellipsize="end"
            android:id="@id/date_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            style="?attr04e0" />
    </LinearLayout>
</RelativeLayout>