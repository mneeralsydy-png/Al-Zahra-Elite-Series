<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/br_bottom_sheet_pix_input_fields_container"
        android:paddingLeft="@dimen/dimen102e"
        android:paddingRight="@dimen/dimen102e"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageButton
            android:layout_gravity="start"
            android:id="@id/close_button"
            android:background="@null"
            android:padding="@dimen/dimen0ce8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/str3dac"
            app:attr0838="@drawable/ic_close" />
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center"
            android:id="@id/br_bottom_sheet_add_pix_logo"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen064c"
            app:attr0838="@drawable/pix_logo_blue_background" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fc0"
            android:textStyle="bold"
            android:textColor="?attr066e"
            android:id="@id/br_bottom_sheet_add_pix_title_text_view"
            android:text="@string/str06f8"
            style="@style/style02df" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb6"
            android:textColor="?attr0a46"
            android:id="@id/br_bottom_sheet_add_pix_description_text_view"
            android:text="@string/str06f4"
            app:attr0a24="wds_font_body2"
            style="@style/style02df" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fbc"
            android:textColor="?attr0a46"
            android:id="@id/br_bottom_sheet_pix_key_type_spinner_text_view"
            android:text="@string/str3d82"
            android:layout_marginStart="@dimen/dimen0b60"
            app:attr0a24="wds_font_body3"
            style="@style/style02de" />
        <Spinner
            android:id="@id/br_bottom_sheet_pix_key_type_spinner"
            android:paddingTop="0.0dip"
            android:paddingBottom="0.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0.0dip"
            style="@style/style0609" />
        <com.google.android.material.textfield.TextInputLayout
            android:id="@id/br_bottom_sheet_pix_key_value_input_layout"
            app:attr0335="@style/style03f0"
            app:attr0401="true"
            style="@style/style02de">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.WaEditText
                    android:enabled="false"
                    android:id="@id/br_bottom_sheet_pix_key_phone_prefix"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:inputType="text"
                    style="@style/style011e" />
                <com.whatsapp.ui.coreui.WaEditText
                    android:id="@id/br_bottom_sheet_pix_key_value_edit_text"
                    android:hint="@string/str070c"
                    android:inputType="text"
                    style="@style/style011e" />
            </LinearLayout>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@id/br_bottom_sheet_pix_name_input_layout"
            app:attr0335="@style/style03f0"
            app:attr03f2="@string/str3d83"
            app:attr0401="true"
            style="@style/style02de">
            <com.whatsapp.ui.coreui.WaEditText
                android:id="@id/br_bottom_sheet_pix_name_edit_text"
                android:hint="@string/str070d"
                android:maxLength="56"
                style="@style/style011e" />
        </com.google.android.material.textfield.TextInputLayout>
        <com.whatsapp.ui.coreui.WaButtonWithLoader
            android:textColor="?attr0a2f"
            android:id="@id/br_bottom_sheet_add_pix_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen064c"
            android:text="@string/str3d81" />
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:textSize="11.0sp"
            android:textColor="?attr0a46"
            android:id="@id/br_bottom_sheet_add_pix_disclaimer_text_view"
            android:text="@string/str06f6"
            style="@style/style02df" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="11.0sp"
            android:textColor="?attr0a49"
            android:id="@id/learn_more_text"
            android:layout_marginTop="0.0dip"
            android:text="@string/str3ec9"
            style="@style/style02df" />
    </LinearLayout>
</ScrollView>