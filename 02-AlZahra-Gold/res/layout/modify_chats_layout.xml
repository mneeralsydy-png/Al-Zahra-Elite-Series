<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <EditText
        android:gravity="center_horizontal"
        android:id="@id/mMessageEditText"
        android:padding="8.0dip"
        android:layout_width="fill_parent"
        android:layout_height="150.0dip"
        android:layout_marginTop="10.0dip"
        android:hint="@string/message"
        android:inputType="textMultiLine"
        android:textAlignment="center"
        android:layout_marginStart="10.0dip"
        android:layout_marginEnd="10.0dip" />
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="10.0dip"
        android:weightSum="2.0">
        <Button
            android:id="@id/mChangeTimeBtn"
            android:background="@drawable/custom_rounded_btn"
            android:padding="10.0dip"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginRight="10.0dip"
            android:text="@string/btnTime"
            android:drawableLeft="@drawable/ic_time"
            android:layout_weight="1.0"
            android:drawableStart="@drawable/ic_time"
            android:layout_marginEnd="10.0dip"
            style="buttonBarButtonStyle" />
        <Button
            android:id="@id/mChangeDateBtn"
            android:background="@drawable/custom_rounded_btn"
            android:padding="10.0dip"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10.0dip"
            android:text="@string/view_messages_date_color"
            android:drawableLeft="@drawable/ic_date"
            android:layout_weight="1.0"
            android:drawableStart="@drawable/ic_date"
            android:layout_marginStart="10.0dip"
            style="buttonBarButtonStyle" />
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/message_bomber_shape"
        android:padding="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10.0dip">
        <CheckBox
            android:id="@id/mMarkAsSeen"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6.0dip"
            android:text="@string/showdouble"
            android:layout_marginStart="6.0dip" />
        <CheckBox
            android:id="@id/mMarkAsUnseen"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6.0dip"
            android:text="@string/hideblue"
            android:layout_marginStart="6.0dip" />
        <CheckBox
            android:id="@id/mMarkAsRevokedV1"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6.0dip"
            android:text="@string/markasrevoked_1"
            android:layout_marginStart="6.0dip" />
        <CheckBox
            android:id="@id/mMarkAsRevokedV2"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6.0dip"
            android:text="@string/markasrevoked_2"
            android:layout_marginStart="6.0dip" />
        <CheckBox
            android:id="@id/mUndoMarkAsRevokedV2"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6.0dip"
            android:text="@string/undomarkasrevoked_3"
            android:layout_marginStart="6.0dip" />
    </LinearLayout>
</LinearLayout>