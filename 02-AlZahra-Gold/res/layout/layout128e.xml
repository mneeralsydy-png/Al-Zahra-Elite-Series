<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dimen0cea"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center|left"
        android:id="@id/icon"
        android:layout_width="@dimen/dimen0755"
        android:layout_height="@dimen/dimen0755"
        android:layout_marginLeft="@dimen/dimen0ce7"
        android:layout_marginRight="@dimen/dimen0cea"
        android:scaleType="center"
        android:layout_marginStart="@dimen/dimen0ce7"
        android:layout_marginEnd="@dimen/dimen0cea"
        app:attr090d="?attr0a47" />
    <LinearLayout
        android:gravity="left"
        android:layout_gravity="center|left"
        android:orientation="vertical"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/dimen0cea"
        android:layout_weight="1.0">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textStyle="bold"
            android:textColor="?attr066e"
            android:ellipsize="end"
            android:layout_gravity="start"
            android:id="@id/primary_text"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAlignment="viewStart"
            app:attr0a24="wds_font_body1"
            style="@style/style05a4" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="?attr0a46"
            android:ellipsize="end"
            android:layout_gravity="start"
            android:id="@id/secondary_text"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:textAlignment="viewStart"
            app:attr0a24="wds_font_body2"
            style="@style/style05a6" />
    </LinearLayout>
    <com.whatsapp.ui.coreui.checkbox.RtlCheckBox
        android:theme="@style/style032a"
        android:layout_gravity="center_vertical"
        android:id="@id/checkbox"
        android:background="@null"
        android:focusable="false"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/dimen0ce7"
        style="@style/style0329" />
</LinearLayout>