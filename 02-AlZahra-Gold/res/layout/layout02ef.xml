<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@android:id/content"
    android:background="@null"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.whatsapp.calling.ui.callhistory.view.CallsHistoryRecyclerView
        android:id="@id/calls_recyclerView"
        android:scrollbars="vertical"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        style="@style/style0245" />
    <FrameLayout
        android:id="@android:id/empty"
        android:paddingBottom="@dimen/dimen0544"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <ViewStub
            android:gravity="center"
            android:id="@id/welcome_calls_layout_stub"
            android:layout="@layout/layout0305"
            android:inflatedId="@id/welcome_calls_layout"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <ViewStub
            android:gravity="center"
            android:id="@id/search_no_matches_text_stub"
            android:layout="@layout/layout02fe"
            android:inflatedId="@id/search_no_matches"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <ViewStub
            android:gravity="center"
            android:id="@id/search_no_matches_frame_stub"
            android:layout="@layout/layout0ed9"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <ViewStub
            android:id="@id/calls_empty_no_contacts_stub"
            android:layout="@layout/layout02eb"
            android:inflatedId="@id/calls_empty_no_contacts"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/calls_empty_no_contacts_stub_v2"
            android:layout="@layout/layout02ff"
            android:inflatedId="@id/calls_tab_invite_friend_view"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/contacts_empty_permission_denied_stub"
            android:visibility="gone"
            android:layout="@layout/layout06b0"
            android:inflatedId="@id/contacts_empty_permission_denied"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/contacts_empty_permission_denied_stub_v2"
            android:layout="@layout/layout06b1"
            android:inflatedId="@id/contacts_empty_permission_denied_v2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/calls_progress_bar_stub"
            android:layout="@layout/layout02f3"
            android:inflatedId="@id/calls_progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </FrameLayout>
    <ViewStub
        android:layout_gravity="center"
        android:id="@id/no_search_results_e2ee_footer"
        android:layout="@layout/layout0677"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
</LinearLayout>