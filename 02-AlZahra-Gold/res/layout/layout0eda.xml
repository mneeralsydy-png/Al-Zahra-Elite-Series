<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@id/row_container"
    android:background="?attr076d"
    android:paddingTop="14.0dip"
    android:paddingBottom="14.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:whatsapp="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.wds.components.profilephoto.WDSProfilePhoto
        android:id="@id/photo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16.0dip"
        android:scaleType="fitCenter"
        android:layout_centerVertical="true"
        whatsapp:attr0675="medium" />
    <com.whatsapp.ui.wds.components.button.WDSButton
        android:id="@id/action_btn"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/str1aab"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        whatsapp:attr0009="normal"
        whatsapp:attr096b="borderless"
        whatsapp:attr09ea="normal" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@id/action_btn"
        android:layout_toRightOf="@id/photo"
        android:layout_centerVertical="true"
        android:layout_marginStart="16.0dip"
        android:layout_marginEnd="16.0dip">
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:id="@id/name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/style0289" />
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:textStyle="normal"
            android:ellipsize="end"
            android:gravity="left"
            android:layout_gravity="left"
            android:id="@id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:singleLine="true"
            style="@style/style0285" />
    </LinearLayout>
</RelativeLayout>