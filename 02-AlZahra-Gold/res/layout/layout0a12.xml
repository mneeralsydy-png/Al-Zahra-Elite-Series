<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/dimen0cc9"
        android:paddingRight="@dimen/dimen075d"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen0ccb">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/avatar"
            android:layout_width="@dimen/dimen0cca"
            android:layout_height="@dimen/dimen0cca"
            android:layout_marginRight="@dimen/dimen0cc9"
            android:scaleType="fitCenter"
            android:contentDescription="@string/str3dcf"
            app:attr0838="@drawable/avatar_contact" />
        <LinearLayout
            android:orientation="vertical"
            android:clipChildren="false"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <LinearLayout
                android:orientation="horizontal"
                android:clipChildren="false"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.TextEmojiLabel
                    android:layout_gravity="left"
                    android:id="@id/name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/style0289" />
                <com.whatsapp.ui.coreui.base.TextEmojiLabel
                    android:textAppearance="@style/style03eb"
                    android:ellipsize="none"
                    android:gravity="end"
                    android:layout_gravity="center|right"
                    android:id="@id/push_name"
                    android:paddingLeft="5.0dip"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:layout_weight="1.0" />
            </LinearLayout>
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:layout_gravity="left"
                android:id="@id/status"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                style="@style/style0285" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>