<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <FrameLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dimen075f">
            <com.whatsapp.ui.coreui.base.WaImageButton
                android:layout_gravity="start|center"
                android:id="@id/bottom_sheet_close_button"
                android:background="?attr076e"
                android:layout_width="@dimen/dimen075e"
                android:layout_height="@dimen/dimen075e"
                android:contentDescription="@string/str3dac"
                android:layout_marginStart="@dimen/dimen0ce7"
                app:attr0838="@drawable/ic_close"
                app:attr090d="@color/color08df" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0760"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/bottom_sheet_title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str1177"
                android:layout_marginStart="@dimen/dimen075e"
                android:layout_marginEnd="@dimen/dimen075e"
                style="@style/style0566" />
            <com.whatsapp.ui.coreui.base.WaImageButton
                android:layout_gravity="end|center"
                android:id="@id/bottom_sheet_done_button"
                android:background="?attr076e"
                android:layout_width="@dimen/dimen075e"
                android:layout_height="@dimen/dimen075e"
                android:contentDescription="@string/str3e2a"
                android:layout_marginStart="@dimen/dimen0ce7"
                app:attr0838="@drawable/ic_check_white"
                app:attr090d="@color/color08df" />
        </FrameLayout>
        <androidx.fragment.app.FragmentContainerView
            android:id="@id/fragment_container"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>