<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:orientation="vertical"
    android:background="@color/yosettings_background"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:title="settings_general"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <include
            layout="@layout/yo_toolbar" />
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_marginLeft="16.0dip"
                android:layout_marginTop="@dimen/settings_divider_text_margin_top"
                android:layout_marginRight="16.0dip">
                <include
                    layout="@layout/Abo_Arab_Alert" />
            </LinearLayout>
            <com.whatsapp.youbasha.ui.YoNoScrollListView
                android:id="@android:id/list"
                android:paddingLeft="@dimen/info_screen_padding"
                android:paddingRight="@dimen/info_screen_padding"
                android:paddingBottom="@dimen/info_screen_padding"
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:divider="@drawable/divider_gray"
                android:layout_weight="1.0"
                android:paddingStart="@dimen/info_screen_padding"
                android:paddingEnd="@dimen/info_screen_padding" />
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15.0dip"
                android:layout_marginTop="15.0dip"
                android:layout_marginRight="15.0dip"
                android:layout_marginBottom="15.0dip">
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="0.0dip"
                    android:layout_height="2.0dip"
                    android:src="@color/abo_arab_accent"
                    android:layout_weight="1.0" />
                <com.whatsapp.yo.tf
                    android:textSize="18.0sp"
                    android:textStyle="bold"
                    android:textColor="@color/abo_arab_accent"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5.0dip"
                    android:layout_marginRight="5.0dip"
                    android:text="@string/settings_security" />
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="0.0dip"
                    android:layout_height="2.0dip"
                    android:src="@color/abo_arab_accent"
                    android:layout_weight="1.0" />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:padding="@dimen/info_screen_padding"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="6.0dip"
                    android:layout_width="42.0dip"
                    android:layout_height="42.0dip"
                    android:src="@drawable/abo_arab_ic_lock"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <LinearLayout
                    android:layout_gravity="start"
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_margin="3.0dip"
                    android:layout_weight="1.0">
                    <Switch
                        android:textSize="16.0sp"
                        android:textColor="@color/primary_text"
                        android:id="@id/checkbox"
                        android:tag="applockV2"
                        android:paddingLeft="@dimen/settings_row_horizontal_padding"
                        android:paddingTop="@dimen/info_screen_padding"
                        android:paddingRight="@dimen/settings_row_horizontal_padding"
                        android:paddingBottom="@dimen/info_screen_card_spacing"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/Lock"
                        android:paddingStart="@dimen/settings_row_horizontal_padding"
                        android:paddingEnd="@dimen/settings_row_horizontal_padding" />
                    <RadioGroup
                        android:id="@id/checkbox_area"
                        android:tag="lock_typeV2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/settings_list_padding_top">
                        <com.whatsapp.yo.radiobtn
                            android:id="@id/action_btn_1"
                            android:tag="Fingerprint"
                            android:padding="@dimen/list_row_padding"
                            android:duplicateParentState="true"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:text="@string/locktype_fingerprint"
                            android:layout_marginStart="@dimen/settings_icon_margin_end" />
                        <com.whatsapp.yo.radiobtn
                            android:id="@id/action_btn_2"
                            android:tag="Pattern"
                            android:padding="@dimen/list_row_padding"
                            android:duplicateParentState="true"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:text="@string/locktype_pattern"
                            android:layout_marginStart="@dimen/settings_icon_margin_end" />
                        <com.whatsapp.yo.radiobtn
                            android:id="@id/action_btn_3"
                            android:tag="PIN"
                            android:padding="@dimen/list_row_padding"
                            android:duplicateParentState="true"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:text="@string/locktype_pin"
                            android:layout_marginStart="@dimen/settings_icon_margin_end" />
                    </RadioGroup>
                </LinearLayout>
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/modPassword"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="6.0dip"
                    android:layout_width="42.0dip"
                    android:layout_height="42.0dip"
                    android:src="@drawable/abo_arab_ic_decrypy"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <LinearLayout
                    android:layout_gravity="start"
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_margin="3.0dip"
                    android:layout_weight="1.0">
                    <com.whatsapp.yo.tf
                        android:text="@string/ChangeP"
                        style="@style/YoSettings_row" />
                    <com.whatsapp.yo.tf
                        android:text="@string/ChangePS"
                        android:singleLine="false"
                        style="@style/YoSettings_row_subtitle" />
                </LinearLayout>
                <ImageView
                    android:layout_gravity="end|center"
                    android:paddingLeft="@dimen/info_screen_padding"
                    android:paddingRight="@dimen/info_screen_padding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/abu_arab_chevron_right"
                    android:tint="@color/conversations_text_gray"
                    android:paddingStart="@dimen/info_screen_padding"
                    android:paddingEnd="@dimen/info_screen_padding" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/patternView"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="6.0dip"
                    android:layout_width="42.0dip"
                    android:layout_height="42.0dip"
                    android:src="@drawable/abo_arab_ic_grid"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <com.whatsapp.yo.tf
                    android:text="@string/ChangePt"
                    style="@style/YoSettings_row_more" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/recoveryQ"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="6.0dip"
                    android:layout_width="42.0dip"
                    android:layout_height="42.0dip"
                    android:src="@drawable/abo_arab_fingerprintoff"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <com.whatsapp.yo.tf
                    android:text="@string/yoRecoveryQ"
                    style="@style/YoSettings_row_more" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/set_wallpaper_button"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="6.0dip"
                    android:layout_width="42.0dip"
                    android:layout_height="42.0dip"
                    android:src="@drawable/abo_arab_ic_customimg"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <com.whatsapp.yo.tf
                    android:text="@string/changeLPW"
                    style="@style/YoSettings_row_more" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/info_screen_padding"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="6.0dip"
                    android:layout_width="42.0dip"
                    android:layout_height="42.0dip"
                    android:src="@drawable/abo_arab_ic_cust"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <Switch
                    android:textSize="16.0sp"
                    android:textColor="@color/primary_text"
                    android:id="@id/button1"
                    android:tag="pattern_invisible"
                    android:padding="@dimen/info_screen_padding"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pat_invisible" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/info_screen_padding"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="6.0dip"
                    android:layout_width="42.0dip"
                    android:layout_height="42.0dip"
                    android:src="@drawable/abo_arab_ic_profileball"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <Switch
                    android:textSize="16.0sp"
                    android:textColor="@color/primary_text"
                    android:id="@id/button2"
                    android:tag="pattern_novibration"
                    android:padding="@dimen/info_screen_padding"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pat_disableVibration" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:onClick="priv_reset">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="6.0dip"
                    android:layout_width="42.0dip"
                    android:layout_height="42.0dip"
                    android:src="@drawable/ic_action_refresh"
                    android:scaleType="fitCenter"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <LinearLayout
                    android:layout_gravity="start"
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_margin="3.0dip"
                    android:layout_weight="1.0">
                    <com.whatsapp.yo.tf
                        android:text="@string/resetPriv"
                        style="@style/YoSettings_row" />
                    <com.whatsapp.yo.tf
                        android:text="@string/resetPrivSum"
                        android:singleLine="false"
                        style="@style/YoSettings_row_subtitle" />
                </LinearLayout>
                <ImageView
                    android:layout_gravity="end|center"
                    android:paddingLeft="@dimen/info_screen_padding"
                    android:paddingRight="@dimen/info_screen_padding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/abu_arab_chevron_right"
                    android:tint="@color/conversations_text_gray"
                    android:paddingStart="@dimen/info_screen_padding"
                    android:paddingEnd="@dimen/info_screen_padding" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>