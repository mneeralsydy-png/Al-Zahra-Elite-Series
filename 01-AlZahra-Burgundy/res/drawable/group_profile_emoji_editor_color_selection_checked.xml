<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@id/padding">
        <shape
            android:shape="oval">
            <solid
                android:color="@color/color0790" />
            <padding
                android:left="@dimen/dimen0623"
                android:right="@dimen/dimen0623" />
        </shape>
    </item>
    <item
        android:id="@id/color_selection_ring">
        <shape
            android:shape="oval">
            <size
                android:height="41.5dip"
                android:width="41.5dip" />
            <stroke
                android:width="1.5dip"
                android:color="?attr0a2f" />
            <solid
                android:color="@color/color0790" />
        </shape>
    </item>
    <item
        android:id="@id/color_selection_circle"
        android:left="3.5dip"
        android:top="3.5dip"
        android:right="3.5dip"
        android:bottom="3.5dip">
        <shape
            android:shape="oval">
            <solid
                android:color="?attr0a2f" />
        </shape>
    </item>
</layer-list>