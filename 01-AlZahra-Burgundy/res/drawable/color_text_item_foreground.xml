<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_selected="true">
        <layer-list>
            <item>
                <shape
                    android:shape="oval">
                    <stroke
                        android:width="2.0dip"
                        android:color="@color/color09a6" />
                </shape>
            </item>
            <item
                android:left="12.0dip"
                android:top="12.0dip"
                android:right="12.0dip"
                android:bottom="12.0dip">
                <bitmap
                    android:src="@drawable/ic_check"
                    android:tint="@color/color09a6" />
            </item>
        </layer-list>
    </item>
    <item
        android:state_pressed="true">
        <shape
            android:shape="oval">
            <stroke
                android:width="2.0dip"
                android:color="@color/color09a6" />
        </shape>
    </item>
    <item>
        <shape
            android:shape="oval">
            <stroke
                android:width="0.5dip"
                android:color="@color/color09ac" />
        </shape>
    </item>
</selector>