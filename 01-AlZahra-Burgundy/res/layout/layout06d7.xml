            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:layout_gravity="center_vertical"
                android:id="@id/event_info_date"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:attr0a24="wds_font_body1"
                style="@style/style05a4" />
            <ViewStub
                android:id="@id/event_add_to_calendar"
                android:layout="@layout/layout06d6"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
    <ViewStub
        android:id="@id/event_info_location_container"
        android:layout="@layout/layout06f8"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen0cee"
        android:layout_marginStart="@dimen/dimen0cea"
        android:layout_marginEnd="@dimen/dimen0cea" />
    <ViewStub
        android:id="@id/event_info_call_container"
        android:layout="@layout/layout06f0"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen0cee"
        android:layout_marginStart="@dimen/dimen0cea"
        android:layout_marginEnd="@dimen/dimen0cea" />
    <ViewStub
        android:id="@id/event_info_reminder_container"
        android:layout="@layout/layout06f9"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen0cee"
        android:layout_marginStart="@dimen/dimen0cea"
        android:layout_marginEnd="@dimen/dimen0cea" />
    <View
        android:layout_marginTop="@dimen/dimen0ceb"
