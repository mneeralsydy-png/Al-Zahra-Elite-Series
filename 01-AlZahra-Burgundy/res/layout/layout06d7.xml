<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen0ceb"
        android:layout_marginStart="@dimen/dimen0cea"
        android:layout_marginEnd="@dimen/dimen0cea">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="top"
            android:id="@id/event_info_date_icon"
            android:layout_width="@dimen/dimen0fdb"
            android:layout_height="@dimen/dimen0fdb"
            android:layout_marginTop="@dimen/dimen0cf0"
            android:layout_marginEnd="@dimen/dimen0cea"
            app:attr0838="@drawable/vec_ic_calendar_month"
            app:attr090d="@color/color0347" />
        <LinearLayout
