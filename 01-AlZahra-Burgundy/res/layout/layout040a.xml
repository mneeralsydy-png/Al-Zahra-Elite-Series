<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:layout_gravity="top"
    android:id="@id/selected_list"
    android:layout_width="fill_parent"
    android:layout_height="@dimen/dimen0c62"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ScrollView
        android:id="@id/empty_state_description_scroll_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/empty_list_description"
            android:padding="@dimen/dimen0cea"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            app:attr0a24="wds_font_body2" />
    </ScrollView>
    <androidx.recyclerview.widget.RecyclerView
        android:layout_gravity="top"
        android:id="@id/selected_items"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_alignParentTop="true"
        android:nestedScrollingEnabled="false" />
    <View
        android:layout_gravity="center"
        android:id="@id/selected_items_divider"
        android:background="@drawable/divider_gray"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen0347"
        android:layout_alignParentBottom="true" />
    <com.whatsapp.ui.coreui.base.WaImageButton
        android:id="@id/selected_list_action_fab_1"
        android:background="@drawable/selected_contacts_action_fab_background"
        android:visibility="gone"
        android:layout_width="@dimen/dimen0c64"
        android:layout_height="@dimen/dimen0c64"
        android:layout_marginTop="@dimen/dimen0c68"
        android:layout_alignTop="@id/selected_items"
        android:layout_alignParentRight="true"
        android:contentDescription="@string/str2157"
        android:elevation="@dimen/dimen0c63"
        app:attr0838="@drawable/ic_fab_next" />
</RelativeLayout>