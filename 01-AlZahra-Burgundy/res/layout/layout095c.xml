        android:tint="?attr0a47"
        android:layout_marginEnd="@dimen/dimen1039"
        android:tintMode="src_atop" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:ellipsize="none"
        android:id="@id/recommendation_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="2"
        style="@style/style05a6" />
</LinearLayout>