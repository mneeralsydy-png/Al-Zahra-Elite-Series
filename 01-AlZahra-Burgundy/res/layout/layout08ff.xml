<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:id="@id/india_upi_coupon_row"
    android:background="@drawable/india_upi_savings_offer_background"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/dimen0b5d"
    android:layout_marginTop="@dimen/dimen0b62"
    android:layout_marginRight="@dimen/dimen0b5d"
    android:layout_marginBottom="@dimen/dimen0b62"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RadioButton
        android:layout_gravity="center_vertical"
        android:id="@id/india_upi_savings_offer_radio_button"
        android:clickable="false"
        android:layout_width="@dimen/dimen0fdc"
        android:layout_height="@dimen/dimen0fdc" />
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen0b62"
        android:layout_marginRight="@dimen/dimen0b62">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="@style/style05a4"
            android:textColor="?attr066e"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@id/india_upi_savings_offer_row_code"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen0b60"
            android:layout_marginTop="@dimen/dimen0b60"
            android:layout_marginRight="@dimen/dimen0b60"
            android:layout_marginBottom="@dimen/dimen0b5f"
            android:maxLines="1"
            app:attr0a24="wds_font_body1" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="@style/style05a6"
            android:textColor="?attr0a46"
            android:ellipsize="end"
            android:id="@id/india_upi_savings_offer_row_description"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen0b60"
            android:layout_marginTop="@dimen/dimen0b5f"
            android:layout_marginRight="@dimen/dimen0b60"
            android:layout_marginBottom="@dimen/dimen0b60"
            android:maxLines="3"
            app:attr0a24="wds_font_body2" />
    </LinearLayout>
</LinearLayout>