<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/wa_switch_view_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginRight="30.0dip"
            android:layout_weight="1.0">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/switch_view_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:attr0a24="wds_font_body2" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/switch_view_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="false"
                style="@style/style0288" />
        </LinearLayout>
        <com.whatsapp.ui.wds.components.toggle.WDSSwitch
            android:id="@id/switch_view_toggle"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
</merge>