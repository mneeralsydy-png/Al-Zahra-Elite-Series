<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:orientation="vertical"
    android:background="@color/yosettings_background"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <include
            layout="@layout/yo_toolbar" />
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10.0dip"
                android:layout_marginTop="15.0dip"
                android:layout_marginRight="10.0dip"
                android:layout_marginBottom="15.0dip">
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="0.0dip"
                    android:layout_height="2.0dip"
                    android:src="@color/abo_arab_accent"
                    android:layout_weight="1.0" />
                <com.whatsapp.yo.tf
                    android:textSize="18.0sp"
                    android:textStyle="bold"
                    android:textColor="@color/abo_arab_accent"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5.0dip"
                    android:layout_marginRight="5.0dip"
                    android:text="@string/yo_About" />
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="0.0dip"
                    android:layout_height="2.0dip"
                    android:src="@color/abo_arab_accent"
                    android:layout_weight="1.0" />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:onClick="openWebsite">
                <ImageView
                    android:padding="8.0dip"
                    android:layout_width="50.0dip"
                    android:layout_height="50.0dip"
                    android:src="@drawable/abo_arab_yoheart_circle"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="12.0dip"
                    android:layout_marginEnd="6.0dip" />
                <com.whatsapp.yo.tf
                    android:paddingRight="0.0dip"
                    android:text="@string/about_me"
                    android:drawablePadding="@dimen/settings_row_horizontal_padding"
                    android:paddingEnd="0.0dip"
                    style="@style/YoSettings_row" />
            </LinearLayout>
            <View
                android:layout_marginStart="@dimen/settings_divider_horizontal_margin_left"
                android:layout_marginEnd="@dimen/settings_radio_button_text_padding_left"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:onClick="openWebsite">
                <ImageView
                    android:padding="8.0dip"
                    android:layout_width="50.0dip"
                    android:layout_height="50.0dip"
                    android:src="@drawable/abo_arab_ic_yoweb"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="12.0dip"
                    android:layout_marginEnd="6.0dip" />
                <com.whatsapp.yo.tf
                    android:paddingRight="0.0dip"
                    android:text="@string/view_website"
                    android:drawablePadding="@dimen/settings_row_horizontal_padding"
                    android:paddingEnd="0.0dip"
                    style="@style/YoSettings_row" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10.0dip"
                android:layout_marginTop="15.0dip"
                android:layout_marginRight="10.0dip"
                android:layout_marginBottom="15.0dip">
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="0.0dip"
                    android:layout_height="2.0dip"
                    android:src="@color/abo_arab_accent"
                    android:layout_weight="1.0" />
                <com.whatsapp.yo.tf
                    android:textSize="18.0sp"
                    android:textStyle="bold"
                    android:textColor="@color/abo_arab_accent"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5.0dip"
                    android:layout_marginRight="5.0dip"
                    android:text="@string/yo_follow" />
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="0.0dip"
                    android:layout_height="2.0dip"
                    android:src="@color/abo_arab_accent"
                    android:layout_weight="1.0" />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:tag="twitter"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:onClick="openSocialMedia">
                <ImageView
                    android:padding="8.0dip"
                    android:layout_width="50.0dip"
                    android:layout_height="50.0dip"
                    android:src="@drawable/abo_arab_ic_yotwitter"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="12.0dip"
                    android:layout_marginEnd="6.0dip" />
                <com.whatsapp.yo.tf
                    android:paddingRight="0.0dip"
                    android:text="@string/twitter"
                    android:drawablePadding="@dimen/settings_row_horizontal_padding"
                    android:paddingEnd="0.0dip"
                    style="@style/YoSettings_row" />
            </LinearLayout>
            <View
                android:layout_marginStart="@dimen/settings_divider_horizontal_margin_left"
                android:layout_marginEnd="@dimen/settings_radio_button_text_padding_left"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:tag="telegram"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:onClick="openSocialMedia">
                <ImageView
                    android:padding="8.0dip"
                    android:layout_width="50.0dip"
                    android:layout_height="50.0dip"
                    android:src="@drawable/abo_arab_ic_yotelegram"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="12.0dip"
                    android:layout_marginEnd="6.0dip" />
                <com.whatsapp.yo.tf
                    android:paddingRight="0.0dip"
                    android:text="@string/telegram"
                    android:drawablePadding="@dimen/settings_row_horizontal_padding"
                    android:paddingEnd="0.0dip"
                    style="@style/YoSettings_row" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/div2"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:foreground="?android:selectableItemBackground">
                <ImageView
                    android:padding="8.0dip"
                    android:layout_width="50.0dip"
                    android:layout_height="50.0dip"
                    android:src="@drawable/abo_arab_ic_yoabout"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="12.0dip"
                    android:layout_marginEnd="6.0dip" />
                <com.whatsapp.yo.tf
                    android:paddingRight="0.0dip"
                    android:text="@string/creditsS"
                    android:paddingEnd="0.0dip"
                    style="@style/YoSettings_row" />
            </LinearLayout>
        </LinearLayout>
        <com.whatsapp.yo.tf
            android:gravity="center"
            android:layout_marginTop="@dimen/info_screen_padding"
            android:text="@string/yowav"
            style="@style/YoSettings_row" />
    </LinearLayout>
</ScrollView>