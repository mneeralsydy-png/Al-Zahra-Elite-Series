<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:id="@id/idHolder"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/idMarginStart"
        android:visibility="gone"
        android:layout_width="8.0dip"
        android:layout_height="0.0dip" />
    <FrameLayout
        android:layout_width="100.0dip"
        android:layout_height="wrap_content">
        <abu3arab.mas.home.views.CardView
            android:id="@id/idItemHolder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:foreground="?android:selectableItemBackground">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@id/idThumbnail"
                    android:layout_width="100.0dip"
                    android:layout_height="146.0dip"
                    android:scaleType="centerCrop"
                    app:attr085d="@color/color08eb" />
                <com.whatsapp.ui.coreui.base.TextEmojiLabel
                    android:textColor="@color/mas_white"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:id="@id/idContactName"
                    android:padding="6.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true" />
            </LinearLayout>
        </abu3arab.mas.home.views.CardView>
        <com.whatsapp.status.api.ContactStatusThumbnail
            android:id="@id/idContactPhoto"
            android:padding="2.5dip"
            android:layout_width="40.0dip"
            android:layout_height="40.0dip"
            android:layout_margin="6.0dip"
            android:scaleType="centerCrop"
            style="@style/StatusRing" />
        <com.whatsapp.yo.tf
            android:gravity="center"
            android:id="@id/idCounter"
            android:background="@drawable/primary_color_circle"
            android:layout_width="wrap_content"
            android:layout_height="22.0dip"
            android:layout_marginTop="26.0dip"
            android:minWidth="22.0dip"
            android:singleLine="true"
            android:layout_marginStart="26.0dip" />
    </FrameLayout>
    <View
        android:id="@id/idMarginEnd"
        android:visibility="visible"
        android:layout_width="8.0dip"
        android:layout_height="0.0dip" />
</LinearLayout>