<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center"
        android:id="@id/sticker_preview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        app:attr0838="@drawable/sticker_error" />
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center"
        android:id="@id/loading_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        app:attr0838="@drawable/sticker_error" />
    <ViewStub
        android:id="@id/animated_sticker_view"
        android:layout="@layout/layout11b7"
        android:inflatedId="@id/animated_sticker_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
</FrameLayout>