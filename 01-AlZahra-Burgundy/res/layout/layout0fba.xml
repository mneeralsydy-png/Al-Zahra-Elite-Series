<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:gravity="bottom"
    android:id="@id/status_mentions_root"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center_horizontal"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_background"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="24.0dip"
            app:attr0838="@drawable/wds_bottom_sheet_handle" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="@style/style05ab"
            android:textStyle="bold"
            android:textColor="@color/color0897"
            android:gravity="center"
            android:id="@id/title"
            android:paddingLeft="@dimen/dimen0cea"
            android:paddingTop="@dimen/dimen0cea"
            android:paddingRight="@dimen/dimen0cea"
            android:paddingBottom="@dimen/dimen0cea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str1ced"
            android:paddingStart="@dimen/dimen0cea"
            android:paddingEnd="@dimen/dimen0cea" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="@style/style05a6"
            android:textColor="@color/color0898"
            android:gravity="center"
            android:paddingLeft="@dimen/dimen0cea"
            android:paddingRight="@dimen/dimen0cea"
            android:paddingBottom="@dimen/dimen0ce7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str1cec"
            android:paddingStart="@dimen/dimen0cea"
            android:paddingEnd="@dimen/dimen0cea"
            app:attr0a24="wds_font_body2" />
        <View
            android:background="@color/color08e5"
            android:layout_width="fill_parent"
            android:layout_height="1.0dip"
            android:layout_marginBottom="@dimen/dimen0ce7" />
        <com.whatsapp.ui.coreui.CircularProgressBar
            android:layout_gravity="center"
            android:id="@id/progress_bar"
            android:visibility="gone"
            android:layout_width="@dimen/dimen0cf1"
            android:layout_height="@dimen/dimen0cf1"
            android:layout_marginTop="@dimen/dimen0cee"
            android:layout_marginBottom="@dimen/dimen0cee"
            android:indeterminate="true"
            app:attr028b="@color/color0790"
            app:attr028c="?attr0a29"
            style="progressBarStyle" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/mentions_list"
            android:paddingLeft="@dimen/dimen0cea"
            android:paddingRight="@dimen/dimen0cea"
            android:paddingBottom="@dimen/dimen0cea"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dimen0cea"
            android:paddingEnd="@dimen/dimen0cea" />
    </LinearLayout>
</FrameLayout>