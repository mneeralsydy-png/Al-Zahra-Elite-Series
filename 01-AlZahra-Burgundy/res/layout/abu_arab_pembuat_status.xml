<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@id/dRootCerita"
        android:background="#ff243640"
        android:padding="8.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1.0">
        <EditText
            android:textSize="40.0sp"
            android:textColor="@color/white"
            android:textColorHighlight="#33000000"
            android:textColorHint="#33ffffff"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/dUbah"
            android:background="@color/primary_psy"
            android:padding="8.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8.0dip"
            android:hint="@string/type_a_status"
            android:translationX="0.0dip"
            android:translationY="0.0dip" />
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/dDua"
        android:background="@color/shadowColor"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:translationZ="2.0dip">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30.0dip">
            <LinearLayout
                android:gravity="center|left"
                android:orientation="horizontal"
                android:id="@id/dTombolBawah"
                android:background="@android:color/transparent"
                android:padding="2.0dip"
                android:layout_width="fill_parent"
                android:layout_height="60.0dip"
                android:translationZ="2.0dip">
                <ImageView
                    android:id="@id/dFotoSendiri"
                    android:layout_width="50.0dip"
                    android:layout_height="fill_parent"
                    android:src="@drawable/abu_arab_status_foto"
                    android:scaleType="center"
                    android:tint="#ffffffff"
                    android:onClick="dFotoSendiri" />
                <ImageView
                    android:id="@id/dWarnaLatar"
                    android:layout_width="50.0dip"
                    android:layout_height="fill_parent"
                    android:src="@drawable/abu_arab_status_latar"
                    android:scaleType="center"
                    android:tint="#ffffffff"
                    android:onClick="dWarnaLatar" />
                <ImageView
                    android:id="@id/dGayaHuruf"
                    android:layout_width="50.0dip"
                    android:layout_height="fill_parent"
                    android:src="@drawable/abu_arab_status_gayahuruf"
                    android:scaleType="center"
                    android:tint="#ffffffff"
                    android:onClick="dGayaHuruf" />
                <ImageView
                    android:id="@id/dWarnaTeks"
                    android:layout_width="50.0dip"
                    android:layout_height="fill_parent"
                    android:layout_marginTop="2.0dip"
                    android:layout_marginBottom="2.0dip"
                    android:src="@drawable/abu_arab_status_warnateks"
                    android:scaleType="center"
                    android:tint="#ffffffff"
                    android:onClick="dWarnaTeks" />
                <ImageView
                    android:id="@id/dGambarSatu"
                    android:layout_width="30.0dip"
                    android:layout_height="fill_parent"
                    android:src="@drawable/abu_arab_status_ukuranhuruf"
                    android:scaleType="center"
                    android:tint="#ffffffff"
                    android:layout_weight="1.0" />
                <ImageView
                    android:id="@id/dGambarDua"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:src="@drawable/abu_arab_status_pindahkan"
                    android:scaleType="center"
                    android:tint="#ffffffff"
                    android:layout_weight="1.0" />
                <ImageView
                    android:id="@id/dSimpanGambar"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:src="@drawable/abu_arab_status_save"
                    android:scaleType="center"
                    android:tint="#ffffffff"
                    android:layout_weight="1.0"
                    android:onClick="dSimpanGambar" />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/mfnmodsy"
                android:padding="8.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="#ffffffff"
                    android:id="@id/dTeksTiga"
                    android:padding="8.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Y" />
                <SeekBar
                    android:id="@id/seekbar3"
                    android:padding="8.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:max="1070"
                    android:progress="200" />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/dx"
                android:padding="8.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="#ffffffff"
                    android:gravity="center"
                    android:id="@id/dTeksDua"
                    android:padding="8.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" x" />
                <SeekBar
                    android:id="@id/dGeserDua"
                    android:padding="8.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:max="370"
                    android:progress="100" />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/dSatu"
                android:background="#ff151515"
                android:padding="8.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:translationZ="4.0dip">
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="#ff000000"
                    android:id="@id/dD"
                    android:padding="8.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="__" />
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="#ffffffff"
                    android:id="@id/dTeksSatu"
                    android:padding="8.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25sp" />
                <SeekBar
                    android:id="@id/dGeserSatu"
                    android:padding="8.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:max="68"
                    android:progress="25" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>