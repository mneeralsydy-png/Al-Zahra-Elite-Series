<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/content"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ViewStub
        android:id="@id/conversation_row_participant_header_view_stub"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <include
        layout="@layout/layout054e" />
    <include
        layout="@layout/layout0588" />
    <FrameLayout
        android:id="@id/map_frame"
        android:padding="@dimen/dimen043d"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen03ea">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:id="@id/thumb"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:scaleType="centerCrop" />
        <com.whatsapp.locationsharing.location.WaMapView
            android:id="@id/map_holder"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:id="@id/thumb_button"
            android:background="@drawable/selector_orange_gradient"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:contentDescription="@string/str1bf5"
            app:attr0a24="wds_font_chat_body2" />
        <FrameLayout
            android:id="@id/location_bubble_frame"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <FrameLayout
            android:layout_gravity="center"
            android:id="@id/control_frame"
            android:background="@drawable/download_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:id="@id/control_btn"
                style="@style/style01b5" />
            <ProgressBar
                android:layout_gravity="center"
                android:id="@id/progress_bar"
                android:visibility="gone"
                android:layout_width="48.0dip"
                android:layout_height="48.0dip" />
        </FrameLayout>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/message_info_holder"
        android:paddingTop="@dimen/dimen1035"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <ViewStub
            android:id="@id/location_place_name_view_stub"
            android:layout="@layout/layout0a0f"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <ViewStub
            android:id="@id/location_place_address_view_stub"
            android:layout="@layout/layout0a0e"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <ViewStub
            android:id="@id/location_host_view_stub"
            android:layout="@layout/layout09f8"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_gravity="right"
            android:orientation="horizontal"
            android:id="@id/date_wrapper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/style01b6">
            <ViewStub
                android:id="@id/broadcast_icon"
                android:layout="@layout/layout0495"
                android:inflatedId="@id/broadcast_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <ViewStub
                android:id="@id/date"
                android:layout="@layout/layout04b8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/status"
                android:paddingLeft="@dimen/dimen1030"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>