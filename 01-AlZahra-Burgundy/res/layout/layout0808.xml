<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="?android:selectableItemBackground"
    android:paddingLeft="@dimen/dimen0cc9"
    android:paddingRight="@dimen/dimen075d"
    android:clipChildren="false"
    android:layout_width="fill_parent"
    android:layout_height="@dimen/dimen0ccb"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:whatsapp="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaImageView
        android:id="@id/avatar"
        style="@style/style0198" />
    <LinearLayout
        android:orientation="vertical"
        android:clipChildren="false"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clipChildren="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <com.whatsapp.ui.coreui.base.TextEmojiLabel
                        android:id="@id/name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/style0289" />
                    <ViewStub
                        android:id="@id/pending_invites_subtitle_view"
                        android:layout="@layout/layout0d0b"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <Space
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0" />
            </LinearLayout>
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/invite_label"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8.0dip"
                android:text="@string/str17b0"
                style="@style/style0240" />
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:id="@id/invite_button"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str2b5f"
                whatsapp:attr0009="normal"
                whatsapp:attr096b="borderless"
                whatsapp:attr09ea="normal" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:id="@id/group_participant_picker_push_name"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8.0dip" />
        </LinearLayout>
        <LinearLayout
            android:gravity="right"
            android:orientation="horizontal"
            android:clipChildren="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:gravity="left"
                android:layout_gravity="left"
                android:id="@id/status"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                style="@style/style0288" />
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textAppearance="@style/style03eb"
                android:id="@id/push_name"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>