                android:id="@id/payment_complete_done"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen0cea"
                android:text="@string/str0718"
                android:layout_marginStart="@dimen/dimen0cea"
                android:layout_marginEnd="@dimen/dimen0cea"
