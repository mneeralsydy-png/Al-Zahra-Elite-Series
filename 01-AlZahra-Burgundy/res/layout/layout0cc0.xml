<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/method_view_container"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/payment_method_container"
        android:background="?attr0a59"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/payment_method_details_container"
            android:background="?android:selectableItemBackground"
            android:paddingTop="16.0dip"
            android:paddingBottom="16.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false">
            <FrameLayout
                android:layout_width="72.0dip"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center"
                    android:id="@id/payment_method_icon"
                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:scaleType="fitXY"
                    android:contentDescription="@string/str2659"
                    app:attr0838="@drawable/ic_account_balance" />
            </FrameLayout>
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:paddingRight="24.0dip"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb0"
                    android:textColor="?attr066e"
                    android:ellipsize="end"
                    android:id="@id/payment_method_bank_name"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    app:attr0a24="wds_font_body1" />
                <com.whatsapp.ui.coreui.CopyableTextView
                    android:textSize="@dimen/dimen0fb6"
                    android:textColor="?attr0a46"
                    android:id="@id/payment_method_account_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb6"
                    android:textColor="?attr0a46"
                    android:id="@id/payment_method_account_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:attr0a24="wds_font_body2" />
            </LinearLayout>
        </LinearLayout>
        <FrameLayout
            android:id="@id/method_details_alert_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/payment_method_refresh_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/payment_method_additional_details_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/default_payment_method_container"
        android:background="?attr0a59"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <include
            android:id="@id/default_payment_method_divider"
            layout="@layout/layout0651" />
        <ViewStub
            android:id="@id/default_payment_method_stub"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/widget_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/support_container"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/help_section"
        android:background="?attr0a59"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <include
            android:id="@id/help_divider_above"
            layout="@layout/layout0651" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/help_row"
            android:background="?android:selectableItemBackground"
            android:paddingTop="16.0dip"
            android:paddingRight="24.0dip"
            android:paddingBottom="16.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:layout_width="72.0dip"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center"
                    android:id="@id/help_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="center"
                    app:attr0838="@drawable/ic_help"
                    app:attr0a89="true" />
            </FrameLayout>
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:textColor="?attr066e"
                android:id="@id/help_label"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str4226"
                android:singleLine="true"
                app:attr0a24="wds_font_body1" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@id/footer_container"
        android:paddingTop="16.0dip"
        android:paddingBottom="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
</LinearLayout>