<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen05cf"
        android:layout_marginStart="@dimen/dimen05cf"
        android:layout_marginEnd="@dimen/dimen05cf">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:gravity="center_vertical"
            android:id="@id/safety_tips_close_button"
            android:layout_width="@dimen/dimen05cb"
            android:layout_height="@dimen/dimen05cb"
            android:contentDescription="@string/str3dac"
            app:attr0838="@drawable/ic_close"
            app:attr090d="@color/color0347" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="20.0sp"
            android:textColor="?attr066e"
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str1506"
            android:fontFamily="?attr03b8" />
    </FrameLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb6"
                android:textColor="?attr066e"
                android:layout_gravity="start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05cf"
                android:text="@string/str150d"
                android:fontFamily="?attr03b8"
                android:layout_marginStart="@dimen/dimen05cf"
                android:layout_marginEnd="@dimen/dimen05cf"
                app:attr0a24="wds_font_body2_emphasized" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb6"
                android:textColor="?attr0a46"
                android:layout_gravity="start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen0ce7"
                android:layout_marginBottom="@dimen/dimen05cf"
                android:text="@string/str150c"
                android:fontFamily="?attr03b6"
                android:layout_marginStart="@dimen/dimen05cf"
                android:layout_marginEnd="@dimen/dimen05cf"
                app:attr0a24="wds_font_body2" />
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@id/block_contact_container"
                android:background="?android:selectableItemBackground"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dimen0ceb"
                android:layout_marginStart="@dimen/dimen05cf"
                android:layout_marginEnd="@dimen/dimen05cf">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="fitCenter"
                    app:attr0838="@drawable/ic_block"
                    app:attr090d="?attr0a4f" />
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:layout_marginStart="@dimen/dimen05cd">
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fb6"
                        android:textColor="?attr0a4f"
                        android:layout_gravity="start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/dimen0cf0"
                        android:text="@string/str150a"
                        android:textAlignment="viewStart"
                        app:attr03ae="?attr03b6"
                        app:attr0a24="wds_font_body2" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fbc"
                        android:textColor="?attr0a46"
                        android:layout_gravity="start"
                        android:id="@id/fmx_block_contact_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str1509"
                        android:textAlignment="viewStart"
                        app:attr03ae="?attr03b6"
                        app:attr0a24="wds_font_body3" />
                </LinearLayout>
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/fmx_block_contact_arrow"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen0ce8"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="@dimen/dimen0ce8"
                    app:attr0838="@drawable/vec_ic_arrow_forward_ios" />
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@id/report_spam_container"
                android:background="?android:selectableItemBackground"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen05cf"
                android:layout_marginEnd="@dimen/dimen05cf">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="fitCenter"
                    app:attr0838="@drawable/ic_thumb_down"
                    app:attr090d="?attr0a4f" />
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:layout_marginStart="@dimen/dimen05cd">
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fb6"
                        android:textColor="?attr0a4f"
                        android:layout_gravity="start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/dimen0cf0"
                        android:text="@string/str1516"
                        android:textAlignment="viewStart"
                        app:attr03ae="?attr03b6"
                        app:attr0a24="wds_font_body2" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fbc"
                        android:textColor="?attr0a46"
                        android:layout_gravity="start"
                        android:id="@id/fmx_report_spam_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str1515"
                        android:textAlignment="viewStart"
                        app:attr03ae="?attr03b6"
                        app:attr0a24="wds_font_body3" />
                </LinearLayout>
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/fmx_report_spam_arrow"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen0ce8"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="@dimen/dimen0ce8"
                    app:attr0838="@drawable/vec_ic_arrow_forward_ios" />
            </LinearLayout>
            <View
                android:layout_marginTop="@dimen/dimen0ceb"
                android:layout_marginStart="@dimen/dimen05cf"
                android:layout_marginEnd="@dimen/dimen05cf"
                style="@style/style0355" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb6"
                android:textColor="?attr066e"
                android:layout_gravity="start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05cf"
                android:text="@string/str150b"
                android:fontFamily="?attr03b8"
                android:layout_marginStart="@dimen/dimen05cf"
                android:layout_marginEnd="@dimen/dimen05cf"
                app:attr0a24="wds_font_body2_emphasized" />
            <com.whatsapp.settings.SettingsRowIconText
                android:id="@id/fmx_safety_tips_profile_name_id"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05cc"
                app:attr07a5="?attr0a46"
                app:attr07a8="@drawable/ic_person"
                app:attr07aa="@string/str1513"
                app:attr07ab="@string/str1514"
                style="?attr07a6" />
            <com.whatsapp.settings.SettingsRowIconText
                android:id="@id/fmx_safety_tips_phone_number_id"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05cd"
                app:attr07a5="?attr0a46"
                app:attr07a8="@drawable/ic_dialpad_gray"
                app:attr07aa="@string/str1511"
                app:attr07ab="@string/str1512"
                style="?attr07a6" />
            <com.whatsapp.settings.SettingsRowIconText
                android:id="@id/fmx_safety_tips_3p_personal_info_id"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05cc"
                app:attr07a5="?attr0a46"
                app:attr07a8="@drawable/wds_3p_account_circle"
                app:attr07aa="@string/str1507"
                app:attr07ab="@string/str1508"
                style="?attr07a6" />
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:id="@id/safety_tips_learn_more"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen05ce"
                android:layout_marginBottom="@dimen/dimen05cf"
                android:text="@string/str150e"
                android:layout_marginStart="@dimen/dimen05cf"
                android:layout_marginEnd="@dimen/dimen05cf"
                style="@style/style0557" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>