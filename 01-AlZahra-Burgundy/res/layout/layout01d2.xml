<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@id/ban_info"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:textSize="@dimen/dimen0fb0"
            android:textColor="?attr066e"
            android:id="@id/heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen0cee"
            android:layout_marginTop="@dimen/dimen0cee"
            android:layout_marginRight="@dimen/dimen0cee"
            android:text="@string/str04d2"
            android:lineSpacingExtra="4.0sp" />
        <com.whatsapp.ui.coreui.WaEditText
            android:textSize="@dimen/dimen0fb6"
            android:textColor="?attr0a46"
            android:gravity="start|center|top"
            android:id="@id/form_appeal_reason"
            android:background="@drawable/description_field_background_state_list"
            android:paddingLeft="@dimen/dimen0cea"
            android:paddingTop="@dimen/dimen0ce7"
            android:paddingRight="@dimen/dimen0cea"
            android:paddingBottom="@dimen/dimen0ce7"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen0cee"
            android:layout_marginTop="@dimen/dimen0cee"
            android:layout_marginRight="@dimen/dimen0cee"
            android:hint="@string/str04d1"
            android:lines="4"
            android:maxLength="5000"
            android:lineSpacingExtra="4.0sp"
            android:textAlignment="viewStart" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/submit_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="18.0dip"
            android:layout_marginTop="@dimen/dimen0cea"
            android:layout_marginRight="18.0dip"
            android:text="@string/str04d3"
            style="@style/style0555" />
    </LinearLayout>
</ScrollView>