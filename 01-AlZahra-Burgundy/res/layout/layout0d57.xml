                android:textSize="@dimen/dimen0fb6"
                android:textColor="@color/color06d1"
                android:id="@id/postcode_item_location_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/postcode_item_text"
                android:letterSpacing="0.02"
                style="@style/style031f" />
        </RelativeLayout>
    </RelativeLayout>
    <View
        android:background="?attr00af"
