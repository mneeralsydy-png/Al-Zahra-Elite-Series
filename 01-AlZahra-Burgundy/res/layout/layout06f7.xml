<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.whatsapp.ui.wds.components.actiontile.WDSActionTileGroup
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen1039">
        <com.whatsapp.ui.wds.components.actiontile.WDSActionTile
            android:icon="@drawable/vec_ic_chat"
            android:id="@id/action_message"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str3f0f"
            android:layout_weight="1.0" />
        <Space
            android:layout_width="@dimen/dimen1039"
            android:layout_height="@dimen/dimen1039" />
        <com.whatsapp.ui.wds.components.actiontile.WDSActionTile
            android:icon="@drawable/vec_ic_person_add"
            android:id="@id/action_add_guest"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str3e51"
            android:layout_weight="1.0" />
    </com.whatsapp.ui.wds.components.actiontile.WDSActionTileGroup>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@id/guest_list"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
</LinearLayout>