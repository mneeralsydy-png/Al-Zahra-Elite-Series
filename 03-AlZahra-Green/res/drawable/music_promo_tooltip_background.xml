<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:bottom="@dimen/dimen09bd">
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/color08f9" />
            <corners
                android:radius="@dimen/dimen09be" />
        </shape>
    </item>
    <item
        android:gravity="bottom|center|left"
        android:left="@dimen/dimen09ba"
        android:bottom="@dimen/dimen09b9">
        <rotate
            android:fromDegrees="45.0"
            android:toDegrees="45.0"
            android:pivotX="50.0%"
            android:pivotY="50.0%">
            <shape
                android:shape="rectangle">
                <size
                    android:height="@dimen/dimen09bc"
                    android:width="@dimen/dimen09bc" />
                <corners
                    android:topLeftRadius="@dimen/dimen09bb"
                    android:topRightRadius="@dimen/dimen09bb" />
                <solid
                    android:color="@color/color08f9" />
            </shape>
        </rotate>
    </item>
</layer-list>