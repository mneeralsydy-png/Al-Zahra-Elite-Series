<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/dyi_report_page"
    android:background="@drawable/round_rectangle"
    android:fitsSystemWindows="true"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.payments.common.ui.widget.PayToolbar
        android:id="@id/pay_service_toolbar"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:attr024e="0.0dip"
        app:attr0251="0.0dip" />
    <ScrollView
        android:orientation="vertical"
        android:id="@id/scroll_view_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/dimen103b"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:id="@id/dyi_report_logo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="center"
                    app:attr0838="@drawable/image_report" />
                <com.whatsapp.ui.coreui.base.TextEmojiLabel
                    android:textSize="@dimen/dimen0fb0"
                    android:textColor="?attr0a47"
                    android:gravity="left"
                    android:id="@id/dyi_report_header"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen103b"
                    android:text="@string/str260e"
                    android:lineSpacingExtra="@dimen/dimen1030" />
            </LinearLayout>
            <View
                android:background="?attr0a4d"
                android:layout_width="fill_parent"
                android:layout_height="0.5dip"
                android:layout_marginTop="@dimen/dimen1039"
                android:layout_marginBottom="@dimen/dimen1039" />
            <FrameLayout
                android:id="@id/dyi_report_button"
                android:background="?android:selectableItemBackground"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center|left"
                    android:id="@id/dyi_report_button_icon"
                    android:paddingLeft="28.0dip"
                    android:paddingRight="28.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:attr0838="@drawable/ic_description" />
                <LinearLayout
                    android:layout_gravity="center|left"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/dimen1032"
                    android:paddingTop="@dimen/dimen102e"
                    android:paddingRight="@dimen/dimen102e"
                    android:paddingBottom="@dimen/dimen102e"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fb0"
                        android:textColor="?attr0a47"
                        android:id="@id/dyi_report_button_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str1146"
                        android:singleLine="true"
                        app:attr0a24="wds_font_body1" />
                    <com.whatsapp.ui.coreui.base.WaTextView
                        android:textSize="@dimen/dimen0fb0"
                        android:id="@id/gdpr_report_button_subtitle"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:attr0a24="wds_font_body1" />
                </LinearLayout>
            </FrameLayout>
            <View
                android:background="?attr0a4d"
                android:layout_width="fill_parent"
                android:layout_height="0.5dip"
                android:layout_marginTop="@dimen/dimen1039"
                android:layout_marginBottom="@dimen/dimen1039" />
            <FrameLayout
                android:id="@id/dyi_report_delete"
                android:background="?android:selectableItemBackground"
                android:paddingTop="@dimen/dimen102e"
                android:paddingBottom="@dimen/dimen102e"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center|left"
                    android:paddingLeft="28.0dip"
                    android:paddingRight="28.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:attr0838="@drawable/ic_delete_white"
                    app:attr090d="?attr0a4f" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:textSize="@dimen/dimen0fb0"
                    android:textColor="?attr0a47"
                    android:gravity="center_vertical"
                    android:layout_gravity="center|left"
                    android:paddingLeft="@dimen/dimen1032"
                    android:paddingRight="@dimen/dimen102e"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str113f"
                    android:singleLine="true"
                    app:attr0a24="wds_font_body1" />
            </FrameLayout>
            <View
                android:id="@id/delete_button_divider"
                android:background="?attr0a4d"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="0.5dip"
                android:layout_marginTop="@dimen/dimen1039"
                android:layout_marginBottom="@dimen/dimen1039" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:textColor="?attr0a46"
                android:id="@id/dyi_report_header_disclaimer"
                android:paddingLeft="@dimen/dimen103b"
                android:paddingTop="@dimen/dimen103b"
                android:paddingRight="@dimen/dimen103b"
                android:paddingBottom="@dimen/dimen102e"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str260d"
                android:lineSpacingMultiplier="1.3"
                app:attr0a24="wds_font_body1" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:textColor="?attr0a46"
                android:id="@id/dyi_report_footer_disclaimer"
                android:paddingLeft="@dimen/dimen103b"
                android:paddingTop="@dimen/dimen1039"
                android:paddingRight="@dimen/dimen103b"
                android:paddingBottom="@dimen/dimen102e"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str260c"
                android:lineSpacingMultiplier="1.3"
                app:attr0a24="wds_font_body1" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:textColor="?attr0a46"
                android:id="@id/dyi_report_footer_delete"
                android:paddingLeft="@dimen/dimen103b"
                android:paddingTop="@dimen/dimen1039"
                android:paddingRight="@dimen/dimen103b"
                android:paddingBottom="@dimen/dimen102e"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str260a"
                android:lineSpacingMultiplier="1.3"
                app:attr0a24="wds_font_body1" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>