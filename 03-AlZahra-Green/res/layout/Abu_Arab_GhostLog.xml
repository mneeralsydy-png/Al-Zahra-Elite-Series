<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:title="settings_general"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6.0dip">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="?android:selectableItemBackground"
            android:padding="8.0dip"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:onClick="abuarabghostlog">
            <ImageView
                android:layout_gravity="center"
                android:background="@drawable/Abo_Arab_WA5"
                android:layout_width="39.0dip"
                android:layout_height="39.0dip"
                android:layout_marginLeft="8.0dip"
                android:layout_marginRight="8.0dip"
                android:src="@drawable/abo_arab_ic_onlinestyle"
                android:scaleType="centerInside"
                android:tint="@color/icon_primary" />
            <LinearLayout
                android:layout_gravity="start"
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8.0dip"
                android:layout_marginRight="8.0dip"
                android:layout_weight="1.0">
                <com.whatsapp.yo.tf
                    android:textSize="16.0sp"
                    android:textColor="@color/primary_text"
                    android:ellipsize="marquee"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3.0dip"
                    android:text="@string/abuarabghostlog"
                    android:maxLines="1" />
                <com.whatsapp.yo.tf
                    android:textSize="14.0sp"
                    android:textStyle="normal"
                    android:textColor="@color/secondary_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1.0dip"
                    android:text="@string/abuarabghostlog_sum"
                    android:singleLine="false" />
            </LinearLayout>
            <ImageView
                android:layout_gravity="end|center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/abu_arab_chevron_right"
                android:layout_marginStart="8.0dip"
                android:layout_marginEnd="8.0dip" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>