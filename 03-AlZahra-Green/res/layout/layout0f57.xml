<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.util.ClippingLayout
        android:layout_gravity="bottom"
        android:id="@id/footer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1.0dip">
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/emoji_popup_anchor"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:gravity="bottom"
                android:id="@id/edit_layout"
                android:paddingLeft="@dimen/dimen103a"
                android:paddingRight="@dimen/dimen103a"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <FrameLayout
                    android:id="@id/text_entry_layout"
                    android:paddingLeft="@dimen/dimen1030"
                    android:paddingTop="3.25dip"
                    android:paddingRight="0.0dip"
                    android:paddingBottom="@dimen/dimen1030"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_toLeftOf="@id/buttons"
                    android:layout_centerVertical="true">
                    <LinearLayout
                        android:gravity="bottom"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:id="@id/input_layout"
                        android:background="@drawable/ib_new_round"
                        android:paddingLeft="0.0dip"
                        android:paddingTop="0.0dip"
                        android:paddingRight="@dimen/dimen1039"
                        android:paddingBottom="0.0dip"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="0.0dip"
                        android:minHeight="46.0dip">
                        <LinearLayout
                            android:orientation="horizontal"
                            android:id="@id/input_layout_content"
                            android:paddingBottom="0.25dip"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="46.0dip">
                            <LinearLayout
                                android:layout_gravity="bottom"
                                android:orientation="vertical"
                                android:id="@id/emoji_btn_holder"
                                android:paddingBottom="@dimen/dimen1035"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">
                                <com.whatsapp.ui.coreui.base.WaTextView
                                    android:textColor="?attr0a46"
                                    android:layout_gravity="center_horizontal"
                                    android:id="@id/counter"
                                    android:visibility="gone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:attr0a24="wds_font_body2" />
                                <com.whatsapp.ui.coreui.base.WaImageButton
                                    android:layout_gravity="center"
                                    android:id="@id/emoji_picker_btn"
                                    android:layout_width="44.0dip"
                                    android:layout_height="46.0dip"
                                    android:scaleType="center"
                                    android:contentDescription="@string/str3e44"
                                    app:attr0838="@drawable/ic_mood_black"
                                    style="@style/style0006" />
                            </LinearLayout>
                            <com.whatsapp.mentions.ui.MentionableEntry
                                android:scrollbarAlwaysDrawVerticalTrack="true"
                                android:scrollbarStyle="insideInset"
                                android:textColor="?attr066e"
                                android:textColorHint="?attr0a46"
                                android:layout_gravity="center_vertical"
                                android:id="@id/send_payment_note"
                                android:background="@null"
                                android:paddingTop="@dimen/dimen1030"
                                android:paddingRight="@dimen/dimen1039"
                                android:paddingBottom="@dimen/dimen1030"
                                android:scrollbars="vertical"
                                android:layout_width="0.0dip"
                                android:layout_height="wrap_content"
                                android:maxLines="3"
                                android:layout_weight="1.0"
                                android:inputType="textAutoCorrect|textCapSentences|textMultiLine"
                                android:imeOptions="actionSend"
                                android:scrollbarFadeDuration="300"
                                android:scrollbarDefaultDelayBeforeFade="200" />
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:id="@id/sticker_preview_layout"
                            android:paddingTop="7.0dip"
                            android:paddingBottom="7.0dip"
                            android:visibility="gone"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content">
                            <com.whatsapp.stickers.StickerView
                                android:layout_gravity="center"
                                android:id="@id/sticker_preview"
                                android:layout_width="@dimen/dimen0ab0"
                                android:layout_height="@dimen/dimen0aaf"
                                android:layout_marginRight="@dimen/dimen1039" />
                            <com.whatsapp.ui.coreui.base.WaImageButton
                                android:layout_gravity="top"
                                android:id="@id/sticker_remove_cta"
                                android:layout_width="24.0dip"
                                android:layout_height="24.0dip"
                                android:layout_marginTop="@dimen/dimen1030"
                                android:scaleType="center"
                                android:contentDescription="@string/str3dac"
                                app:attr0838="@drawable/ic_close"
                                app:attr090d="@color/color00ca"
                                style="?attr0015" />
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
                <FrameLayout
                    android:id="@id/buttons"
                    android:paddingBottom="@dimen/dimen1030"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen1039"
                    android:layout_marginRight="@dimen/dimen06d7"
                    android:layout_alignBottom="@id/text_entry_layout"
                    android:layout_alignParentRight="true">
                    <ViewStub
                        android:id="@id/payment_entry_action_stub"
                        android:inflatedId="@id/payment_entry_action_inflated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </FrameLayout>
            </RelativeLayout>
            <com.whatsapp.media.gifsearch.GifSearchContainer
                android:id="@id/gif_search_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/dimen060c" />
            <com.whatsapp.emoji.search.EmojiSearchContainer
                android:id="@id/emoji_search_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </com.whatsapp.ui.coreui.util.ClippingLayout>
</FrameLayout>