                    android:id="@id/contacts_backup_description_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="3.0dip"
                    style="?attr07b1" />
            </LinearLayout>
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.wds.components.toggle.WDSSwitch
                    android:layout_gravity="end|center|top"
                    android:id="@id/contacts_backup_switch"
                    android:focusable="false"
                    android:clickable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
                <com.whatsapp.ui.coreui.CircularProgressBar
                    android:layout_gravity="center"
                    android:id="@id/backup_progress_bar"
                    android:visibility="gone"
                    android:layout_width="32.0dip"
                    android:layout_height="32.0dip"
                    android:indeterminateOnly="true" />
            </FrameLayout>
        </com.whatsapp.settings.SettingsRowPrivacyLinearLayout>
    </LinearLayout>
