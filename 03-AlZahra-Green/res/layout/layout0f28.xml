<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <ViewStub
            android:id="@id/dependent_messages_settings_stub"
            android:layout="@layout/layout0616"
            android:inflatedId="@id/dependent_messages_settings"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <com.whatsapp.consumer.settings.SettingsRowPrivacyText
            android:id="@id/block_list_privacy_contacts_preference"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            style="?attr07ac" />
        <com.whatsapp.settings.SettingsRowPrivacyLinearLayout
            android:orientation="horizontal"
            android:id="@id/contacts_backup_layout"
            android:paddingTop="@dimen/dimen0c97"
            android:paddingBottom="@dimen/dimen0c97"
