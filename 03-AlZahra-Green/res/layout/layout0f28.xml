            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:paddingStart="@dimen/dimen0c93"
            android:paddingEnd="@dimen/dimen0c93"
            style="@style/style0363">
            <LinearLayout
                android:orientation="vertical"
                android:paddingRight="@dimen/dimen102e"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:ellipsize="none"
                    android:id="@id/contacts_backup_label_view"
                    android:paddingBottom="@dimen/dimen1030"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/str23ae"
                    android:maxLines="@null"
                    android:singleLine="false"
                    style="?attr07b5" />
