<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="@drawable/spam_report_dialog_background"
    android:padding="@dimen/dimen103b"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center"
        android:layout_width="24.0sp"
        android:layout_height="24.0sp"
        android:layout_marginBottom="@dimen/dimen102e"
        android:tint="?attr0a46"
        app:attr0838="@drawable/ic_check_circle_white" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:textAppearance="@style/style05aa"
        android:gravity="center"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/str2bf2"
        app:attr0a24="wds_font_headline1" />
    <com.whatsapp.ui.coreui.base.WaTextView
        android:textAppearance="@style/style05a6"
        android:textColor="@color/color08de"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen102e"
        android:layout_marginBottom="@dimen/dimen102e"
        android:text="@string/str2bf0"
        app:attr0a24="wds_font_body2" />
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:background="@drawable/report_success_tip_bg"
        android:padding="@dimen/dimen1039"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center_vertical"
            android:layout_width="@dimen/dimen0fdb"
            android:layout_height="@dimen/dimen0fdb"
            android:tint="?attr0a46"
            android:layout_marginEnd="@dimen/dimen103a"
            app:attr0838="@drawable/ic_description" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb6"
            android:textColor="?attr066e"
            android:layout_gravity="center_vertical"
            android:id="@id/report_spam_dialog_success_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="4.0sp"
            app:attr0a24="wds_font_body2" />
    </LinearLayout>
    <LinearLayout
        android:gravity="end|center"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:id="@id/report_spam_dialog_success_button_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen103b">
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/report_spam_dialog_success_view_report"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str2bf3"
            android:layout_marginEnd="@dimen/dimen1039"
            app:attr096b="borderless" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/report_spam_dialog_success_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str2bef"
            app:attr096b="borderless" />
    </LinearLayout>
</LinearLayout>