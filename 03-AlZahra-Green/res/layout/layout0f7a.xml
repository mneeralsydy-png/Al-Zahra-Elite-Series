                style="@style/style0132" />
            <com.whatsapp.business.biz.BusinessProfileFieldView
                android:id="@id/business_location"
                android:visibility="gone"
                app:attr00e7="@drawable/ic_location_on"
                style="@style/style0132" />
            <com.whatsapp.business.biz.BusinessProfileFieldView
                android:id="@id/business_link"
                android:tag="website"
                android:visibility="gone"
                app:attr00e5="end"
                app:attr00e7="@drawable/ic_public"
                app:attr00e8="true"
                style="@style/style0132" />
            <com.whatsapp.business.biz.BusinessProfileFieldView
                android:id="@id/business_link_2"
                android:tag="website"
                android:visibility="gone"
                app:attr00e5="end"
                app:attr00e7="@drawable/ic_public"
                app:attr00e8="true"
                style="@style/style0132" />
            <com.whatsapp.business.biz.BusinessProfileFieldView
                android:id="@id/business_email"
                android:visibility="gone"
                app:attr00e5="end"
                app:attr00e7="@drawable/ic_mail"
                app:attr00e8="true"
                style="@style/style0132" />
        </com.whatsapp.ui.coreui.InfoCard>
        <com.whatsapp.ui.coreui.InfoCard
            android:id="@id/brand_link_card"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:attr040b="?attr0a59"
            style="@style/style0256">
            <com.whatsapp.business.biz.BusinessProfileFieldView
