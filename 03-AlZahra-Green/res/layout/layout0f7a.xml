        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <View
            style="@style/style0282" />
        <com.whatsapp.ui.coreui.InfoCard
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:attr040b="?attr0a59"
            style="@style/style0256">
            <com.whatsapp.business.biz.BusinessHoursView
                android:id="@id/business_hours"
                android:visibility="gone"
                style="@style/style0132" />
            <com.whatsapp.business.biz.BusinessProfileFieldView
                android:id="@id/business_categories"
                android:visibility="gone"
                app:attr00e7="@drawable/ic_category"
                style="@style/style0132" />
            <com.whatsapp.business.biz.BusinessProfileFieldView
                android:id="@id/business_description_v2"
                android:visibility="gone"
                android:paddingEnd="@dimen/dimen0a26"
