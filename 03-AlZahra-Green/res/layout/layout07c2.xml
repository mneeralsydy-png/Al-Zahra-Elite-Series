<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/gallery_container"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <View
            android:id="@id/gallery_header_transition"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:transitionName="@string/str42e2" />
        <include
            layout="@layout/layout0860" />
        <View
            android:id="@id/gallery_footer_transition"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:transitionName="@string/str42e1" />
    </LinearLayout>
</FrameLayout>