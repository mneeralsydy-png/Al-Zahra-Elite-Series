<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    style="@style/style0536"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textStyle="bold"
            android:id="@id/variants_label"
            android:background="@color/color0901"
            android:layout_width="@dimen/dimen0b69"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dimen0b6a"
            android:letterSpacing="0.02" />
        <androidx.recyclerview.widget.RecyclerView
            android:orientation="horizontal"
            android:id="@id/variants_list"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0b68"
            app:attr0488="androidx.recyclerview.widget.LinearLayoutManager" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:id="@id/variants_dropdown"
            android:visibility="gone"
            android:layout_marginTop="@dimen/dimen0b68"
            app:attr02ed="@color/color07d1"
            style="@style/style0538" />
    </LinearLayout>
</com.facebook.shimmer.ShimmerFrameLayout>