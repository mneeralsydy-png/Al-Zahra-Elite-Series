<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/alert_banner_component"
        android:paddingTop="12.0dip"
        android:paddingBottom="12.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center_vertical"
            android:id="@id/alert_icon"
            android:layout_width="24.0dip"
            android:layout_height="24.0dip"
            android:layout_marginLeft="28.0dip"
            android:layout_marginRight="@dimen/dimen102f" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/alert_info_layout"
            android:paddingRight="24.0dip"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/alert_title"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style0024" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/alert_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style001f" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="@id/alert_action_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/style001e" />
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/alert_count_icon_layout"
            android:paddingRight="16.0dip"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:textStyle="bold"
                android:textColor="@color/color0905"
                android:id="@id/multi_alert_count"
                android:paddingRight="@dimen/dimen1030"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/alert_right_icon"
                android:layout_width="16.0dip"
                android:layout_height="16.0dip"
                app:attr0838="@drawable/ic_arrow_forward_ios"
                app:attr090d="@color/color0905" />
        </LinearLayout>
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center_vertical"
            android:id="@id/alert_close_icon"
            android:paddingRight="16.0dip"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:attr0838="@drawable/ic_close"
            app:attr090d="@color/color0902" />
    </LinearLayout>
</merge>