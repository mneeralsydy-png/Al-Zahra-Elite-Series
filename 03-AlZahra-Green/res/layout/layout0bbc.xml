<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/dimen0cee"
        android:paddingEnd="@dimen/dimen0cee">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0df5"
            android:textColor="@color/color0776"
            android:gravity="center"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0cee"
            android:text="@string/str2082"
            android:fontFamily="?attr03b8" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textSize="@dimen/dimen0fb6"
            android:gravity="center"
            android:id="@id/bottom_sheet_description"
            android:paddingTop="@dimen/dimen0cea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str2081"
            android:lineSpacingExtra="4.0sp"
            android:paddingStart="@dimen/dimen0ce7"
            android:paddingEnd="@dimen/dimen0ce7"
            app:attr0a24="wds_font_body2" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/close_bottom_sheet"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0cf1"
            android:layout_marginBottom="@dimen/dimen0cea"
            android:text="@string/str3dac" />
    </LinearLayout>
</ScrollView>