<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_horizontal"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:id="@id/ambilwarna_dialogView"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@id/mTabView"
        android:background="@color/abo_arab_primary"
        android:layout_width="fill_parent"
        android:layout_height="50.0dip"
        android:elevation="3.0dip">
        <FrameLayout
            android:layout_gravity="center_horizontal"
            android:id="@id/mBtnPallete"
            android:background="?android:selectableItemBackground"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:layout_weight="1.0">
            <com.whatsapp.yo.tf
                android:textStyle="bold"
                android:textColor="@color/mas_white"
                android:layout_gravity="center"
                android:id="@id/tPalette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/abu_arab_palett_plt" />
            <View
                android:layout_gravity="bottom"
                android:id="@id/palleteView"
                android:background="@color/delta_white50"
                android:layout_width="fill_parent"
                android:layout_height="2.0dip" />
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="center_horizontal"
            android:id="@id/mBtnArgb"
            android:background="?android:selectableItemBackground"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:layout_weight="1.0">
            <com.whatsapp.yo.tf
                android:textStyle="bold"
                android:textColor="@color/mas_white"
                android:layout_gravity="center"
                android:id="@id/tArgb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/abu_arab_palett_cstm" />
            <View
                android:layout_gravity="bottom"
                android:id="@id/argbView"
                android:background="@color/delta_white50"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="2.0dip" />
        </FrameLayout>
    </LinearLayout>
    <FrameLayout
        android:layout_gravity="center"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:gravity="center_horizontal"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@id/mArgbView"
            android:padding="16.0dip"
            android:visibility="invisible"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <include
                layout="@layout/ambilwarna_dialog" />
        </LinearLayout>
        <FrameLayout
            android:gravity="center_horizontal"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@id/mPalleteView"
            android:paddingTop="8.0dip"
            android:paddingBottom="8.0dip"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <abu3arab.mas.preferences.palette.ColorPickerPalette
                android:layout_gravity="center_horizontal"
                android:id="@id/mPallete"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent" />
        </FrameLayout>
    </FrameLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@id/ambilwarna_state"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ambilwarna_spacer"
        android:layout_marginBottom="16.0dip"
        android:paddingStart="40.0dip"
        android:paddingEnd="40.0dip">
        <FrameLayout
            android:id="@id/ambilwarna_oldColor"
            android:layout_width="0.0dip"
            android:layout_height="40.0dip"
            android:layout_weight="1.0">
            <EditText
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/input_warna"
                android:background="@null"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:hint="(exp: #ffffffff)"
                android:singleLine="true"
                android:maxLength="9"
                android:imeOptions="actionDone" />
        </FrameLayout>
        <ImageView
            android:paddingLeft="16.0dip"
            android:paddingRight="16.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/delta_aw_arrow_right" />
        <FrameLayout
            android:id="@id/ambilwarna_newColor"
            android:background="#ffaaaaff"
            android:layout_width="0.0dip"
            android:layout_height="40.0dip"
            android:layout_weight="1.0" />
    </LinearLayout>
    <View
        android:background="?android:listDivider"
        android:layout_width="fill_parent"
        android:layout_height="1.0px"
        android:layout_marginLeft="16.0dip"
        android:layout_marginRight="16.0dip"
        android:layout_marginBottom="8.0dip" />
    <abu3arab.mas.preferences.colorpicker.HistorySelectorView
        android:id="@id/mHistory"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
</LinearLayout>