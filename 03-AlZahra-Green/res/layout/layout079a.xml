            android:layout_height="@dimen/dimen0b71" />
        <include
            android:id="@id/variants_container1"
            layout="@layout/layout1144" />
    </FrameLayout>
    <View
        style="@style/style0355" />
    <FrameLayout
        android:layout_width="fill_parent"
