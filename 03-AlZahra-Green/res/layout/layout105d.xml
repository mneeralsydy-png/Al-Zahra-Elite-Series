<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/sticker_store_my"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <androidx.recyclerview.widget.RecyclerView
        android:id="@id/store_recycler_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <ViewStub
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@id/store_progress"
        android:layout="@layout/layout1061"
        android:inflatedId="@id/store_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <ViewStub
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@id/empty"
        android:layout="@layout/layout105e"
        android:inflatedId="@id/empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
</FrameLayout>