            android:id="@id/subtitle"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            style="@style/style0285" />
    </LinearLayout>
    <RadioButton
        android:layout_gravity="center_vertical"
        android:id="@id/radio"
        android:focusable="false"
