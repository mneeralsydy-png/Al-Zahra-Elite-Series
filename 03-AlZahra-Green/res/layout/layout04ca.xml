<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:facepile="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center|right"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/dimen0569"
        android:minHeight="30.0dip">
        <ViewStub
            android:id="@id/conversation_row_participant_header_view_stub"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <include
            layout="@layout/layout054e" />
        <com.whatsapp.ui.coreui.WaFrameLayout
            android:background="@drawable/conversation_row_event_bubble_background"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dimen0cec">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <ViewStub
                    android:id="@id/cover_image_stub"
                    android:layout="@layout/layout06e5"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen0ce7"
                    android:layout_marginStart="@dimen/dimen0ce7"
                    android:layout_marginEnd="@dimen/dimen0ce7">
                    <FrameLayout
                        android:background="@drawable/bubble_circle_outgoing"
                        android:layout_width="40.0dip"
                        android:layout_height="40.0dip"
                        android:layout_marginRight="@dimen/dimen0ce7">
                        <com.whatsapp.ui.coreui.base.WaImageView
