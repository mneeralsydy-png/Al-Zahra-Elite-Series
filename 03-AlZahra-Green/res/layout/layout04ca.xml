        </com.whatsapp.ui.coreui.WaFrameLayout>
        <ViewStub
            android:id="@id/invalid_event_text"
            android:visibility="gone"
            android:layout="@layout/layout0450"
            android:inflatedId="@id/invalid_event_text"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12.0dip"
            android:layout_marginRight="12.0dip" />
        <include
            layout="@layout/layout04c7" />
        <ViewStub
            android:id="@id/conversation_row_secondary_action_button"
            android:layout="@layout/layout04cb"
            android:inflatedId="@id/conversation_row_secondary_action_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</merge>