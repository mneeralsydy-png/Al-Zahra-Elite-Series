                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
                        <com.whatsapp.ui.coreui.base.TextEmojiLabel
                            android:textAppearance="@style/style05a7"
                            android:layout_gravity="left"
                            android:id="@id/event_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <com.whatsapp.ui.coreui.base.TextEmojiLabel
                            android:textAppearance="@style/style05a6"
                            android:textColor="?attr0a46"
                            android:ellipsize="end"
                            android:layout_gravity="left"
                            android:id="@id/event_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxLines="1" />
                        <ViewStub
                            android:id="@id/event_location"
                            android:layout="@layout/layout04c8"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <ViewStub
                            android:id="@id/event_call"
                            android:layout="@layout/layout04cc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <LinearLayout
                            android:orientation="horizontal"
                            android:id="@id/responses_row"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <com.whatsapp.ui.coreui.contact.FacepileView
                                android:gravity="center_vertical"
                                android:id="@id/responses_face_pile_view"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
