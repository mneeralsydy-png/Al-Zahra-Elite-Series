                            android:paddingBottom="@dimen/dimen0cec"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ViewStub
                                android:id="@id/broadcast_icon"
                                android:layout="@layout/layout0495"
                                android:inflatedId="@id/broadcast_icon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                            <ViewStub
                                android:id="@id/date"
                                android:layout="@layout/layout04b8"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
