                                facepile:attr0369="@dimen/dimen0597"
                                facepile:attr036a="@dimen/dimen056b"
                                facepile:attr036b="3"
                                facepile:attr036c="@dimen/dimen056a" />
                            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                                android:textAppearance="@style/style05a6"
                                android:textColor="?attr0a46"
                                android:gravity="center_vertical"
                                android:id="@id/responses_going_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:includeFontPadding="false"
                                android:layout_marginStart="@dimen/dimen0cec" />
                        </LinearLayout>
                        <LinearLayout
