<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@id/mlquality_feedback_onboarding_bottom_sheet"
        android:padding="@dimen/dimen0cee"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_gravity="center_vertical"
            android:paddingBottom="@dimen/dimen0cef"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layoutDirection="locale">
            <com.whatsapp.ui.coreui.base.WaImageButton
                android:layout_gravity="center_vertical"
                android:id="@id/feedback_close_button"
                android:background="?attr076e"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/str3dac"
                app:attr0838="@drawable/ic_close"
                app:attr090d="@color/color0347" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textAppearance="?attr0a08"
                android:gravity="center"
                android:id="@id/feedback_title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="@string/str3502"
                app:attr0a24="wds_font_headline2" />
        </FrameLayout>
        <ViewStub
            android:id="@id/feedback_view_stub"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:attr01cf="@dimen/dimen0cee"
            app:attr01d0="@dimen/dimen0ceb"
            app:attr0817="false" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textAppearance="?attr09fc"
            android:gravity="center"
            android:id="@id/feedback_description"
            android:paddingTop="@dimen/dimen0ce8"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str34ff"
            app:attr0a24="wds_font_body3" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:enabled="false"
            android:id="@id/feedback_submit_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen0ce7"
            android:text="@string/str32e9"
            style="@style/style0555" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>