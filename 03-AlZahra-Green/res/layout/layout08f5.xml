<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ScrollView
        android:id="@id/scroll_view"
        android:scrollbars="none"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.wds.components.banners.WDSBanner
                android:id="@id/add_bank_account_promo_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen103a"
                android:layout_marginTop="@dimen/dimen102e"
                android:layout_marginRight="@dimen/dimen103a"
                android:layout_marginBottom="@dimen/dimen102e"
                style="@style/style0571" />
            <ViewStub
                android:id="@id/profile_details_section_stub"
                android:layout="@layout/layout08f1"
                android:inflatedId="@id/profile_details_section"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <ViewStub
                android:id="@id/payment_methods_container_stub"
                android:layout="@layout/layout08f4"
                android:inflatedId="@id/payment_methods_container_stub"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <ViewStub
                android:id="@id/upi_number_container_stub"
                android:layout="@layout/layout08f6"
                android:inflatedId="@id/upi_number_container_stub"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <ViewStub
                android:id="@id/manage_account_container_stub"
                android:layout="@layout/layout08f2"
                android:inflatedId="@id/manage_account_container_stub"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingTop="@dimen/dimen1034"
                android:paddingBottom="@dimen/dimen102e"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="bottom"
                    style="@style/style02f5" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>