<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@id/conversation_contact"
    android:background="?attr0a59"
    android:clipChildren="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:paddingStart="@dimen/dimen1035"
    android:paddingEnd="@dimen/dimen1035"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaImageView
        android:id="@id/side_chat_close_button"
        android:background="?android:selectableItemBackgroundBorderless"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="@dimen/dimen0047"
        android:layout_height="@dimen/dimen0047"
        android:src="@drawable/ic_close"
        android:scaleType="center"
        android:tint="?attr0a47"
        android:layout_centerVertical="true"
        android:contentDescription="@string/str4275"
        android:layout_alignParentStart="true" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/content_container"
        android:paddingBottom="@dimen/dimen1039"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@id/history_button"
        android:layout_toEndOf="@id/side_chat_close_button">
        <FrameLayout
            android:id="@id/contact_photo_view"
            android:clickable="false"
            android:layout_width="@dimen/dimen0cb9"
            android:layout_height="@dimen/dimen0cb9">
            <FrameLayout
                android:layout_gravity="start|center"
                android:id="@id/side_chat_conversation_contact_photo_holder"
                android:layout_width="@dimen/dimen0cb8"
                android:layout_height="@dimen/dimen0cb8">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center"
                    android:id="@id/conversation_contact_photo"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:scaleType="fitCenter" />
            </FrameLayout>
            <FrameLayout
                android:layout_gravity="end|bottom|center"
                android:id="@id/side_chat_badge_container"
                android:background="@drawable/side_chat_badge_background"
                android:layout_width="@dimen/dimen0cb1"
                android:layout_height="@dimen/dimen0cb1">
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:layout_gravity="center"
                    android:id="@id/side_chat_badge_icon"
                    android:layout_width="@dimen/dimen0cb0"
                    android:layout_height="@dimen/dimen0cb0"
                    android:src="@drawable/ic_lock_meta_ai"
                    android:scaleType="fitCenter"
                    android:tint="?attr0a46" />
            </FrameLayout>
        </FrameLayout>
        <LinearLayout
            android:gravity="start|center"
            android:orientation="vertical"
            android:id="@id/conversation_contact_name_holder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:paddingStart="@dimen/dimen1039"
            android:paddingEnd="@dimen/dimen1039"
            android:layout_marginStart="@dimen/dimen1035">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.whatsapp.ui.coreui.base.TextEmojiLabel
                    android:textAppearance="@style/style05a4"
                    android:textColor="?attr0a47"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@id/conversation_contact_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="1"
                    android:scrollHorizontally="true"
                    android:singleLine="true" />
                <com.whatsapp.ui.coreui.base.WaImageView
                    android:id="@id/verified_badge"
                    android:layout_width="@dimen/dimen0cc1"
                    android:layout_height="@dimen/dimen0cc1"
                    android:src="@drawable/ic_verified_blue_16"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="@dimen/dimen1035" />
            </LinearLayout>
            <com.whatsapp.ui.coreui.base.TextEmojiLabel
                android:textAppearance="@style/style05a8"
                android:textColor="?attr0a47"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:id="@id/conversation_contact_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"
                android:singleLine="true" />
        </LinearLayout>
    </LinearLayout>
    <com.whatsapp.ui.coreui.base.WaImageView
        android:id="@id/history_button"
        android:background="?android:selectableItemBackgroundBorderless"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="@dimen/dimen0047"
        android:layout_height="@dimen/dimen0047"
        android:src="@drawable/wa_ic_history"
        android:scaleType="center"
        android:tint="?attr0a47"
        android:layout_centerVertical="true"
        android:contentDescription="@string/str4276"
        android:layout_toStartOf="@id/overflow_button" />
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="end|center"
        android:id="@id/overflow_button"
        android:background="?android:selectableItemBackgroundBorderless"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="@dimen/dimen0047"
        android:layout_height="@dimen/dimen0047"
        android:src="@drawable/wa_ic_more_vert"
        android:scaleType="center"
        android:tint="?attr0a47"
        android:layout_centerVertical="true"
        android:contentDescription="@string/str4277"
        android:layout_alignParentEnd="true" />
</RelativeLayout>