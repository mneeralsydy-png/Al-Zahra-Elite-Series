<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/root_background"
        android:background="#ffa52c71"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="0.0dip">
        <FrameLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_margin="0.0dip">
            <ImageView
                android:layout_gravity="center"
                android:id="@id/background_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop" />
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <LinearLayout
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:id="@id/background_imput"
                    android:background="@android:color/transparent"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0">
                    <EditText
                        android:textSize="40.0sp"
                        android:textColor="#ffffffff"
                        android:textColorHighlight="#33000000"
                        android:textColorHint="#33ffffff"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@id/imput"
                        android:background="@android:color/transparent"
                        android:padding="4.0dip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="8.0dip"
                        android:hint="@string/type_a_status" />
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:id="@id/linear5"
                    android:padding="4.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:gravity="center|left"
                        android:layout_gravity="center|left"
                        android:orientation="horizontal"
                        android:id="@id/tools"
                        android:background="#ff000000"
                        android:padding="4.0dip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.7">
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@id/ic_fancy"
                            android:padding="4.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4.0dip"
                            android:scaleType="center" />
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@id/ic_background"
                            android:padding="4.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4.0dip"
                            android:src="@drawable/ic_format_paint_white"
                            android:scaleType="center" />
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@id/ic_importbackground"
                            android:padding="4.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4.0dip"
                            android:src="@drawable/ic_insert_photo_white"
                            android:scaleType="center" />
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@id/ic_gradiente"
                            android:padding="4.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4.0dip"
                            android:src="@drawable/ic_gradient_white"
                            android:scaleType="center" />
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@id/ic_textcolor"
                            android:padding="4.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4.0dip"
                            android:src="@drawable/ic_colorize_white"
                            android:scaleType="center" />
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@id/ic_textfontsize"
                            android:padding="4.0dip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4.0dip"
                            android:src="@drawable/ic_format_size_white"
                            android:scaleType="center" />
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@id/linear6"
                        android:padding="8.0dip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0" />
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@id/fab"
                        android:layout_width="50.0dip"
                        android:layout_height="50.0dip"
                        android:layout_margin="8.0dip"
                        android:alpha="0.7">
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@id/ic_saveandsend"
                            android:background="#ff000000"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:src="@drawable/ic_send_white"
                            android:scaleType="center" />
                    </LinearLayout>
                </LinearLayout>
                <com.whatsapp.yo.tf
                    android:textSize="12.0sp"
                    android:textColor="#ffffffff"
                    android:gravity="center|left"
                    android:layout_gravity="center|left"
                    android:id="@id/help"
                    android:background="#ff000000"
                    android:padding="8.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/abuarab_statusimg_export"
                    android:singleLine="true"
                    android:alpha="0.6" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>