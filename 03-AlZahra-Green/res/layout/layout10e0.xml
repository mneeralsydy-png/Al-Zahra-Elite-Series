<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/progress_container"
    android:layout_width="@dimen/dimen0e25"
    android:layout_height="@dimen/dimen0e25"
    android:layout_centerHorizontal="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.CircularProgressBar
        android:layout_gravity="center_vertical"
        android:id="@id/progress_bar"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:indeterminate="false"
        android:indeterminateOnly="false"
        app:attr090d="@color/color0346" />
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center_vertical"
        android:id="@id/close"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="5.0dip"
        android:src="@drawable/ic_close"
        android:contentDescription="@string/str3d9b"
        app:attr090d="@color/color0346" />
</FrameLayout>