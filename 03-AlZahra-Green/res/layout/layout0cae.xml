<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen102e"
        android:minHeight="24.0dip">
        <com.whatsapp.ui.coreui.base.WaImageButton
            android:layout_gravity="start"
            android:id="@id/back"
            android:layout_width="24.0dip"
            android:layout_height="24.0dip"
            android:layout_marginLeft="@dimen/dimen102e"
            android:contentDescription="@string/str3dac"
            app:attr0838="@drawable/ic_close_white"
            app:attr090d="@color/color02b3"
            style="?attr0015" />
        <FrameLayout
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@id/title_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textSize="@dimen/dimen0fb0"
                android:textStyle="bold"
                android:textColor="?attr066e"
                android:layout_gravity="center_horizontal"
                android:id="@id/payment_incentive_bottom_sheet_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="36.0dip"
                android:layout_marginRight="36.0dip"
                android:lineSpacingExtra="8.0sp"
                android:textAlignment="center"
                android:layout_marginStart="36.0dip"
                android:layout_marginEnd="36.0dip" />
        </FrameLayout>
    </FrameLayout>
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center"
        android:layout_width="114.0dip"
        android:layout_height="64.0dip"
        android:layout_marginTop="@dimen/dimen102e"
        android:contentDescription="@string/str24b9"
        app:attr0838="@drawable/ic_incentive_main" />
    <com.whatsapp.ui.coreui.base.TextEmojiLabel
        android:textSize="@dimen/dimen0fb6"
        android:textColor="?attr0a46"
        android:id="@id/payment_incentive_bottom_sheet_body"
        android:paddingLeft="@dimen/dimen102e"
        android:paddingRight="@dimen/dimen102e"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen102e"
        android:text="@string/str193d"
        android:lineSpacingExtra="6.0sp" />
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@id/security_container"
        android:background="@drawable/rounded_corner_green_box"
        android:paddingTop="@dimen/dimen0a63"
        android:paddingBottom="@dimen/dimen0a63"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen0a5d"
        android:layout_marginTop="@dimen/dimen0a5d"
        android:layout_marginRight="@dimen/dimen0a5d">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_width="32.0dip"
            android:layout_height="32.0dip"
            android:layout_marginLeft="@dimen/dimen0a5d"
            android:layout_marginRight="@dimen/dimen0a5d"
            android:contentDescription="@string/str2dc7"
            app:attr0838="@drawable/settings_security"
            app:attr090d="?attr031b" />
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:textSize="@dimen/dimen0fb6"
            android:textColor="?attr0a46"
            android:id="@id/payment_savings_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen0a5d"
            android:text="@string/str2332"
            android:lineSpacingMultiplier="1.17" />
    </LinearLayout>
    <com.whatsapp.ui.wds.components.button.WDSButton
        android:id="@id/ok_button"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10.0dip"
        android:layout_marginTop="@dimen/dimen102f"
        android:layout_marginRight="10.0dip"
        android:layout_marginBottom="@dimen/dimen103a"
        android:text="@string/str22a9"
        style="@style/style0555" />
</LinearLayout>