<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:paddingBottom="@dimen/dimen102e"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.wds.components.topbar.WDSToolbar
        android:id="@id/end_time_toolbar"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingEnd="@dimen/dimen103b"
        app:attr02dd="gone"
        app:attr05cb="@drawable/vec_ic_close"
        app:attr0912="true"
        style="@style/style05c2" />
    <RadioGroup
        android:id="@id/end_time_radio_group"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/dimen103b"
        android:paddingEnd="@dimen/dimen103b">
        <com.whatsapp.ui.wds.components.radiobutton.WDSRadioButton
            android:id="@id/end_time_none"
            android:paddingTop="@dimen/dimen102e"
            android:paddingBottom="@dimen/dimen102e"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/str4085"
            app:attr0a24="wds_font_body1" />
        <com.whatsapp.ui.wds.components.radiobutton.WDSRadioButton
            android:id="@id/end_time_set"
            android:paddingTop="@dimen/dimen102e"
            android:paddingBottom="@dimen/dimen102e"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str41cf"
            app:attr0a24="wds_font_body1" />
    </RadioGroup>
</LinearLayout>