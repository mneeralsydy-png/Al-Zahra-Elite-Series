<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:background="@drawable/selector_orange_gradient"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout
        android:id="@id/community_selector"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dimen0450">
        <com.whatsapp.ui.coreui.base.WaImageView
            android:layout_gravity="center"
            android:id="@id/community_icon"
            android:layout_width="@dimen/dimen0333"
            android:layout_height="@dimen/dimen0333"
            android:layout_marginLeft="@dimen/dimen0cc9"
            android:layout_marginTop="@dimen/dimen02ca"
            android:layout_marginRight="@dimen/dimen0cc9"
            android:layout_marginBottom="@dimen/dimen02ca"
            android:scaleType="centerCrop"
            android:importantForAccessibility="no" />
    </FrameLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen0450">
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:gravity="start|center"
            android:id="@id/community_subject"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str1fb1"
            android:textAlignment="viewStart"
            style="@style/style0289" />
    </LinearLayout>
</LinearLayout>