<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center|top"
        android:orientation="vertical"
        android:id="@id/request_review_view"
        android:padding="@dimen/dimen103b"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:id="@id/request_review_title"
            android:paddingBottom="@dimen/dimen102e"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str20f4"
            app:attr049a="parent"
            app:attr04ad="parent"
            app:attr04b1="parent"
            app:attr0a24="wds_font_headline2"
            style="@style/style05ab" />
        <com.google.android.material.textfield.TextInputLayout
            android:id="@id/additional_information_input_layout"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            app:attr0285="true"
            app:attr0286="250"
            app:attr049a="parent"
            app:attr04ad="parent"
            app:attr04b0="@id/request_review_title"
            style="@style/style0336">
            <com.google.android.material.textfield.TextInputEditText
                android:gravity="start|center|top"
                android:id="@id/additional_information_input_field"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:lines="6" />
        </com.google.android.material.textfield.TextInputLayout>
        <View
            android:id="@id/request_review_divider"
            android:layout_marginTop="@dimen/dimen102e"
            android:layout_marginBottom="@dimen/dimen102e"
            app:attr0495="@id/request_review_footnote"
            app:attr049a="parent"
            app:attr04ad="parent"
            style="@style/style0355" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:id="@id/request_review_footnote"
            android:paddingBottom="@dimen/dimen1039"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str20f8"
            app:attr0495="@id/request_review_submit_button"
            app:attr049a="parent"
            app:attr04ad="parent"
            app:attr0a24="wds_font_body3"
            style="@style/style05a8" />
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="@id/request_review_submit_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str2c52"
            app:attr0494="parent"
            app:attr049a="parent"
            app:attr04ad="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>