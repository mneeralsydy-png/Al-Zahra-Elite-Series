<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:robobunny="http://robobunny.com">
    <PreferenceCategory
        android:layout="@layout/abu_arab_preference_category"
        android:title="@string/settings_chat">
        <SwitchPreference
            android:icon="@drawable/abo_arab_bubblephoto"
            android:layout="@layout/abu_arab_preference_layout"
            android:title="@string/inside_bubble"
            android:key="pic_inside"
            android:defaultValue="false" />
        <SwitchPreference
            android:icon="@drawable/abo_arab_contactphoto"
            android:layout="@layout/abu_arab_preference_layout"
            android:title="@string/chat_contact_pic"
            android:key="chat_contactpicV2"
            android:summary="@string/chat_contact_pic_summary"
            android:dependency="pic_inside"
            android:defaultValue="false" />
        <SwitchPreference
            android:icon="@drawable/abo_arab_ic_mephoto"
            android:layout="@layout/abu_arab_preference_layout"
            android:title="@string/chat_my_pic"
            android:key="chat_mypicV2"
            android:summary="@string/chat_my_pic_summary"
            android:dependency="pic_inside"
            android:defaultValue="false" />
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/abu_arab_preference_category"
        android:title="@string/action_settings">
        <com.whatsapp.yo.SeekBarPreference
            android:max="64"
            android:title="@string/pic_chat_size"
            android:key="pic_chat_size_pickerV2"
            android:summary="@string/pic_chat_size_summary"
            android:dependency="pic_inside"
            android:defaultValue="40"
            robobunny:min="10"
            robobunny:unitsLeft=""
            robobunny:unitsRight="dp" />
    </PreferenceCategory>
</PreferenceScreen>