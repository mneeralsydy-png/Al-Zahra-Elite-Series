<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="bottom"
    android:orientation="horizontal"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="top"
        android:orientation="vertical"
        android:id="@id/cancel_call_back"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0">
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/cancel_callback_image_btn_stub"
            android:layout="@layout/layout0316"
            android:inflatedId="@id/cancel_call_back_btn"
            android:layout_width="@dimen/dimen01ac"
            android:layout_height="@dimen/dimen01ac" />
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/cancel_callback_wds_btn_stub"
            android:layout="@layout/layout0317"
            android:inflatedId="@id/cancel_call_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/cancel_call_back_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str3d9b"
            android:shadowColor="@color/color089a"
            android:shadowDx="1.0"
            android:shadowDy="1.0"
            android:shadowRadius="2.0"
            android:importantForAccessibility="no"
            style="@style/style013b" />
    </LinearLayout>
    <ViewStub
        android:layout_gravity="top"
        android:id="@id/message"
        android:layout="@layout/layout02ae"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0" />
    <ViewStub
        android:layout_gravity="top"
        android:id="@id/voicemail"
        android:layout="@layout/layout02b0"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0" />
    <LinearLayout
        android:layout_gravity="top"
        android:orientation="vertical"
        android:id="@id/call_back"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0">
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/call_back_image_btn_stub"
            android:layout="@layout/layout0297"
            android:inflatedId="@id/call_back_btn"
            android:layout_width="@dimen/dimen01ac"
            android:layout_height="@dimen/dimen01ac" />
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/call_back_wds_btn_stub"
            android:layout="@layout/layout0298"
            android:inflatedId="@id/call_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:id="@id/call_back_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/str4030"
            android:shadowColor="@color/color089a"
            android:shadowDx="1.0"
            android:shadowDy="1.0"
            android:shadowRadius="2.0"
            android:importantForAccessibility="no"
            style="@style/style013b" />
    </LinearLayout>
</LinearLayout>