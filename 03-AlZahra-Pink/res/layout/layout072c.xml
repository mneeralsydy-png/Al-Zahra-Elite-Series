<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout
        android:id="@id/video_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <View
        android:id="@id/thumbnailBackground"
        android:background="?attr0a2d"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <com.whatsapp.mediaview.api.PhotoView
        android:layout_gravity="center"
        android:id="@id/thumbnail"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true" />
    <com.whatsapp.videoplayback.ExoPlayerErrorFrame
        android:id="@id/exoplayer_error_elements"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <com.whatsapp.videoplayback.FbHeroPlaybackControlView
        android:id="@id/controlView"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
</FrameLayout>