<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:layoutDirection="locale"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:layoutDirection="ltr">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="?attr0a46"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:singleLine="true"
            android:layout_alignBaseline="@id/registration_cc"
            android:layout_centerVertical="true"
            android:importantForAccessibility="no"
            android:paddingStart="@dimen/dimen054f"
            android:paddingEnd="@dimen/dimen054f"
            android:layout_alignParentStart="true"
            app:attr0a24="wds_font_body1"
            style="@style/style05a4" />
        <com.whatsapp.ui.coreui.WaEditText
            android:textColor="?attr066e"
            android:ellipsize="end"
            android:gravity="start|center"
            android:id="@id/registration_cc"
            android:layout_width="@dimen/dimen054e"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:lines="1"
            android:singleLine="true"
            android:digits=" 0123456789"
            android:layout_centerVertical="true"
            android:inputType="phone"
            android:imeOptions="actionDone"
            android:textAlignment="viewStart"
            android:paddingStart="@dimen/dimen102f"
            android:paddingEnd="@dimen/dimen054f"
            style="@style/style05a4" />
    </RelativeLayout>
    <com.whatsapp.ui.coreui.WaEditText
        android:textColor="?attr066e"
        android:textColorHint="?attr0a46"
        android:ellipsize="end"
        android:gravity="start|center"
        android:layout_gravity="center_vertical"
        android:id="@id/registration_phone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:hint="@string/str2afb"
        android:singleLine="true"
        android:selectAllOnFocus="true"
        android:digits="0123456789( )-"
        android:layout_weight="1.0"
        android:inputType="phone"
        android:imeOptions="actionDone"
        android:textAlignment="viewStart"
        android:layout_marginStart="5.0dip"
        style="@style/style05a4" />
</LinearLayout>