<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/phone_container"
    android:layout_width="fill_parent"
    android:layout_height="@dimen/dimen0ccb"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center|left"
        android:id="@id/phone_content"
        android:background="@drawable/selector_orange_gradient"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false">
        <LinearLayout
            android:gravity="center|left"
            android:id="@id/primary_action_btn"
            android:background="@drawable/selector_orange_gradient"
            android:paddingLeft="@dimen/dimen06a4"
            android:layout_width="0.0dip"
            android:layout_height="@dimen/dimen0ccb"
            android:baselineAligned="false"
            android:layout_weight="1.0">
            <LinearLayout
                android:gravity="center|left"
                android:layout_gravity="center|left"
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:layout_gravity="left"
                    android:id="@id/title_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/style0289" />
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:layout_gravity="left"
                    android:id="@id/subtitle_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/style0288" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/contact_info_phone_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/primary_action_icon"
                android:contentDescription="@string/str1d36"
                app:attr0838="@drawable/vec_ic_chat"
                style="@style/style0283" />
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/secondary_action_btn"
                android:contentDescription="@string/str3d5c"
                app:attr0838="@drawable/ic_call_white"
                style="@style/style0283" />
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/third_action_btn"
                android:visibility="gone"
                android:contentDescription="@string/str4307"
                app:attr0838="@drawable/ic_videocam_white"
                style="@style/style0283" />
        </LinearLayout>
    </LinearLayout>
    <View
        android:id="@id/divider"
        android:layout_marginLeft="@dimen/dimen06a4"
        style="@style/style0355" />
</LinearLayout>