<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/product_detail_image_container"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.components.button.ThumbnailButton
        android:layout_gravity="center"
        android:id="@id/product_detail_image"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:contentDescription="@string/str07ec" />
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center"
        android:id="@id/play"
        android:background="@drawable/exo_player_gray_circle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="center"
        android:contentDescription="@string/str28f7"
        app:attr0838="@drawable/ic_video_play" />
</FrameLayout>