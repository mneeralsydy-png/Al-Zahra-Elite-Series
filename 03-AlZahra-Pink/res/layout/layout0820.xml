                android:gravity="center"
                android:id="@id/learn_more"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dimen0ce7"
                android:text="@string/str1845"
                android:maxLines="1"
                app:attr04d0="20.0sp"
                style="@style/style0557" />
