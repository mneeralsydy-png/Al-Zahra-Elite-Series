            android:padding="@dimen/dimen0cea"
            android:paddingBottom="@dimen/dimen0ce8"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="90.0dip"
                app:attr0838="@drawable/wds_picto_privacy_business" />
            <com.whatsapp.ui.coreui.base.WaTextView
                android:textColor="@color/color08df"
                android:gravity="center"
                android:id="@id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen0cea"
                android:text="@string/str1848"
                android:layout_marginStart="@dimen/dimen0cea"
                android:layout_marginEnd="@dimen/dimen0cea"
                app:attr04d0="@dimen/dimen0456"
                app:attr0a24="wds_font_headline1"
