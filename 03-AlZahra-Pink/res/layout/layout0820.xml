            <com.whatsapp.ui.coreui.base.WaTextView
                android:textColor="@color/color0282"
                android:id="@id/description"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen0cea"
                android:text="@string/str1846"
                android:lineSpacingExtra="@dimen/dimen0cec"
                android:textAlignment="viewStart"
                android:layout_marginStart="@dimen/dimen0cea"
                android:layout_marginEnd="@dimen/dimen0cea"
                android:letterSpacing="0.025"
                app:attr04d0="20.0sp"
                app:attr0a24="wds_font_body2"
                style="@style/style05a6" />
            <com.whatsapp.ui.wds.components.button.WDSButton
                android:textSize="@dimen/dimen0fb6"
                android:gravity="center"
                android:id="@id/close"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen0cea"
                android:text="@string/str22a9"
                android:maxLines="1"
                android:layout_marginStart="@dimen/dimen0ce7"
                android:layout_marginEnd="@dimen/dimen0ce7"
                app:attr04d0="20.0sp"
