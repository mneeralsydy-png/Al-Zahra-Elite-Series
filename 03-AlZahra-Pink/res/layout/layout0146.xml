<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:id="@id/bot_list_item"
    android:background="?android:selectableItemBackground"
    android:paddingTop="@dimen/dimen1039"
    android:paddingBottom="@dimen/dimen1039"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/dimen102e"
    android:paddingEnd="@dimen/dimen102e"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:whatsapp="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.wds.components.profilephoto.WDSProfilePhoto
        android:layout_gravity="center"
        android:id="@id/photo"
        android:layout_width="@dimen/dimen0146"
        android:layout_height="@dimen/dimen0146"
        android:layout_marginEnd="@dimen/dimen103a" />
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@id/card_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:id="@id/name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/style0289" />
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:id="@id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/style0285" />
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:id="@id/author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/style0286" />
    </LinearLayout>
</LinearLayout>