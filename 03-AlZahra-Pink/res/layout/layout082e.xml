            android:layout_width="@dimen/dimen0766"
            android:layout_height="@dimen/dimen0765" />
        <FrameLayout
            android:background="?attr0a59"
            android:clipChildren="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/list_holder_shadow"
                android:layout_width="fill_parent"
                android:layout_height="8.0dip"
                android:layout_marginTop="-8.0dip"
                android:scaleType="fitXY"
                app:attr0838="@drawable/shadow_send_location" />
            <androidx.recyclerview.widget.RecyclerView
