<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.ui.coreui.base.WaImageButton
        android:layout_gravity="top"
        android:id="@id/uc_bottomsheet_close"
        android:background="@null"
        android:layout_width="@dimen/dimen0755"
        android:layout_height="@dimen/dimen0755"
        android:layout_marginTop="@dimen/dimen0ce8"
        android:tint="@color/color08de"
        android:contentDescription="@string/str3dac"
        android:layout_marginStart="@dimen/dimen0cee"
        android:layout_marginEnd="@dimen/dimen0cee"
        app:attr0838="@drawable/ic_close_themed" />
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0">
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/uc_bottomsheet_title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/str1c30"
            android:maxLines="1"
            app:attr0a24="wds_font_body1"
            style="@style/style05a4" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/uc_bottomsheet_sut_title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:attr0a24="wds_font_body3"
            style="@style/style05a8" />
    </LinearLayout>
    <View
        android:visibility="invisible"
        android:layout_width="@dimen/dimen0755"
        android:layout_height="@dimen/dimen0755"
        android:layout_marginTop="@dimen/dimen0ce8"
        android:layout_marginStart="@dimen/dimen0cee"
        android:layout_marginEnd="@dimen/dimen0cee" />
</LinearLayout>