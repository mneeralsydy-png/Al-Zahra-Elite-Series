<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:orientation="vertical"
    android:background="@color/yosettings_background"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:title="settings_general"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:descendantFocusability="blocksDescendants"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <include
            layout="@layout/yo_toolbar" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/participants_card"
            android:background="@drawable/rounded_card"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/header"
                android:tag="@string/yo_settings_header"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="8.0dip"
                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:src="@drawable/home_header"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <com.whatsapp.yo.tf
                    android:text="@string/yo_settings_header"
                    style="@style/YoSettings_row_more" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/modRows"
                android:tag="@string/yo_settings_rows"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="8.0dip"
                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:src="@drawable/home_rows"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <com.whatsapp.yo.tf
                    android:text="@string/yo_settings_rows"
                    style="@style/YoSettings_row_more" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:onClick="AbuArabQuickContact">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="8.0dip"
                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:src="@drawable/abo_arab_ic_stylectt"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <com.whatsapp.yo.tf
                    android:text="@string/Abo_Arab_Speed_Dial_Baslik"
                    style="@style/YoSettings_row_more" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/modFab"
                android:tag="@string/acjfabtab"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="8.0dip"
                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:src="@drawable/home_floating"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <com.whatsapp.yo.tf
                    android:text="@string/acjfabtab"
                    style="@style/YoSettings_row_more" />
            </LinearLayout>
            <View
                android:layout_marginLeft="@dimen/settings_row_horizontal_padding"
                android:layout_marginRight="@dimen/settings_row_horizontal_padding"
                android:layout_marginStart="@dimen/settings_row_horizontal_padding"
                android:layout_marginEnd="@dimen/settings_row_horizontal_padding"
                style="@style/FlatCardSeparator" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/status"
                android:tag="@string/statuses"
                android:background="?android:selectableItemBackground"
                android:padding="@dimen/info_screen_padding"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <ImageView
                    android:background="@drawable/Abo_Arab_WA5"
                    android:padding="8.0dip"
                    android:layout_width="40.0dip"
                    android:layout_height="40.0dip"
                    android:src="@drawable/home_status"
                    android:scaleType="centerInside"
                    android:tint="@color/icon_primary"
                    android:layout_marginStart="12.0dip" />
                <com.whatsapp.yo.tf
                    android:text="@string/settings_privacy_status"
                    style="@style/YoSettings_row_more" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:padding="@dimen/info_screen_padding"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginLeft="16.0dip"
            android:layout_marginTop="@dimen/settings_divider_text_margin_top"
            android:layout_marginRight="16.0dip">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10.0dip"
                android:layout_marginTop="15.0dip"
                android:layout_marginRight="10.0dip"
                android:layout_marginBottom="15.0dip">
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="0.0dip"
                    android:layout_height="2.0dip"
                    android:src="@color/abo_arab_accent"
                    android:layout_weight="1.0" />
                <com.whatsapp.yo.tf
                    android:textSize="18.0sp"
                    android:textStyle="bold"
                    android:textColor="@color/abo_arab_accent"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5.0dip"
                    android:layout_marginRight="5.0dip"
                    android:text="@string/yo_mods" />
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="0.0dip"
                    android:layout_height="2.0dip"
                    android:src="@color/abo_arab_accent"
                    android:layout_weight="1.0" />
            </LinearLayout>
            <com.whatsapp.youbasha.ui.YoNoScrollListView
                android:id="@android:id/list"
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:divider="@drawable/divider_gray"
                android:layout_weight="1.0" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>