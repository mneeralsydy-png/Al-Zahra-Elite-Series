<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.whatsapp.videoplayback.VideoSurfaceView
        android:layout_gravity="center"
        android:id="@id/video_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:scaleType="fitCenter" />
    <ProgressBar
        android:layout_gravity="center"
        android:id="@id/loading_progress"
        android:layout_width="70.0dip"
        android:layout_height="70.0dip" />
    <com.whatsapp.ui.coreui.base.WaImageView
        android:layout_gravity="center"
        android:id="@id/play_button"
        android:background="@drawable/exo_player_gray_circle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="fitCenter"
        android:contentDescription="@string/str28f7"
        app:attr0838="@drawable/ic_video_play" />
</FrameLayout>