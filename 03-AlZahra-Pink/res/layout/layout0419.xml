<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.facebook.smartcapture.components.DottedAlignmentView
        android:id="@id/dotted_alignment_view"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:alpha="0.0" />
    <com.facebook.smartcapture.components.DarkenedFrameView
        android:id="@id/darkened_frame_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <ImageView
        android:id="@id/iv_contour_top_left"
        android:src="@drawable/camera_contour_corner_rounded"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        style="@style/style01ac" />
    <ImageView
        android:id="@id/iv_contour_top_right"
        android:src="@drawable/camera_contour_corner_rounded"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:rotation="90.0"
        style="@style/style01ac" />
    <ImageView
        android:id="@id/iv_contour_bottom_left"
        android:src="@drawable/camera_contour_corner_rounded"
        android:layout_alignParentLeft="true"
        android:layout_alignParentBottom="true"
        android:rotation="270.0"
        style="@style/style01ac" />
    <ImageView
        android:id="@id/iv_contour_bottom_right"
        android:src="@drawable/camera_contour_corner_rounded"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:rotation="180.0"
        style="@style/style01ac" />
    <TextView
        android:textSize="20.0sp"
        android:textStyle="bold"
        android:textColor="?attr070a"
        android:gravity="center"
        android:id="@id/tv_text_tip"
        android:padding="8.0dip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="9.0dip"
        android:shadowColor="?attr0713"
        android:shadowRadius="15.0"
        android:drawablePadding="8.0dip"
        android:layout_centerHorizontal="true" />
</RelativeLayout>