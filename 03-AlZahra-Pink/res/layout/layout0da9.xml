<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        style="@style/style0216">
        <LinearLayout
            style="@style/style0217">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/description_row_one_icon"
                app:attr0838="@drawable/ic_call"
                style="@style/style01dc" />
            <LinearLayout
                style="@style/style01dd">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:id="@id/make_and_manage_calls"
                    android:text="@string/str1c2b"
                    style="@style/style0215" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            style="@style/style0217">
            <com.whatsapp.ui.coreui.base.WaImageView
                android:id="@id/description_row_two_icon"
                app:attr0838="@drawable/ic_call_log"
                style="@style/style01dc" />
            <LinearLayout
                style="@style/style01dd">
                <com.whatsapp.ui.coreui.base.WaTextView
                    android:id="@id/access_phone_call_logs"
                    android:text="@string/str007b"
                    style="@style/style0215" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <com.whatsapp.ui.coreui.base.TextEmojiLabel
        android:textColorLink="?attr0a49"
        android:gravity="bottom|center"
        android:id="@id/flash_call_learn_more"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen05c1"
        android:layout_marginRight="@dimen/dimen05c1"
        android:text="@string/str1acc"
        android:lineSpacingMultiplier="1.25"
        style="@style/style05a8" />
</LinearLayout>