<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="?android:selectableItemBackground"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_width="80.0dip"
        android:layout_height="fill_parent">
        <ImageView
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_in_progress"
            android:tint="#ff111b21" />
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="18.0dip"
        android:layout_marginBottom="18.0dip"
        android:layout_weight="1.0">
        <TextView
            android:textSize="15.0sp"
            android:textStyle="bold"
            android:textColor="#ff111b21"
            android:id="@id/abu_arab_update_title_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:includeFontPadding="false" />
        <TextView
            android:textSize="15.0sp"
            android:textColor="#ff111b21"
            android:id="@id/abu_arab_update_msg_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5.0dip"
            android:text=""
            android:includeFontPadding="false" />
    </LinearLayout>
    <FrameLayout
        android:background="?android:selectableItemBackground"
        android:layout_width="28.0dip"
        android:layout_height="28.0dip"
        android:layout_marginLeft="12.0dip"
        android:layout_marginTop="12.0dip"
        android:layout_marginRight="12.0dip"
        android:layout_marginBottom="12.0dip">
        <ImageView
            android:layout_gravity="center"
            android:id="@id/abu_arab_close_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_close"
            android:tint="#ff667781" />
    </FrameLayout>
</LinearLayout>