<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_horizontal"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:background="@drawable/music_shape_background"
    android:padding="@dimen/dimen1031"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@id/music_shape_artwork"
            android:layout_width="@dimen/dimen09cb"
            android:layout_height="@dimen/dimen09cb" />
        <ViewStub
            android:layout_gravity="center"
            android:id="@id/music_artwork_error"
            android:layout="@layout/layout0b42"
            android:inflatedId="@id/music_artwork_error"
            android:layout_width="@dimen/dimen09c1"
            android:layout_height="@dimen/dimen09c1" />
    </FrameLayout>
    <TextView
        android:textSize="@dimen/dimen09cc"
        android:textStyle="bold"
        android:textColor="@color/color089a"
        android:ellipsize="end"
        android:id="@id/music_shape_title"
        android:paddingTop="@dimen/dimen1030"
        android:paddingBottom="@dimen/dimen1030"
        android:layout_width="@dimen/dimen09cb"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:textAlignment="center"
        android:paddingStart="@dimen/dimen1039"
        android:paddingEnd="@dimen/dimen1039" />
    <TextView
        android:textSize="@dimen/dimen09cd"
        android:textColor="@color/color089a"
        android:ellipsize="end"
        android:id="@id/music_shape_artist"
        android:paddingBottom="@dimen/dimen1030"
        android:layout_width="@dimen/dimen09cb"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:textAlignment="center"
        android:paddingStart="@dimen/dimen1039"
        android:paddingEnd="@dimen/dimen1039" />
</LinearLayout>