<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/title_bar"
        android:paddingTop="@dimen/dimen1030"
        android:paddingBottom="@dimen/dimen1039"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.WaImageButton
            android:id="@id/text_variants_selection_dismiss"
            android:background="@drawable/selector_orange_gradient"
            android:padding="@dimen/dimen064c"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen1030"
            android:layout_marginBottom="@dimen/dimen1030"
            android:tint="?attr066e"
            android:contentDescription="@string/str3dac" />
        <com.whatsapp.ui.coreui.base.WaTextView
            android:textColor="?attr066e"
            android:layout_gravity="center"
            android:id="@id/variants_screen_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:attr0a24="wds_font_headline2"
            style="@style/style05ab" />
    </FrameLayout>
    <androidx.core.widget.NestedScrollView
        android:id="@id/variants_scroll"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_weight="1.0">
        <RadioGroup
            android:id="@id/variant_radio_group"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dimen1034"
            android:paddingEnd="@dimen/dimen1034" />
    </androidx.core.widget.NestedScrollView>
</LinearLayout>