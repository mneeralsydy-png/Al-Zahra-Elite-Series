            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen0cea"
            android:layout_marginTop="@dimen/dimen0ce7"
            android:layout_marginRight="@dimen/dimen0cea"
